@model SupportTicketSysterm.ViewModels.ForgotPasswordViewModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Khôi phục mật khẩu - Bước 1 | TechSupport</title>
    <link rel="icon" type="image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/assets/css/site.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/forgot-password.css" asp-append-version="true">
</head>

<body>

    <!-- Back to Login Button -->
    <a href="@Url.Action("DangNhap", "Auth")" class="btn-back-home" title="Quay về trang đăng nhập">
        <i class="bi bi-arrow-left"></i>
    </a>

    <div class="login-wrapper">
        <div class="container">
            <div class="row justify-content-center align-items-center min-vh-100">
                <div class="col-lg-10 col-xl-8">
                    <div class="login-card shadow-lg">
                        <div class="row g-0">
                            <!-- Left side: Info & Banner -->
                            <div class="col-lg-6 login-info p-4 p-xl-5">
                                <div class="brand mb-4">
                                    <i class="fa-solid fa-cpu-fill"></i>
                                    <span>Tech<span class="text-danger">Support</span></span>
                                </div>
                                <h2 class="fw-bold mb-3">Khôi phục mật khẩu</h2>
                                <p class="text-white-50 mb-4">Nhận mã xác thực qua Email hoặc Số điện thoại để thiết lập lại mật khẩu tài khoản TechSupport của bạn.</p>

                                <div class="feature-list">
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Bảo mật 2 lớp qua Email OTP</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Tự động mã hóa mật khẩu mới</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Khôi phục tài khoản nhanh chóng</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Hỗ trợ khôi phục qua SĐT liên kết</span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3">
                                    <p class="text-white-50 small mb-0">
                                        <i class="bi bi-shield-check"></i> Bảo mật thông tin tuyệt đối
                                    </p>
                                </div>
                            </div>

                            <!-- Right side: Enter Email Form -->
                            <div class="col-lg-6 login-form p-4 p-xl-5 d-flex flex-column justify-content-center">
                                <div class="text-center mb-4">
                                    <h3 class="fw-bold text-dark">Quên mật khẩu?</h3>
                                    <p class="text-muted">Nhập thông tin tài khoản của bạn</p>
                                </div>

                                @if (!Html.ViewData.ModelState.IsValid)
                                {
                                    <div class="alert alert-danger border-0 rounded-3 mb-3 shadow-sm" style="font-size:0.85rem;">
                                        <div asp-validation-summary="ModelOnly" class="text-danger fw-semibold"></div>
                                        <ul class="mb-0 ps-3">
                                            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                            {
                                                <li>@error.ErrorMessage</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                <form id="forgotForm" asp-controller="Auth" asp-action="ForgotPassword" method="post" class="needs-validation" novalidate>
                                    @Html.AntiForgeryToken()

                                    <div class="mb-4">
                                        <label asp-for="Email" class="form-label fw-semibold">Email hoặc Số điện thoại</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-user text-danger"></i>
                                            </span>
                                            <input asp-for="Email" class="form-control border-start-0" placeholder="Email hoặc số điện thoại" required autocomplete="email">
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger small mt-1 d-block"></span>
                                    </div>

                                    <button type="submit" id="btnSendOtp" class="btn-submit w-100 py-2 mb-3">
                                        <span class="btn-text">
                                            <i class="fa-solid fa-paper-plane me-2"></i> Gửi mã OTP
                                        </span>
                                        <span class="spinner" style="display: none;">
                                            <i class="fa-solid fa-circle-notch fa-spin me-2"></i> Đang gửi mã...
                                        </span>
                                    </button>

                                    <div class="text-center">
                                        <p class="mb-0">
                                            Quay lại <a href="@Url.Action("DangNhap", "Auth")" class="text-danger fw-semibold text-decoration-none">Đăng nhập</a>
                                        </p>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    <!-- Client-side Loading effect -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('forgotForm');
            const btn = document.getElementById('btnSendOtp');
            if (form && btn) {
                form.addEventListener('submit', () => {
                    if (form.checkValidity()) {
                        const btnText = btn.querySelector('.btn-text');
                        const spinner = btn.querySelector('.spinner');
                        if (btnText && spinner) {
                            btnText.style.display = 'none';
                            spinner.style.display = 'inline-flex';
                        }
                        btn.disabled = true;
                    }
                });
            }
        });
    </script>
</body>

</html>
