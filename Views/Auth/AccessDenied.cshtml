@{
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
    ViewData["Title"] = "Từ chối truy cập";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center" style="min-height: 50vh; padding-top: 80px; padding-bottom: 80px;">
        <div class="col-md-6 text-center">
            <div class="mb-4">
                <i class="bi bi-shield-slash text-danger" style="font-size: 6rem; filter: drop-shadow(0 4px 6px rgba(238, 0, 51, 0.2));"></i>
            </div>
            <h1 class="fw-bold text-dark mb-3">TỪ CHỐI TRUY CẬP</h1>
            <p class="text-muted fs-5 mb-4">
                Bạn không có quyền hạn để xem nội dung trang này. Vui lòng kiểm tra lại tài khoản hoặc đăng nhập với vai trò phù hợp.
            </p>
            <div class="d-flex justify-content-center gap-3">
                <a href="/" class="btn btn-outline-secondary px-4 py-2 rounded-pill">
                    <i class="bi bi-house-door me-2"></i> Quay về trang chủ
                </a>
                <a asp-controller="Auth" asp-action="DangNhap" class="btn btn-danger px-4 py-2 rounded-pill" style="background-color: #EE0033; border-color: #EE0033;">
                    <i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập tài khoản khác
                </a>
            </div>
        </div>
    </div>
</div>
