@{
    Layout = null;
}
@model SupportTicketSysterm.Models.DangNhapViewModel

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Đăng nhập | TechSupport - Hệ thống quản lý phiếu hỗ trợ kỹ thuật</title>

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome 6 (for Chat Widget) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
    <!-- Chatbox Widget CSS -->
    <link rel="stylesheet" href="assets/css/chatbox.css">
    <!-- Google Font -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@500;600;700;800&display=swap"
          rel="stylesheet">

    <!-- Site CSS -->
    <link rel="stylesheet" href="~/assets/css/site.css">
    <!-- Login CSS -->
    <link rel="stylesheet" href="~/assets/css/login.css">
</head>

<body>

    <!-- Back to Home Button -->
    <a href="/" class="btn-back-home" title="Quay về trang chủ">
        <i class="bi bi-arrow-left"></i>
    </a>

    <div class="login-wrapper">
        <div class="container">
            <div class="row justify-content-center align-items-center min-vh-100">
                <div class="col-lg-10 col-xl-8">
                    <div class="login-card shadow-lg">
                        <div class="row g-0">
                            <!-- Left side: Info & Banner -->
                            <div class="col-lg-6 login-info p-4 p-xl-5">
                                <div class="brand mb-4">
                                    <i class="fa-solid fa-cpu-fill"></i>
                                    <span>Tech<span class="text-danger">Support</span></span>
                                </div>
                                <h2 class="fw-bold mb-3">Chào mừng bạn trở lại!</h2>
                                <p class="text-white-50 mb-4">
                                    Đăng nhập để quản lý phiếu hỗ trợ kỹ thuật, theo dõi tiến
                                    độ xử lý và nhận thông báo quan trọng.
                                </p>

                                <div class="feature-list">
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Quản lý tất cả phiếu hỗ trợ</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Theo dõi tiến độ xử lý realtime</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Nhận thông báo qua email & SMS</span>
                                    </div>
                                    <div class="feature-item">
                                        <i class="fa-solid fa-circle-check"></i>
                                        <span>Hỗ trợ kỹ thuật chuyên nghiệp 24/7</span>
                                    </div>
                                </div>

                                <div class="mt-4 pt-3">
                                    <p class="text-white-50 small mb-0">
                                        <i class="bi bi-shield-check"></i> 🔒 Bảo mật tuyệt đối thông tin cá nhân
                                    </p>
                                </div>
                            </div>

                            <!-- Right side: Login Form -->
                            <div class="col-lg-6 login-form p-4 p-xl-5">
                                <div class="text-center mb-4">
                                    <h3 class="fw-bold text-dark">Đăng nhập</h3>
                                    <p class="text-muted">Nhập thông tin tài khoản của bạn</p>
                                </div>

                                @if (!ViewData.ModelState.IsValid)
                                {
                                    <div asp-validation-summary="All" class="alert alert-danger py-2 px-3 mb-3" role="alert"></div>
                                }

                                <form id="loginForm" asp-controller="Auth" asp-action="DangNhap" asp-route-returnUrl="@ViewBag.ReturnUrl" method="post">
                                    @Html.AntiForgeryToken()
                                    <!-- Tên đăng nhập -->
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold" asp-for="TenDangNhap">Email hoặc số điện thoại</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-user text-danger"></i>
                                            </span>
                                            <input asp-for="TenDangNhap" type="text" class="form-control border-start-0" id="loginIdentifier"
                                                   placeholder="Nhập email hoặc số điện thoại" required>
                                        </div>
                                        <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
                                    </div>

                                    <!-- Mật khẩu -->
                                    <div class="mb-3">
                                        <label class="form-label fw-semibold" asp-for="MatKhau">Mật khẩu</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-lock text-danger"></i>
                                            </span>
                                            <input asp-for="MatKhau" type="password" class="form-control border-start-0" id="password"
                                                   placeholder="••••••••" required>
                                            <button class="btn btn-outline-secondary border-start-0 toggle-password"
                                                    type="button" data-target="password">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        </div>
                                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                                    </div>

                                    <!-- Remember me & Forgot password -->
                                    <div class="d-flex justify-content-between align-items-center mb-4">
                                        <div class="form-check">
                                            <input asp-for="RememberMe" type="checkbox" class="form-check-input" id="rememberMe">
                                            <label class="form-check-label small" asp-for="RememberMe">
                                                Ghi nhớ đăng nhập
                                            </label>
                                        </div>
                                        <a href="/auth/step1-verify-account.html"
                                           class="text-danger text-decoration-none small">Quên mật khẩu?</a>
                                    </div>

                                    <!-- Submit button -->
                                    <button type="submit" class="btn btn-login w-100 py-2 mb-3">
                                        <i class="bi bi-box-arrow-in-right me-2"></i> Đăng nhập
                                    </button>

                                    <!-- Link to Register -->
                                    <div class="text-center">
                                        <p class="mb-0">
                                            Chưa có tài khoản? <a asp-controller="Auth" asp-action="DangKy"
                                                                  class="text-danger fw-semibold text-decoration-none">Đăng ký ngay</a>
                                        </p>
                                    </div>
                                </form>

                                <!-- Divider -->
                                <div class="position-relative my-4">
                                    <hr>
                                    <span class="position-absolute top-50 start-50 translate-middle bg-white px-3 text-muted small">Hoặc</span>
                                </div>

                                <!-- Social buttons -->
                                <div class="d-flex gap-3 justify-content-center">
                                    <button class="btn btn-outline-secondary rounded-pill px-3 social-btn">
                                        <i class="bi bi-google text-danger"></i> Google
                                    </button>
                                    <button class="btn btn-outline-secondary rounded-pill px-3 social-btn">
                                        <i class="bi bi-facebook text-primary"></i> Facebook
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Modal Quên mật khẩu -->
    <div class="modal fade" id="forgotPasswordModal" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content rounded-4">
                <div class="modal-header bg-danger text-white">
                    <h5 class="fw-bold"><i class="bi bi-key me-2"></i> Khôi phục mật khẩu</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted mb-3">
                        Nhập email đăng ký của bạn, chúng tôi sẽ gửi hướng dẫn khôi phục mật
                        khẩu.
                    </p>
                    <input type="email" class="form-control mb-3" id="resetEmail" placeholder="Email của bạn">
                    <button class="btn btn-red-premium w-100" onclick="sendResetPassword()">Gửi yêu cầu</button>
                </div>
            </div>
        </div>
    </div>




    <!-- Bootstrap JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/assets/js/site.js" asp-append-version="true"></script>
    <!-- Login JS -->
    <script src="~/assets/js/login.js" asp-append-version="true"></script>
    <!-- Chatbox Widget -->
    <div id="chatbox-container" style="position:fixed;bottom:0;right:0;z-index:99990"></div>
    <script src="~/assets/js/chatbox.js" asp-append-version="true"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
          const el = document.getElementById('chatbox-container');
          if (!el) return;
          fetch('components/chatbox.html').then(r=>r.text()).then(html=>{ el.innerHTML=html; if(window.initChatbox) window.initChatbox(); });
        });
    </script>
</body>

</html>