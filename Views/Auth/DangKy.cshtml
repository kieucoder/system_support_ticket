@model SupportTicketSysterm.Models.DangKyViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Đăng ký | TechSupport - Hệ thống quản lý phiếu hỗ trợ kỹ thuật</title>

    <!-- SEO Optimization -->
    <meta name="description" content="Đăng ký tài khoản TechSupport để quản lý phiếu hỗ trợ kỹ thuật, theo dõi tiến độ xử lý và nhận hỗ trợ nhanh chóng từ Viettel Telecom.">
    <meta name="keywords" content="đăng ký techsupport, tài khoản kỹ thuật, hỗ trợ viettel, báo hỏng internet">
    <meta name="author" content="Viettel Telecom TechSupport">
    <meta name="robots" content="index, follow">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" crossorigin="anonymous" referrerpolicy="no-referrer">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&family=Poppins:wght@500;600;700;800&display=swap" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/assets/css/site.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/login.css" asp-append-version="true">
    <link rel="stylesheet" href="~/css/auth/register.css" asp-append-version="true">
</head>
<body>

    <!-- Back to Home Button -->
    <a asp-controller="Customers" asp-action="TrangChu" class="btn-back-home" title="Quay về trang chủ" aria-label="Quay về trang chủ">
        <i class="bi bi-arrow-left" aria-hidden="true"></i>
    </a>

    <div class="register-wrapper">
        <div class="register-container">
            <div class="login-card shadow-lg">
                <div class="row g-0">

                    <!-- Left Side: Info & Features List -->
                    <div class="col-lg-5 register-info p-4 p-xl-5">
                        <div class="brand mb-4">
                            <i class="fa-solid fa-cpu-fill"></i>
                            <span>Tech<span class="text-danger">Support</span></span>
                        </div>
                        <h2 class="fw-bold mb-3">Tạo tài khoản mới</h2>
                        <p class="text-white-50 mb-3">Đăng ký thành viên để gửi phiếu hỗ trợ kỹ thuật, theo dõi tiến độ xử lý sự cố trực tuyến và nhận thông báo.</p>

                        <!-- Centered Illustration Banner SVG -->
                        <div class="illustration-container">
                            <img src="~/assets/images/register-banner.svg" alt="TechSupport Illustration" class="illustration-img">
                        </div>

                        <!-- Feature list matching login list style -->
                        <div class="feature-list">
                            <div class="feature-item">
                                <i class="fa-solid fa-circle-check"></i>
                                <span>Theo dõi phiếu hỗ trợ trực quan</span>
                            </div>
                            <div class="feature-item">
                                <i class="fa-solid fa-circle-check"></i>
                                <span>Hỗ trợ trực tuyến 24/7 chuyên nghiệp</span>
                            </div>
                            <div class="feature-item">
                                <i class="fa-solid fa-circle-check"></i>
                                <span>Bảo mật tuyệt đối thông tin cá nhân</span>
                            </div>
                        </div>

                        <div class="mt-4 pt-3">
                            <p class="text-white-50 small mb-0">
                                <i class="bi bi-shield-check"></i> Bảo mật tuyệt đối thông tin cá nhân
                            </p>
                        </div>
                    </div>

                    <!-- Right Side: Registration Form -->
                    <div class="col-lg-7 register-form p-4 p-xl-5">
                        
                        <!-- Toggle Login / Register Tabs -->
                        <div class="auth-toggle-container">
                            <div class="auth-toggle-wrapper">
                                <a asp-controller="Auth" asp-action="DangNhap" class="auth-toggle-btn">Đăng nhập</a>
                                <a href="#" class="auth-toggle-btn active">Đăng ký</a>
                            </div>
                        </div>

                        <div class="text-center mb-4">
                            <h3 class="fw-bold text-dark">Đăng ký</h3>
                            <p class="text-muted">Nhập thông tin đăng ký tài khoản mới</p>
                        </div>

                        <!-- Error Message Summary -->
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 rounded-3 mb-3 shadow-sm" style="font-size:0.85rem;">
                                <div asp-validation-summary="ModelOnly" class="text-danger fw-semibold"></div>
                                <ul class="mb-0 ps-3">
                                    @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                </ul>
                            </div>
                        }

                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger border-0 rounded-3 mb-3 shadow-sm" style="font-size:0.85rem;">
                                <i class="bi bi-exclamation-triangle-fill me-2 text-danger"></i>
                                <span class="fw-semibold text-danger">@TempData["Error"]</span>
                            </div>
                        }

                        <!-- Main Form -->
                        <form id="registerForm" asp-controller="Auth" asp-action="GuiOTP" method="post" novalidate>
                            @Html.AntiForgeryToken()
                            
                            <!-- Hidden OTP input linked to Model -->
                            <input asp-for="OTP" type="hidden" id="otpValue" />

                            <div id="registrationFields">
                                <div class="row">
                                    <!-- Họ tên -->
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-semibold" asp-for="HoTen">Họ và tên <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-user text-danger"></i>
                                            </span>
                                            <input asp-for="HoTen" type="text" id="fullname" class="form-control border-start-0" placeholder="Nguyễn Văn A" autocomplete="name" required>
                                        </div>
                                        <span asp-validation-for="HoTen" class="text-danger small"></span>
                                    </div>

                                    <!-- Email -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="Email">Email <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-envelope text-danger"></i>
                                            </span>
                                            <input asp-for="Email" type="email" id="email" class="form-control border-start-0" placeholder="example@@domain.com" autocomplete="email" required>
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger small"></span>
                                    </div>

                                    <!-- Số điện thoại -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="SoDienThoai">Số điện thoại <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-phone text-danger"></i>
                                            </span>
                                            <input asp-for="SoDienThoai" type="tel" id="phone" class="form-control border-start-0" placeholder="0987654321" autocomplete="tel" required>
                                        </div>
                                        <span asp-validation-for="SoDienThoai" class="text-danger small"></span>
                                    </div>

                                    <!-- Ngày sinh -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="NgaySinh">Ngày sinh</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-calendar-days text-danger"></i>
                                            </span>
                                            <input asp-for="NgaySinh" type="date" id="birthdate" class="form-control border-start-0">
                                        </div>
                                        <span asp-validation-for="NgaySinh" class="text-danger small"></span>
                                    </div>

                                    <!-- Địa chỉ -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="DiaChi">Địa chỉ</label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="fa-solid fa-location-dot text-danger"></i>
                                            </span>
                                            <input asp-for="DiaChi" type="text" id="address" class="form-control border-start-0" placeholder="Hà Nội, Việt Nam" autocomplete="street-address">
                                        </div>
                                        <span asp-validation-for="DiaChi" class="text-danger small"></span>
                                    </div>

                                    <!-- Mật khẩu -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="MatKhau">Mật khẩu <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-lock-fill text-danger"></i>
                                            </span>
                                            <input asp-for="MatKhau" type="password" id="password" class="form-control border-start-0" placeholder="••••••••" autocomplete="new-password" required>
                                            <button class="btn btn-outline-secondary border-start-0 toggle-password" type="button" data-target="password">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        </div>
                                        <span asp-validation-for="MatKhau" class="text-danger small"></span>
                                    </div>

                                    <!-- Xác nhận mật khẩu -->
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-semibold" asp-for="XacNhanMatKhau">Xác nhận mật khẩu <span class="text-danger">*</span></label>
                                        <div class="input-group">
                                            <span class="input-group-text bg-light border-end-0">
                                                <i class="bi bi-lock-fill text-danger"></i>
                                            </span>
                                            <input asp-for="XacNhanMatKhau" type="password" id="confirmPassword" class="form-control border-start-0" placeholder="••••••••" autocomplete="new-password" required>
                                            <button class="btn btn-outline-secondary border-start-0 toggle-password" type="button" data-target="confirmPassword">
                                                <i class="bi bi-eye-slash"></i>
                                            </button>
                                        </div>
                                        <span asp-validation-for="XacNhanMatKhau" class="text-danger small"></span>
                                    </div>
                                </div>

                                <!-- Checkbox Đồng ý điều khoản -->
                                <div class="form-check mb-4">
                                    <input type="checkbox" class="form-check-input" id="agreeTerms" required>
                                    <label class="form-check-label small text-muted ms-1" for="agreeTerms">
                                        Tôi đồng ý với <a href="#" class="text-danger text-decoration-none fw-semibold">điều khoản sử dụng</a> của hệ thống.
                                    </label>
                                </div>
                            </div>

                            <!-- Partial OTP verification screen embedded dynamically -->
                            @await Html.PartialAsync("Partial/_OTPVerification", Model)

                            <!-- Submit Button: Send OTP -->
                            <button type="submit" id="btnSendOtp" class="btn btn-login w-100 py-2 mb-3">
                                <span class="btn-text">
                                    <i class="fa-solid fa-paper-plane me-1"></i> Gửi mã OTP
                                </span>
                                <span class="spinner" style="display: none;">
                                    <i class="fa-solid fa-circle-notch fa-spin me-2"></i> Đang gửi mã...
                                </span>
                            </button>

                            <!-- Submit Button: Register (Hidden initially, shown after OTP sent) -->
                            <button type="submit" id="btnRegister" class="btn btn-login w-100 py-2 mb-3 d-none" disabled>
                                <span class="btn-text">
                                    <i class="fa-solid fa-user-plus me-1"></i> ĐĂNG KÝ TÀI KHOẢN
                                </span>
                                <span class="spinner" style="display: none;">
                                    <i class="fa-solid fa-circle-notch fa-spin me-2"></i> Đang đăng ký...
                                </span>
                            </button>

                            <!-- Footer Link -->
                            <div class="text-center">
                                <p class="mb-0 text-muted">
                                    Đã có tài khoản? <a asp-controller="Auth" asp-action="DangNhap" class="text-danger fw-semibold text-decoration-none">Đăng nhập ngay</a>
                                </p>
                            </div>
                        </form>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/js/auth/register.js" asp-append-version="true"></script>
</body>
</html>
