@model SupportTicketSysterm.Data.LienHe

<div class="stream-header-bar flex-column align-items-stretch">
    <div class="d-flex align-items-center gap-2 mb-2">
        <button class="stream-back-btn" onclick="window.TechSupportChat.backToConversations()" title="Quay lại" aria-label="Quay lại">
            <i class="bi bi-chevron-left"></i>
        </button>
        <div class="stream-header-info text-truncate">
            <div class="stream-header-title-row">
                <span class="stream-header-title text-truncate">@Model.TieuDe</span>
                <span class="stream-header-status-badge text-white" style="background-color: @(Model.TrangThai == "Hoàn thành" ? "#10B981" : "#e60028"); font-size: 0.7rem;">
                    @(Model.TrangThai ?? "Đang hỗ trợ")
                </span>
            </div>
            <span class="stream-header-desc">
                @if (Model.IdNhanVienNavigation != null)
                {
                    <i class="bi bi-person-badge"></i> @("Nhân viên: " + Model.IdNhanVienNavigation.HoTen)
                }
                else
                {
                    <i class="bi bi-robot"></i> @("Trò chuyện trực tuyến")
                }
            </span>
        </div>
    </div>

    @if (Model.IdPhieuNavigation != null)
    {
        var ticket = Model.IdPhieuNavigation;
        var nvName = ticket.IdNhanVienNavigation?.HoTen ?? "Chưa phân công";
        
        <div class="p-2 border rounded bg-light mt-1" style="font-size: 0.8rem;">
            <div class="d-flex justify-content-between align-items-center mb-1">
                <span class="fw-bold text-dark"><i class="bi bi-ticket-detailed me-1"></i>Phiếu: @ticket.MaPhieu</span>
                <span class="badge bg-secondary-subtle text-secondary" style="font-size: 0.72rem;">@ticket.TrangThai</span>
            </div>
            <p class="text-truncate text-muted mb-1" style="font-size: 0.76rem;" title="@ticket.TieuDe">@ticket.TieuDe</p>
            <div class="d-flex justify-content-between align-items-center mt-2 pt-2 border-top">
                <span class="text-muted" style="font-size: 0.72rem;">Kỹ thuật viên: <strong>@nvName</strong></span>
                <a href="/Ticket/ChiTietPhieu/@ticket.IdPhieu" target="_blank" class="btn btn-outline-danger btn-xs py-1 px-2 rounded-pill font-bold" style="font-size: 0.72rem; text-decoration:none;">
                    Xem chi tiết <i class="bi bi-box-arrow-up-right"></i>
                </a>
            </div>
        </div>
    }
</div>
