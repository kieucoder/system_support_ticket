@model SupportTicketSysterm.Data.PhieuHoTro
@{
    ViewData["Title"] = "Phân Công Nhân Viên - TechSupport Viettel";
    ViewData["HeaderTitle"] = "Phân Công Nhân Viên";
    ViewData["HeaderSubtitle"] = "Điều hướng & chỉ định kỹ thuật viên phụ trách xử lý phiếu";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb" style="font-size: 0.82rem;">
        <li class="breadcrumb-item"><a href="/Staff/QuanLyPhieuHoTro" class="text-danger text-decoration-none">Quản lý phiếu</a></li>
        <li class="breadcrumb-item active">Phân công nhân viên</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-8 col-12">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h4 class="fw-bold mb-4 text-dark-emphasis"><i class="fa-solid fa-user-gear text-danger me-2"></i>Phân công xử lý phiếu</h4>
            
            <div class="row g-3 mb-4">
                <div class="col-md-6">
                    <span class="text-muted small d-block">Mã Phiếu</span>
                    <strong class="text-danger fs-5">@Model.MaPhieu</strong>
                </div>
                <div class="col-md-6">
                    <span class="text-muted small d-block">Khách hàng</span>
                    <strong class="fs-6">@(Model.IdKhachHangNavigation?.HoTen ?? "Không rõ")</strong>
                </div>
                <div class="col-12">
                    <span class="text-muted small d-block">Tiêu đề yêu cầu</span>
                    <p class="mb-0 fw-medium">@Model.TieuDe</p>
                </div>
                <div class="col-12">
                    <span class="text-muted small d-block">Nội dung chi tiết</span>
                    <p class="mb-0 text-muted">@(Model.NoiDung ?? "Không có mô tả chi tiết.")</p>
                </div>
            </div>

            <form asp-controller="Staff" asp-action="PhanCongNhanVien" asp-route-id="@Model.IdPhieu" method="post">
                <div class="mb-4">
                    <label for="idNhanVien" class="form-label fw-bold text-dark-emphasis">Chọn nhân viên kỹ thuật phụ trách</label>
                    <select name="idNhanVien" id="idNhanVien" class="form-select border rounded-3 p-3">
                        <option value="">-- Chọn nhân viên (Để trống để bỏ phân công) --</option>
                        @if (ViewBag.NhanViens != null)
                        {
                            @foreach (var nv in ViewBag.NhanViens)
                            {
                                <option value="@nv.IdNhanVien" selected="@(Model.IdNhanVien == nv.IdNhanVien)">@nv.HoTen (@nv.ChucVu)</option>
                            }
                        }
                    </select>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-viettel fw-bold px-4 py-2" style="border-radius:10px;">Lưu phân công</button>
                    <a href="/Staff/QuanLyPhieuHoTro" class="btn btn-outline-secondary fw-bold px-4 py-2" style="border-radius:10px;">Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
