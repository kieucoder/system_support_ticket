@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Báo Cáo & Thống Kê - TechSupport Viettel Admin</title>
    <meta name="description" content="Hệ thống báo cáo và thống kê hiệu suất TechSupport Viettel Telecom.">
    <meta name="robots" content="noindex, nofollow">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <!-- Admin Dashboard CSS (base layout) -->
    <link rel="stylesheet" href="~/assets/css/staff/dashboard.css">
    <!-- Page-specific CSS -->
    <link rel="stylesheet" href="~/assets/css/staff/admin-report.css">
</head>

<body>
    <div id="adminLayout">

        <!-- SIDEBAR MOUNT -->
        <div id="sidebarMount"></div>

        <!-- MAIN WRAPPER -->
        <div class="main-wrapper">

            <!-- TOPBAR -->
            <header class="admin-topbar">
                <div class="topbar-left">
                    <button class="sidebar-toggle-btn d-lg-none" id="toggleMobileSidebar" aria-label="Open menu">
                        <i class="bi bi-bars"></i>
                    </button>
                    <button class="sidebar-toggle-btn d-none d-lg-flex" id="toggleSidebar" aria-label="Toggle sidebar">
                        <i class="bi bi-bars"></i>
                    </button>
                    <div class="d-none d-md-block">
                        <p class="mb-0 fw-semibold" style="font-size:0.95rem; color:var(--text-main);">
                            Báo Cáo & Thống Kê
                        </p>
                        <p class="mb-0" style="font-size:0.75rem; color:var(--text-muted);">
                            Hệ thống tổng hợp dữ liệu sự cố và đánh giá chất lượng dịch vụ
                        </p>
                    </div>
                </div>

                <form class="topbar-search-form d-none d-md-block" role="search" onsubmit="event.preventDefault();">
                    <div class="search-input-group">
                        <i class="fa-solid fa-search"></i>
                        <input type="search" class="form-control search-bar-input" placeholder="Tìm kiếm toàn hệ thống..." autocomplete="off">
                    </div>
                </form>

                <div class="topbar-right">
                    <button class="topbar-action-btn" id="toggleTheme" title="Toggle Dark Mode">
                        <i class="bi bi-moon"></i>
                    </button>
                    <button class="topbar-action-btn" title="Thông báo">
                        <i class="fa-solid fa-bell"></i>
                        <span class="notification-badge" style="position: absolute; top: 6px; right: 6px; width: 18px; height: 18px; background-color: var(--viettel-red); color: #fff; border-radius: 50%; font-size: 0.6rem; font-weight: 700; display: flex; align-items: center; justify-content: center; border: 2px solid var(--bg-topbar);">5</span>
                    </button>
                    <div class="dropdown">
                        <a class="user-profile-dropdown" href="#" data-bs-toggle="dropdown">
                            <img src="https://ui-avatars.com/api/?name=Admin+Viettel&background=EE0033&color=fff&size=38" alt="Avatar">
                            <div class="d-none d-sm-block">
                                <p class="user-profile-name mb-0">Nguyễn Văn Hùng</p>
                                <p class="mb-0 user-profile-role">Kỹ thuật viên Trưởng</p>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2" style="border-radius:12px;">
                            <li><a class="dropdown-item py-2" href="admin-profile.html"><i class="fa-solid fa-user me-2 text-primary"></i>Thông tin cá nhân</a></li>
                            <li><a class="dropdown-item py-2" href="admin-profile.html#changePassword"><i class="fa-solid fa-key me-2 text-warning"></i>Đổi mật khẩu</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item py-2 text-danger" href="../login.html"><i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất</a></li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- MAIN CONTENT -->
            <main class="admin-content container-fluid" id="reportPageContent">

                <!-- Breadcrumb -->
                <nav aria-label="breadcrumb" class="mb-4">
                    <ol class="breadcrumb" style="font-size: 0.82rem; margin: 0; padding: 0;">
                        <li class="breadcrumb-item">
                            <a href="dashboard.html" class="text-danger text-decoration-none">
                                <i class="fa-solid fa-gauge-high me-1"></i>Dashboard
                            </a>
                        </li>
                        <li class="breadcrumb-item active fw-semibold" style="color: var(--text-main);">Báo cáo thống kê</li>
                    </ol>
                </nav>

                <!-- Hero Section -->
                <div class="row align-items-center mb-4 g-3">
                    <div class="col-12 col-md-8">
                        <h1 class="h3 fw-bold mb-1" style="color: var(--vt-dark-blue);">📊 Báo cáo & Thống kê</h1>
                        <p class="text-muted mb-0" style="font-size: 0.9rem;">Theo dõi hiệu suất xử lý phiếu hỗ trợ, đánh giá chất lượng dịch vụ và hiệu quả vận hành hệ thống.</p>
                    </div>
                    <div class="col-12 col-md-4 text-md-end rep-export-actions">
                        <button class="btn btn-success fw-bold px-3 py-2 me-2" onclick="exportExcel()" style="border-radius: var(--vt-border-radius-sm); box-shadow: 0 4px 10px rgba(25, 135, 84, 0.15);">
                            <i class="fa-solid fa-file-excel me-1"></i> Xuất Excel
                        </button>
                        <button class="btn btn-danger fw-bold px-3 py-2" onclick="exportPDF()" style="background-color: var(--vt-red); border-color: var(--vt-red); border-radius: var(--vt-border-radius-sm); box-shadow: 0 4px 10px rgba(238, 0, 51, 0.15);">
                            <i class="fa-solid fa-file-pdf me-1"></i> Xuất PDF
                        </button>
                    </div>
                </div>

                <!-- Statistics Filters Card -->
                <div class="card border-0 shadow-sm mb-4 rep-filter-card" style="border-radius: var(--vt-border-radius);">
                    <div class="card-header bg-transparent border-0 pt-3 pb-0">
                        <h5 class="card-title fw-bold mb-0 text-dark"><i class="bi bi-filter me-2 text-danger"></i>Bộ lọc thống kê</h5>
                    </div>
                    <div class="card-body">
                        <div class="row g-3">
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportFromDate">Từ ngày</label>
                                <input type="date" id="reportFromDate" class="form-control">
                            </div>
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportToDate">Đến ngày</label>
                                <input type="date" id="reportToDate" class="form-control">
                            </div>
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportCategory">Danh mục dịch vụ</label>
                                <select id="reportCategory" class="form-select">
                                    <option value="">Tất cả danh mục</option>
                                    <option value="Internet">Internet</option>
                                    <option value="Truyền hình">Truyền hình</option>
                                    <option value="Di động">Di động</option>
                                    <option value="Camera">Camera</option>
                                </select>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportService">Dịch vụ</label>
                                <select id="reportService" class="form-select">
                                    <option value="">Tất cả dịch vụ</option>
                                    <!-- Nạp động cascade qua JS -->
                                </select>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportStaff">Nhân viên hỗ trợ</label>
                                <select id="reportStaff" class="form-select">
                                    <option value="">Tất cả nhân viên</option>
                                    <!-- Nạp qua JS -->
                                </select>
                            </div>
                            <div class="col-12 col-sm-6 col-md-4 col-lg-2">
                                <label class="form-label text-muted fw-bold small text-uppercase" for="reportStatus">Trạng thái phiếu</label>
                                <select id="reportStatus" class="form-select">
                                    <option value="">Tất cả trạng thái</option>
                                    <option value="Chờ tiếp nhận">Chờ tiếp nhận</option>
                                    <option value="Đang xử lý">Đang xử lý</option>
                                    <option value="Đã hoàn thành">Đã hoàn thành</option>
                                    <option value="Đã hủy">Đã hủy</option>
                                </select>
                            </div>
                            <div class="col-12 text-end mt-3">
                                <button class="btn btn-danger fw-bold px-4 py-2 me-2" onclick="runStatistics()" style="background-color: var(--vt-red); border-color: var(--vt-red); border-radius: var(--vt-border-radius-sm);">
                                    <i class="bi bi-magnifying-glass me-1"></i> Thống kê
                                </button>
                                <button class="btn btn-outline-secondary fw-bold px-4 py-2" onclick="clearFilters()" style="border-radius: var(--vt-border-radius-sm);">
                                    <i class="bi bi-rotate-right me-1"></i> Làm mới
                                </button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- KPI Dashboard Section -->
                <div class="row g-3 mb-4">
                    <!-- KPI 1 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Tổng phiếu hỗ trợ</span>
                                    <h3 class="fw-bold mt-1 mb-0" id="kpiTotalTickets">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-light text-dark">
                                    <i class="fa-solid fa-ticket"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 2 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Chờ tiếp nhận</span>
                                    <h3 class="fw-bold mt-1 mb-0 text-warning" id="kpiPendingTickets">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-warning-subtle text-warning">
                                    <i class="fa-solid fa-clock"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 3 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Đang xử lý</span>
                                    <h3 class="fw-bold mt-1 mb-0 text-primary" id="kpiProcessingTickets">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-primary-subtle text-primary">
                                    <i class="fa-solid fa-spinner fa-spin"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 4 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Đã hoàn thành</span>
                                    <h3 class="fw-bold mt-1 mb-0 text-success" id="kpiCompletedTickets">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-success-subtle text-success">
                                    <i class="fa-solid fa-circle-check"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 5 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Tổng khách hàng</span>
                                    <h3 class="fw-bold mt-1 mb-0" id="kpiTotalCustomers">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-info-subtle text-info">
                                    <i class="fa-solid fa-users"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 6 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Tổng nhân viên</span>
                                    <h3 class="fw-bold mt-1 mb-0" id="kpiTotalStaff">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-danger-subtle text-danger">
                                    <i class="fa-solid fa-user-tie"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 7 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Tổng lịch hẹn</span>
                                    <h3 class="fw-bold mt-1 mb-0 text-teal" id="kpiTotalAppointments">0</h3>
                                </div>
                                <div class="rep-kpi-icon-box bg-teal-subtle text-teal">
                                    <i class="fa-solid fa-calendar-days"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                    <!-- KPI 8 -->
                    <div class="col-12 col-sm-6 col-lg-3">
                        <div class="card border-0 shadow-sm rep-kpi-card" style="border-radius: 16px;">
                            <div class="card-body d-flex align-items-center justify-content-between">
                                <div>
                                    <span class="text-muted fw-bold small text-uppercase" style="letter-spacing: 0.5px;">Đánh giá trung bình</span>
                                    <div class="d-flex align-items-center mt-1 gap-2">
                                        <h3 class="fw-bold mb-0 text-amber" id="kpiAvgRating">0.0</h3>
                                        <div class="rep-stars-wrapper" id="kpiStars">
                                            <!-- Nạp qua JS -->
                                        </div>
                                    </div>
                                </div>
                                <div class="rep-kpi-icon-box bg-amber-subtle text-amber">
                                    <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Display Area -->
                <div class="row g-4 mb-4">
                    <!-- Chart 1: Daily line Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-line me-2 text-danger"></i>Phiếu hỗ trợ theo ngày</h5>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Lọc số ngày">
                                    <button type="button" class="btn btn-outline-danger active" id="btnDays7" onclick="setDailyChartRange(7)">7 ngày</button>
                                    <button type="button" class="btn btn-outline-danger" id="btnDays30" onclick="setDailyChartRange(30)">30 ngày</button>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartDaily"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 2: Monthly line Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-chart-line me-2 text-danger"></i>Phiếu hỗ trợ theo tháng</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartMonthly"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 3: Status doughnut Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-chart-pie me-2 text-danger"></i>Thống kê theo trạng thái</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartStatus"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 4: Category bar Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-chart-bar me-2 text-danger"></i>Thống kê theo danh mục</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartCategory"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 5: Services horizontal bar Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="bi bi-list-check me-2 text-danger"></i>Thống kê theo dịch vụ (Lỗi phổ biến)</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartService"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 6: Ratings radar Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-shield-halved me-2 text-danger"></i>Đánh giá chất lượng dịch vụ</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartRatingDimensions"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 7: Ratings star distribution pie Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-star-half-stroke me-2 text-danger"></i>Phân bố số sao đánh giá</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartStarDistribution"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chart 8: Appointments monthly bar Chart -->
                    <div class="col-12 col-lg-6">
                        <div class="card border-0 shadow-sm rep-chart-card" style="border-radius: var(--vt-border-radius);">
                            <div class="card-header bg-transparent border-0 pt-3 pb-0">
                                <h5 class="fw-bold mb-0 text-dark"><i class="fa-solid fa-calendar-days me-2 text-danger"></i>Thống kê lịch hẹn theo tháng</h5>
                            </div>
                            <div class="card-body">
                                <div class="rep-chart-wrapper">
                                    <canvas id="chartAppointmentsMonthly"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Detailed Table Card Section -->
                <div class="card border-0 shadow-sm mb-4" style="border-radius: var(--vt-border-radius); overflow: hidden;">
                    <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <div>
                            <h5 class="card-title fw-bold mb-0 text-dark">📋 Danh sách phiếu hỗ trợ</h5>
                            <p class="text-muted mb-0 mt-1" id="tableMetaCount" style="font-size: 0.82rem;">Đang tải...</p>
                        </div>
                        <span class="badge bg-danger-subtle text-danger px-3 py-2 border border-danger-subtle rounded-pill" style="font-size: 0.78rem;">
                            Đang hiển thị <span id="filteredCountBadge">0</span> phiếu
                        </span>
                    </div>
                    <div class="card-body px-0 pb-0">
                        <!-- Desktop Bootstrap Table Responsive -->
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0" id="reportsMainTable" aria-label="Báo cáo chi tiết">
                                <thead class="table-light">
                                    <tr>
                                        <th style="padding-left: 24px; width: 60px;">#</th>
                                        <th style="width: 110px;">Mã Phiếu</th>
                                        <th>Khách Hàng</th>
                                        <th>Dịch Vụ</th>
                                        <th>Nhân Viên</th>
                                        <th style="width: 130px;">Ngày Tạo</th>
                                        <th style="width: 140px;">Mức Ưu Tiên</th>
                                        <th style="width: 140px;">Trạng Thái</th>
                                        <th style="width: 110px; text-align: center;">Đánh Giá</th>
                                        <th style="padding-right: 24px; width: 100px; text-align: center;">Thao Tác</th>
                                    </tr>
                                </thead>
                                <tbody id="reportsTableBody">
                                    <!-- Nạp động qua JS -->
                                </tbody>
                            </table>
                        </div>

                        <!-- Mobile Card List View -->
                        <div id="reportsMobileContainer" class="d-none px-3 pb-3">
                            <!-- Nạp động qua JS -->
                        </div>

                        <!-- Pagination control -->
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 p-4 border-top">
                            <span class="text-muted" id="paginationInfoText" style="font-size: 0.82rem;"></span>
                            <nav aria-label="Điều hướng phân trang">
                                <ul class="pagination pagination-sm mb-0" id="reportsPagination">
                                    <!-- Nạp qua JS -->
                                </ul>
                            </nav>
                        </div>
                    </div>
                </div>

            </main>
        </div>
    </div>

    <!-- TICKET DETAIL DIALOG MODAL -->
    <div class="modal fade" id="ticketDetailModal" tabindex="-1" aria-labelledby="ticketDetailModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="border-radius: var(--vt-border-radius); overflow: hidden; border: none;">
                <div class="modal-header bg-danger text-white py-3">
                    <h5 class="modal-title fw-bold" id="ticketDetailModalLabel"><i class="fa-solid fa-ticket me-2"></i>Chi Tiết Phiếu Hỗ Trợ</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body p-0">
                    <!-- Detail banner -->
                    <div class="p-4 d-flex align-items-center gap-3" style="background: linear-gradient(135deg, rgba(238, 0, 51, 0.05) 0%, rgba(238, 0, 51, 0.01) 100%);">
                        <div class="bg-danger text-white d-flex align-items-center justify-content-center" style="width: 48px; height: 48px; border-radius: 12px; font-size: 1.25rem;">
                            <i class="fa-solid fa-headset"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold mb-0 text-dark" id="modalCustomerName">—</h4>
                            <span class="badge bg-danger-subtle text-danger border border-danger-subtle mt-1 font-monospace" id="modalTicketCode">—</span>
                        </div>
                    </div>
                    <div class="px-4 py-3">
                        <div class="row g-3" style="font-size: 0.9rem;">
                            <div class="col-4 text-muted fw-bold">Dịch vụ:</div>
                            <div class="col-8 text-dark fw-bold" id="modalService">—</div>

                            <div class="col-4 text-muted fw-bold">Kỹ thuật viên:</div>
                            <div class="col-8 text-dark" id="modalStaff">—</div>

                            <div class="col-4 text-muted fw-bold">Ngày tạo:</div>
                            <div class="col-8 text-dark" id="modalCreatedAt">—</div>

                            <div class="col-4 text-muted fw-bold">Ưu tiên:</div>
                            <div class="col-8" id="modalPriority">—</div>

                            <div class="col-4 text-muted fw-bold">Trạng thái:</div>
                            <div class="col-8" id="modalStatus">—</div>

                            <div class="col-4 text-muted fw-bold">Đánh giá:</div>
                            <div class="col-8" id="modalRating">—</div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer border-top-0 pt-0">
                    <button type="button" class="btn btn-secondary px-4 py-2" data-bs-dismiss="modal" style="border-radius: var(--vt-border-radius-sm);">Đóng</button>
                </div>
            </div>
        </div>
    </div>

    <!-- FULLSCREEN LOADING OVERLAY -->
    <div id="loadingOverlay" style="display:none; position:fixed; inset:0; background:rgba(255,255,255,0.7); backdrop-filter:blur(3px); z-index:9999; align-items:center; justify-content:center; flex-direction:column; gap:16px;">
        <div class="spinner-border text-danger" role="status" style="width: 3rem; height: 3rem;">
            <span class="visually-hidden">Loading...</span>
        </div>
        <p class="fw-bold text-dark mb-0" style="font-size:0.95rem;">Đang kết xuất dữ liệu và biểu đồ thống kê...</p>
    </div>

    <!-- Bootstrap Bundle JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>
    <!-- SheetJS (xlsx) CDN -->
    <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
    <!-- html2canvas & jsPDF CDNs -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <!-- Base dashboard loader scripts -->
    <script src="~/assets/js/staff/dashboard.js"></script>
    <!-- Page script -->
    <script src="~/assets/js/staff/admin-report.js"></script>
    <!-- Sidebar template loader -->
    <script src="~/assets/js/staff/sidebar-loader.js"></script>
</body>

</html>
