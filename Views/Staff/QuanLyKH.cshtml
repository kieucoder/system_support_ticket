@model List<SupportTicketSysterm.Data.KhachHang>

@{
    ViewData["Title"] = "Quản Lý Khách Hàng";
    ViewData["HeaderTitle"] = "Quản Lý Khách Hàng";
    ViewData["HeaderSubtitle"] = "Hệ thống quản lý thông tin khách hàng, trạng thái tài khoản và lịch sử phiếu hỗ trợ";
    Layout = "~/Views/Shared/_LayoutStaff.cshtml";
}

@section Styles {
    <!-- Page-specific CSS -->
    <link rel="stylesheet" href="~/assets/css/staff/admin-customers.css">
}

<form id="antiForgeryForm">
    @Html.AntiForgeryToken()
</form>

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb" style="font-size: 0.82rem; margin: 0; padding: 0;">
        <li class="breadcrumb-item">
            <a href="/Staff/Dashboard" class="text-danger text-decoration-none">
                <i class="fa-solid fa-gauge-high me-1"></i>Dashboard
            </a>
        </li>
        <li class="breadcrumb-item active fw-semibold" style="color: var(--text-main);">
            Quản lý khách hàng
        </li>
    </ol>
</nav>

<!-- Header Section -->
<div class="vt-header-container">
    <div class="vt-header-left">
        <h1>Quản lý khách hàng</h1>
        <p>Quản lý thông tin khách hàng, trạng thái tài khoản và lịch sử phiếu hỗ trợ kỹ thuật</p>
    </div>
    <button class="vt-btn-add" data-bs-toggle="modal" data-bs-target="#addCustomerModal">
        <i class="fa-solid fa-plus"></i> Thêm khách hàng
    </button>
</div>

<!-- Statistics Cards -->
<div class="vt-stats-grid">
    <!-- KPI 1: Total Customers -->
    <div class="vt-stat-card">
        <div class="vt-stat-info">
            <span class="vt-stat-label">Tổng khách hàng</span>
            <span class="vt-stat-value animate-counter" id="kpiTotalCustomers">@ViewBag.TotalCustomers</span>
        </div>
        <div class="vt-stat-icon-box">
            <i class="fa-solid fa-users"></i>
        </div>
    </div>
    <!-- KPI 2: Active Accounts -->
    <div class="vt-stat-card">
        <div class="vt-stat-info">
            <span class="vt-stat-label">Tài khoản hoạt động</span>
            <span class="vt-stat-value animate-counter text-success" id="kpiActiveAccounts">@ViewBag.ActiveCustomers</span>
        </div>
        <div class="vt-stat-icon-box">
            <i class="fa-solid fa-user-check"></i>
        </div>
    </div>
    <!-- KPI 3: Locked Accounts -->
    <div class="vt-stat-card">
        <div class="vt-stat-info">
            <span class="vt-stat-label">Tài khoản khóa</span>
            <span class="vt-stat-value animate-counter text-danger" id="kpiLockedAccounts">@ViewBag.InactiveCustomers</span>
        </div>
        <div class="vt-stat-icon-box">
            <i class="fa-solid fa-user-slash"></i>
        </div>
    </div>
    <!-- KPI 4: New Customers this Month -->
    <div class="vt-stat-card">
        <div class="vt-stat-info">
            <span class="vt-stat-label">Khách hàng mới tháng này</span>
            <span class="vt-stat-value animate-counter text-warning" id="kpiNewCustomers">@ViewBag.NewThisMonth</span>
        </div>
        <div class="vt-stat-icon-box">
            <i class="fa-solid fa-user-plus"></i>
        </div>
    </div>
</div>

<!-- Filters & Searching Panel -->
<div class="card border-0 shadow-sm mb-4 rep-filter-card"
     style="border-radius: var(--vt-border-radius);">
    <div class="card-header bg-transparent border-0 pt-3 pb-0">
        <h5 class="card-title fw-bold mb-0 text-dark">
            <i class="bi bi-filter me-2 text-danger"></i>Bộ lọc tìm kiếm
        </h5>
    </div>
    <div class="card-body">
        <div class="row g-3">
            <!-- Keyword Input -->
            <div class="col-12 col-md-5 col-lg-4">
                <label class="form-label-custom" for="searchCustomer">Tìm kiếm</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0"
                          style="border-radius: 10px 0 0 10px; border-color: var(--border-color);">
                        <i class="bi bi-magnifying-glass text-muted"></i>
                    </span>
                    <input type="text" id="searchCustomer"
                           class="form-control form-control-custom border-start-0"
                           placeholder="Tìm kiếm tên khách hàng hoặc số điện thoại..."
                           style="border-radius: 0 10px 10px 0 !important;">
                </div>
            </div>
            <!-- Status Filter -->
            <div class="col-12 col-sm-6 col-md-3 col-lg-3">
                <label class="form-label-custom" for="filterStatus">Lọc trạng thái</label>
                <select id="filterStatus" class="form-select form-select-custom">
                    <option value="all">Tất cả</option>
                    <option value="Hoạt động">Hoạt động</option>
                    <option value="Đã khóa">Đã khóa</option>
                </select>
            </div>
            <!-- Sort Filter -->
            <div class="col-12 col-sm-6 col-md-2 col-lg-3">
                <label class="form-label-custom" for="filterSort">Sắp xếp</label>
                <select id="filterSort" class="form-select form-select-custom">
                    <option value="newest">Mới nhất</option>
                    <option value="oldest">Cũ nhất</option>
                    <option value="az">Họ tên A → Z</option>
                    <option value="za">Họ tên Z → A</option>
                </select>
            </div>
            <!-- Actions Buttons -->
            <div class="col-12 col-sm-12 col-md-2 col-lg-2 d-flex align-items-end justify-content-lg-end gap-2 filter-actions-col">
                <button class="btn btn-danger fw-bold px-3 py-2 flex-grow-1" onclick="searchCustomers()"
                        style="background-color: var(--vt-red); border-color: var(--vt-red); border-radius: var(--vt-border-radius-sm); height: 44px;">
                    <i class="fa-solid fa-search me-1"></i>
                </button>
                <button class="btn btn-outline-secondary fw-bold px-3 py-2 flex-grow-1"
                        onclick="clearFilters()"
                        style="border-radius: var(--vt-border-radius-sm); height: 44px;">
                    <i class="bi bi-rotate-right me-1"></i> Reset
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Detailed Customers List -->
<div class="card border-0 shadow-sm mb-4"
     style="border-radius: var(--vt-border-radius); overflow: hidden;">
    <div class="card-header bg-transparent border-0 pt-4 pb-0 d-flex justify-content-between align-items-center flex-wrap gap-2">
        <div>
            <h5 class="card-title fw-bold mb-0 text-dark">📋 Danh sách khách hàng</h5>
            <p class="text-muted mb-0 mt-1" id="filteredCountText" style="font-size: 0.82rem;">
                Đang tải...
            </p>
        </div>
        <span class="badge bg-danger-subtle text-danger px-3 py-2 border border-danger-subtle rounded-pill"
              style="font-size: 0.78rem;" id="customersCountText">
            Đang hiển thị 0 khách hàng
        </span>
    </div>
    <div class="card-body px-0 pb-0">
        <!-- Desktop Bootstrap Table Responsive -->
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="customersMainTable"
                   aria-label="Bảng quản lý khách hàng">
                <thead class="table-light">
                    <tr>
                        <th style="padding-left: 20px; width: 50px;">#</th>
                        <th style="width: 90px;">Mã KH</th>
                        <th style="width: 180px;">Họ và tên</th>
                        <th style="width: 140px;">Số điện thoại</th>
                        <th>Email</th>
                        <th style="width: 140px;">Tên đăng nhập</th>
                        <th style="width: 120px;">Trạng thái</th>
                        <th style="width: 110px;">Ngày tạo</th>
                        <th style="padding-right: 20px; width: 170px; min-width: 170px; text-align: center;">Thao tác</th>
                    </tr>
                </thead>
                <tbody id="customersBody">
                    @{
                        int stt = 1;
                    }

                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="padding-left:20px;">@stt</td>

                            <td>
                                <span class="badge bg-secondary">
                                    @item.MaKh
                                </span>
                            </td>

                            <td>
                                <div class="fw-semibold">@item.HoTen</div>
                            </td>

                            <td>@item.SoDienThoai</td>

                            <td>
                                @(string.IsNullOrEmpty(item.Email) ? "-" : item.Email)
                            </td>

                            <td>@item.TenDangNhap</td>

                            <td>
                                @if (item.TrangThai == "Hoạt động")
                                {
                                    <span class="badge bg-success status-badge">
                                        @item.TrangThai
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger status-badge">
                                        @item.TrangThai
                                    </span>
                                }
                            </td>

                            <td>
                                @(item.NgayTao?.ToString("dd/MM/yyyy") ?? "—")
                            </td>

                            <td style="padding-right: 20px; min-width: 170px; text-align: center;">
                                <div class="d-flex gap-2 justify-content-center flex-nowrap">
                                    <button class="btn-action-custom view"
                                            title="Chi tiết"
                                            onclick="viewCustomerDetails('@item.IdKhachHang')">
                                        <i class="fa-solid fa-eye"></i>
                                    </button>

                                    <button class="btn-action-custom history"
                                            title="Lịch sử hỗ trợ"
                                            onclick="viewTicketHistory('@item.IdKhachHang')">
                                        <i class="fa-solid fa-clock-rotate-left"></i>
                                    </button>

                                    <button class="btn-action-custom @(item.TrangThai == "Hoạt động" ? "lock" : "unlock") btn-toggle-status"
                                            data-id="@item.IdKhachHang"
                                            title="@(item.TrangThai == "Hoạt động" ? "Khóa tài khoản" : "Mở khóa tài khoản")"
                                            onclick="toggleLockStatus('@item.IdKhachHang')">

                                        <i class="fa-solid @(item.TrangThai == "Hoạt động" ? "fa-lock" : "fa-lock-open")"></i>

                                    </button>

                                    <button class="btn-action-custom delete"
                                            title="Xóa tài khoản"
                                            onclick="deleteCustomer('@item.IdKhachHang')">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                </tbody>
            </table>
        </div>

        <!-- Mobile Card List View -->
        <div id="customersMobileContainer" class="d-none px-3 pb-3">
            <!-- Filled dynamically by JS -->
        </div>

        <!-- Table Pagination Footer -->
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 p-4 border-top">
            <div class="d-flex align-items-center gap-2">
                <label for="pageSizeSelect" class="text-muted mb-0"
                       style="font-size: 0.82rem; white-space: nowrap;">Hiển thị:</label>
                <select id="pageSizeSelect" class="form-select form-select-sm border"
                       style="width: 75px; border-radius: 6px;">
                    <option value="10" selected>10</option>
                    <option value="25">25</option>
                    <option value="50">50</option>
                    <option value="100">100</option>
                </select>
                <span class="text-muted" style="font-size: 0.82rem; white-space: nowrap;">
                    bản ghi / trang
                </span>
            </div>
            <nav aria-label="Điều hướng phân trang khách hàng">
                <ul class="pagination pagination-sm mb-0" id="customersPagination">
                    <!-- Filled dynamically by JS -->
                </ul>
            </nav>
        </div>
    </div>
</div>

<!-- 1. ADD CUSTOMER DIALOG MODAL -->
@await Html.PartialAsync("_ThemKH", new SupportTicketSysterm.Data.KhachHang())
<!-- 2. VIEW CUSTOMER DETAIL DIALOG MODAL (PROFILE CARD) -->
<div class="modal fade" id="viewCustomerModal" tabindex="-1" aria-labelledby="viewCustomerModalLabel" aria-hidden="true">
    <div id="customerDetailContainer">
        Loading...
    </div>
</div>
<!-- 3. TICKET HISTORY MODAL -->
<div class="modal fade" id="ticketHistoryModal" tabindex="-1" aria-labelledby="ticketHistoryModalLabel"
     aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-xl">
        <div class="modal-content" style="border-radius: var(--vt-border-radius); overflow: hidden; border: none;">
            <div class="modal-header bg-danger text-white py-3">
                <h5 class="modal-title fw-bold" id="ticketHistoryModalLabel">
                    <i class="fa-solid fa-clock-rotate-left me-2"></i>Lịch Sử Phiếu Hỗ Trợ Khách Hàng
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Đóng"></button>
            </div>
            <div class="modal-body p-4">
                <!-- Customer Summary banner in modal -->
                <div class="alert alert-danger border-0 d-flex justify-content-between align-items-center flex-wrap gap-2 mb-4"
                     style="border-radius: 12px; background: rgba(238,0,51,0.05); color: var(--vt-dark-blue);">
                    <div>
                        <span class="text-muted fs-7">Khách hàng:</span>
                        <h5 class="fw-bold mb-0 text-danger" id="historyCustomerName">—</h5>
                    </div>
                    <div>
                        <span class="text-muted fs-7">Số điện thoại:</span>
                        <p class="mb-0 fw-bold" id="historyCustomerPhone">—</p>
                    </div>
                    <div>
                        <span class="text-muted fs-7">Email:</span>
                        <p class="mb-0 fw-bold" id="historyCustomerEmail">—</p>
                    </div>
                </div>

                <!-- Ticket History Filter block -->
                <div class="row g-2 align-items-end mb-3">
                    <div class="col-12 col-md-5">
                        <label class="form-label-custom" for="historySearchCode">Mã phiếu / Tiêu đề</label>
                        <input type="text" id="historySearchCode" class="form-control form-control-custom"
                               placeholder="Tìm mã phiếu hoặc tiêu đề...">
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label-custom" for="historySearchStatus">Trạng thái phiếu</label>
                        <select id="historySearchStatus" class="form-select form-select-custom">
                            <option value="all">Tất cả trạng thái</option>
                            <option value="waiting">Chờ tiếp nhận</option>
                            <option value="processing">Đang xử lý</option>
                            <option value="completed">Đã hoàn thành</option>
                            <option value="cancelled">Đã hủy</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-3 d-flex gap-2">
                        <button class="btn btn-danger fw-bold flex-grow-1" onclick="applyHistoryFilters()"
                                style="background-color: var(--vt-red); border-color: var(--vt-red); border-radius: var(--vt-border-radius-sm); height:44px;">
                            <i class="fa-solid fa-search"></i> Lọc
                        </button>
                        <button class="btn btn-outline-secondary fw-bold" onclick="resetHistoryFilters()"
                                style="border-radius: var(--vt-border-radius-sm); height:44px;">
                            <i class="bi bi-rotate-right"></i>
                        </button>
                    </div>
                </div>

                <!-- Ticket History List -->
                <div class="table-responsive border rounded-3 overflow-hidden">
                    <table class="table table-hover align-middle mb-0" aria-label="Bảng lịch sử phiếu hỗ trợ">
                        <thead class="table-light">
                            <tr>
                                <th style="width: 120px; padding-left:16px;">Mã phiếu</th>
                                <th>Tiêu đề</th>
                                <th style="width: 150px;">Loại yêu cầu</th>
                                <th style="width: 120px;">Mức ưu tiên</th>
                                <th style="width: 120px;">Trạng thái</th>
                                <th style="width: 140px;">Ngày tạo</th>
                                <th style="width: 80px; text-align: center; padding-right:16px;">Chi tiết</th>
                            </tr>
                        </thead>
                        <tbody id="historyTicketsBody">
                            <!-- Populated dynamically -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-secondary px-4 py-2" data-bs-dismiss="modal"
                        style="border-radius: var(--vt-border-radius-sm);">
                    Đóng
                </button>
            </div>
        </div>
    </div>
</div>

<!-- 4. VIEW TICKET DETAIL DIALOG MODAL -->
<div class="modal fade" id="ticketDetailsModal" tabindex="-1" aria-labelledby="ticketDetailsModalLabel"
     aria-hidden="true" style="z-index: 1060;">
    <!-- Ensure higher z-index to stack on history modal -->
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content"
             style="border-radius: var(--vt-border-radius); overflow: hidden; border: none; box-shadow: 0 10px 40px rgba(0,0,0,0.25);">
            <div class="modal-header bg-danger text-white py-3">
                <h5 class="modal-title fw-bold" id="ticketDetailsModalLabel">
                    <i class="fa-solid fa-circle-info me-2"></i>Chi Tiết Phiếu Hỗ Trợ
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                        aria-label="Đóng"></button>
            </div>
            <div class="modal-body p-0">
                <div class="p-4 d-flex align-items-center gap-3"
                     style="background: linear-gradient(135deg, rgba(238, 0, 51, 0.05) 0%, rgba(238, 0, 51, 0.01) 100%);">
                    <div class="bg-danger text-white d-flex align-items-center justify-content-center"
                         style="width: 48px; height: 48px; border-radius: 12px; font-size: 1.25rem;">
                        <i class="fa-solid fa-ticket"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-0 text-dark" id="ticketDetTitle">—</h5>
                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle mt-1 font-monospace"
                              id="ticketDetCode">—</span>
                    </div>
                </div>
                <div class="px-4 py-3">
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Khách hàng:</div>
                        <div class="col-8 text-dark fw-bold" id="ticketDetCustomer">—</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Loại yêu cầu:</div>
                        <div class="col-8 text-dark fw-semibold" id="ticketDetReqType">—</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Mức ưu tiên:</div>
                        <div class="col-8" id="ticketDetPriority">—</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Trạng thái:</div>
                        <div class="col-8" id="ticketDetStatus">—</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Nhân viên xử lý:</div>
                        <div class="col-8 text-dark" id="ticketDetStaff">Nguyễn Hữu Nam (Kỹ thuật viên)</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Lịch hẹn hỗ trợ:</div>
                        <div class="col-8 text-dark" id="ticketDetAppointment">Không cần đặt lịch</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Ngày tạo lập:</div>
                        <div class="col-8 text-dark font-monospace" id="ticketDetCreatedDate">—</div>
                    </div>
                    <div class="detail-modal-row row align-items-center">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Ngày cập nhật:</div>
                        <div class="col-8 text-dark font-monospace" id="ticketDetUpdatedDate">—</div>
                    </div>
                    <div class="detail-modal-row row">
                        <div class="col-4 text-muted fw-bold" style="font-size: 0.85rem;">Mô tả chi tiết:</div>
                        <div class="col-8 text-dark text-wrap" id="ticketDetDesc"
                             style="font-size: 0.85rem; line-height: 1.5;">
                            —
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-top-0 pt-0 px-4 pb-4">
                <button type="button" class="btn btn-secondary px-4 py-2" data-bs-dismiss="modal"
                        style="border-radius: var(--vt-border-radius-sm);">
                    Đóng
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/assets/js/staff/admin-customers.js"></script>
}


