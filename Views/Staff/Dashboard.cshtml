@model SupportTicketSysterm.Models.ViewModels.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Tổng Quan";
    ViewData["HeaderTitle"] = "Tổng Quan Hệ Thống";
    ViewData["HeaderSubtitle"] = "Cập nhật lần cuối hôm nay, " + DateTime.Now.ToString("dd/MM/yyyy");
}

@section Styles {
    <!-- Page-specific CSS -->
    <link rel="stylesheet" href="~/assets/css/staff/dashboard-page.css">
}

<script>
    // Flag to tell the mock dashboard.js to skip setting up fake data and charts
    window.isServerDashboard = true;
</script>

<!-- ====================================
     SECTION 1: STATISTICS CARDS
     ==================================== -->
<section aria-label="Thống kê tổng quan" class="mb-4">
    <div class="row g-3">
        <!-- Card 1 - Total Tickets -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Tổng Phiếu Hỗ Trợ</p>
                        <h2 class="stat-card-number">@Model.TongPhieu</h2>
                        <p class="stat-trend up mb-0 mt-1">
                            <i class="bi bi-arrow-trend-up me-1"></i>Hệ thống tiếp nhận
                        </p>
                    </div>
                    <div class="stat-card-icon primary">
                        <i class="fa-solid fa-ticket" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 2 - Waiting -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Chờ Tiếp Nhận</p>
                        <h2 class="stat-card-number text-warning">@Model.ChoTiepNhan</h2>
                        <p class="stat-trend down mb-0 mt-1 text-warning">
                            <i class="fa-solid fa-circle-exclamation me-1"></i>Cần xử lý sớm
                        </p>
                    </div>
                    <div class="stat-card-icon warning">
                        <i class="fa-solid fa-clock" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 3 - Processing -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Đang Xử Lý</p>
                        <h2 class="stat-card-number text-primary">@Model.DangXuLy</h2>
                        <p class="stat-trend up mb-0 mt-1 text-primary">
                            <i class="fa-solid fa-spinner fa-spin me-1"></i>Đang tiến hành
                        </p>
                    </div>
                    <div class="stat-card-icon primary">
                        <i class="fa-solid fa-spinner fa-spin" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 4 - Completed -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Đã Hoàn Thành</p>
                        <h2 class="stat-card-number text-success">@Model.DaHoanThanh</h2>
                        <p class="stat-trend up mb-0 mt-1 text-success">
                            <i class="fa-solid fa-circle-check me-1"></i>Tốt! Tỉ lệ cao
                        </p>
                    </div>
                    <div class="stat-card-icon success">
                        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 5 - Customers -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Khách Hàng</p>
                        <h2 class="stat-card-number text-info">@Model.SoKhachHang</h2>
                        <p class="stat-trend up mb-0 mt-1 text-info">
                            <i class="fa-solid fa-users me-1"></i>Đã gửi phiếu
                        </p>
                    </div>
                    <div class="stat-card-icon info">
                        <i class="fa-solid fa-users" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 6 - Appointments -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Lịch Hẹn Kỹ Thuật</p>
                        <h2 class="stat-card-number text-success">@Model.LichHenKyThuat</h2>
                        <p class="stat-trend up mb-0 mt-1 text-success">
                            <i class="fa-solid fa-calendar-check me-1"></i>Đã được duyệt
                        </p>
                    </div>
                    <div class="stat-card-icon success">
                        <i class="fa-solid fa-calendar-check" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 7 - Services -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Dịch Vụ Kỹ Thuật</p>
                        <h2 class="stat-card-number text-info">@Model.SoDichVu</h2>
                        <p class="stat-trend up mb-0 mt-1 text-info">
                            <i class="fa-solid fa-network-wired me-1"></i>Đang cung cấp
                        </p>
                    </div>
                    <div class="stat-card-icon info">
                        <i class="fa-solid fa-network-wired" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 8 - Categories -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Danh Mục Sự Cố</p>
                        <h2 class="stat-card-number text-warning">@Model.SoDanhMuc</h2>
                        <p class="stat-trend up mb-0 mt-1 text-warning">
                            <i class="fa-solid fa-layer-group me-1"></i>Nhóm sự cố
                        </p>
                    </div>
                    <div class="stat-card-icon warning">
                        <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Card 9 - Chat with Customer -->
        <div class="col-xl-3 col-lg-4 col-md-6 col-12">
            <div class="dashboard-card">
                <div class="stat-card-wrapper">
                    <div>
                        <p class="stat-card-title">Tin Nhắn Chưa Đọc</p>
                        <h2 class="stat-card-number text-danger">@Model.ChatChuaDoc</h2>
                        <p class="stat-trend up mb-0 mt-1 text-danger">
                            <i class="fa-solid fa-comments me-1"></i>Hộp thư hỗ trợ
                        </p>
                    </div>
                    <div class="stat-card-icon warning" style="background-color: rgba(255, 193, 7, 0.15); color: #ffc107;">
                        <i class="fa-solid fa-comments" aria-hidden="true"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================
     SECTION 2: CHARTS ROW 1 (Line + Doughnut)
     ==================================== -->
<section aria-label="Biểu đồ thống kê phiếu" class="mb-4">
    <div class="row g-3">
        <!-- Line Chart - Trend by Month -->
        <div class="col-lg-8 col-12">
            <div class="dashboard-card h-100">
                <div class="table-card-header">
                    <div>
                        <h2 class="section-heading-line">
                            Phiếu Hỗ Trợ Theo Tháng
                            <small>Biểu đồ xu hướng tiếp nhận phiếu trong 6 tháng gần nhất</small>
                        </h2>
                    </div>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded fs-9">
                        <i class="fa-solid fa-chart-line me-1"></i>Line Chart
                    </span>
                </div>
                <div class="chart-container" style="position: relative; height: 320px;">
                    <canvas id="ticketTrendChart" aria-label="Biểu đồ phiếu theo tháng"></canvas>
                </div>
            </div>
        </div>

        <!-- Doughnut Chart - Status -->
        <div class="col-lg-4 col-12">
            <div class="dashboard-card h-100">
                <div class="table-card-header">
                    <div>
                        <h2 class="section-heading-line">
                            Trạng Thái Phiếu
                            <small>Phân bổ theo từng trạng thái xử lý</small>
                        </h2>
                    </div>
                    <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1 rounded fs-9">
                        <i class="bi bi-chart-pie me-1"></i>Doughnut
                    </span>
                </div>
                <div class="chart-container" style="position: relative; height: 320px;">
                    <canvas id="ticketStatusChart" aria-label="Biểu đồ phân bổ trạng thái"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================
     SECTION 3: CHARTS ROW 2 (Bar + Radar)
     ==================================== -->
<section aria-label="Biểu đồ dịch vụ và đánh giá" class="mb-4">
    <div class="row g-3">
        <!-- Bar Chart - by Service -->
        <div class="col-lg-7 col-12">
            <div class="dashboard-card h-100">
                <div class="table-card-header">
                    <div>
                        <h2 class="section-heading-line">
                            Phiếu Theo Dịch Vụ
                            <small>Số lượng yêu cầu tương ứng mỗi dịch vụ kỹ thuật</small>
                        </h2>
                    </div>
                    <span class="badge bg-info-subtle text-info border border-info-subtle px-2 py-1 rounded fs-9">
                        <i class="fa-solid fa-chart-bar me-1"></i>Bar Chart
                    </span>
                </div>
                <div class="chart-container" style="position: relative; height: 320px;">
                    <canvas id="ticketServiceChart" aria-label="Biểu đồ phiếu theo dịch vụ"></canvas>
                </div>
            </div>
        </div>

        <!-- Radar Chart - Customer Ratings -->
        <div class="col-lg-5 col-12">
            <div class="dashboard-card h-100">
                <div class="table-card-header">
                    <div>
                        <h2 class="section-heading-line">
                            Đánh Giá Hài Lòng (Sao)
                            <small>Phân bổ đánh giá theo thang từ 1 đến 5 sao</small>
                        </h2>
                    </div>
                    <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded fs-9">
                        <i class="fa-solid fa-star me-1"></i>Radar
                    </span>
                </div>
                <div class="chart-container" style="position: relative; height: 320px;">
                    <canvas id="ticketRatingChart" aria-label="Biểu đồ đánh giá khách hàng"></canvas>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ====================================
     SECTION 4: RECENT TICKETS TABLE
     ==================================== -->
<section aria-label="Phiếu hỗ trợ gần đây" class="mb-4">
    <div class="dashboard-card">
        <div class="table-card-header flex-wrap gap-2">
            <div>
                <h2 class="section-heading-line">
                    Phiếu Tiếp Nhận Gần Đây
                    <small>5 phiếu hỗ trợ kỹ thuật được tạo mới nhất trong hệ thống</small>
                </h2>
            </div>
            <a asp-controller="Staff" asp-action="QuanLyPhieu" class="btn btn-sm btn-viettel px-3">
                <i class="bi bi-eye me-1"></i>Xem tất cả
            </a>
        </div>

        <div class="table-responsive">
            <table class="table custom-table" aria-label="Danh sách phiếu gần đây">
                <thead>
                    <tr>
                        <th scope="col">Mã Phiếu</th>
                        <th scope="col">Khách Hàng</th>
                        <th scope="col">Nội Dung / Dịch Vụ</th>
                        <th scope="col">Ưu Tiên</th>
                        <th scope="col">Trạng Thái</th>
                        <th scope="col">Ngày Tạo</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.PhieuMoiNhat != null && Model.PhieuMoiNhat.Any())
                    {
                        foreach (var item in Model.PhieuMoiNhat)
                        {
                            <tr>
                                <td class="fw-bold">
                                    <a asp-controller="Staff" asp-action="ChiTietPhieu" asp-route-id="@item.MaPhieu" class="text-danger text-decoration-none">
                                        @item.MaPhieu
                                    </a>
                                </td>
                                <td>@item.KhachHang</td>
                                <td>
                                    <div class="fw-semibold text-truncate" style="max-width: 250px;" title="@item.NoiDung">
                                        @item.NoiDung
                                    </div>
                                    <small class="text-muted">@item.DichVu</small>
                                </td>
                                <td>
                                    @if (item.MucDoUuTien == "Khẩn Cấp")
                                    {
                                        <span class="badge bg-danger">Khẩn Cấp</span>
                                    }
                                    else if (item.MucDoUuTien == "Cao")
                                    {
                                        <span class="badge bg-warning text-dark">Cao</span>
                                    }
                                    else if (item.MucDoUuTien == "Trung Bình")
                                    {
                                        <span class="badge bg-info text-dark">Trung Bình</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Thấp</span>
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai == "waiting" || item.TrangThai == "Chờ tiếp nhận")
                                    {
                                        <span class="badge bg-warning-subtle text-warning border border-warning-subtle px-2 py-1 rounded">Chờ tiếp nhận</span>
                                    }
                                    else if (item.TrangThai == "processing" || item.TrangThai == "Đang xử lý")
                                    {
                                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-2 py-1 rounded">Đang xử lý</span>
                                    }
                                    else if (item.TrangThai == "completed" || item.TrangThai == "Hoàn thành" || item.TrangThai == "Đã hoàn thành")
                                    {
                                        <span class="badge bg-success-subtle text-success border border-success-subtle px-2 py-1 rounded">Hoàn thành</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger-subtle text-danger border border-danger-subtle px-2 py-1 rounded">@item.TrangThai</span>
                                    }
                                </td>
                                <td>@item.NgayTao?.ToString("dd/MM/yyyy")</td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-4">Chưa có phiếu hỗ trợ nào.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<!-- ====================================
     SECTION 5: QUICK ACCESS LINKS
     ==================================== -->
<section aria-label="Truy cập nhanh" class="mb-2">
    <h2 class="section-heading-line mb-3">
        Truy Cập Nhanh
        <small>Các tác vụ quản trị thường dùng</small>
    </h2>
    <div class="row g-3">
        <div class="col-lg-3 col-md-6 col-6">
            <a asp-controller="Staff" asp-action="QuanLyDanhMuc"
               class="dashboard-card d-flex align-items-center gap-3 text-decoration-none"
               style="padding: 18px 20px;">
                <div class="stat-card-icon primary" style="flex-shrink:0;">
                    <i class="fa-solid fa-layer-group" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="fw-bold mb-0" style="color:var(--text-main); font-size:0.88rem;">
                        Quản Lý
                    </p>
                    <p class="mb-0 text-muted" style="font-size:0.78rem;">Danh Mục Sự Cố</p>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <a asp-controller="DichVu" asp-action="Index"
               class="dashboard-card d-flex align-items-center gap-3 text-decoration-none"
               style="padding: 18px 20px;">
                <div class="stat-card-icon info" style="flex-shrink:0;">
                    <i class="fa-solid fa-network-wired" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="fw-bold mb-0" style="color:var(--text-main); font-size:0.88rem;">
                        Quản Lý
                    </p>
                    <p class="mb-0 text-muted" style="font-size:0.78rem;">Dịch Vụ Kỹ Thuật</p>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <a asp-controller="LichHen" asp-action="Index"
               class="dashboard-card d-flex align-items-center gap-3 text-decoration-none"
               style="padding: 18px 20px;">
                <div class="stat-card-icon warning" style="flex-shrink:0;">
                    <i class="fa-solid fa-calendar-days" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="fw-bold mb-0" style="color:var(--text-main); font-size:0.88rem;">
                        Quản Lý
                    </p>
                    <p class="mb-0 text-muted" style="font-size:0.78rem;">Lịch Hẹn Hỗ Trợ</p>
                </div>
            </a>
        </div>
        <div class="col-lg-3 col-md-6 col-6">
            <a asp-controller="NhanVien" asp-action="Index"
               class="dashboard-card d-flex align-items-center gap-3 text-decoration-none"
               style="padding: 18px 20px;">
                <div class="stat-card-icon success" style="flex-shrink:0;">
                    <i class="fa-solid fa-user-gear" aria-hidden="true"></i>
                </div>
                <div>
                    <p class="fw-bold mb-0" style="color:var(--text-main); font-size:0.88rem;">
                        Tài Khoản
                    </p>
                    <p class="mb-0 text-muted" style="font-size:0.78rem;">Thông Tin Nhân Viên</p>
                </div>
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Theme settings mapping
            const theme = document.documentElement.getAttribute('data-bs-theme') || 'light';
            const isDark = theme === 'dark';
            const labelColor = isDark ? '#94A3B8' : '#6B7280';
            const gridColor = isDark ? 'rgba(51, 65, 85, 0.4)' : 'rgba(229, 231, 235, 0.6)';

            // 1. Line Chart: Monthly Trend
            const trendLabels = @Html.Raw(Json.Serialize(Model.ThongKeTheoThang.Select(x => $"Tháng {x.Thang}")));
            const trendData = @Html.Raw(Json.Serialize(Model.ThongKeTheoThang.Select(x => x.SoLuong)));
            const trendCtx = document.getElementById('ticketTrendChart');
            if (trendCtx) {
                new Chart(trendCtx, {
                    type: 'line',
                    data: {
                        labels: trendLabels,
                        datasets: [{
                            label: 'Phiếu hỗ trợ tiếp nhận',
                            data: trendData,
                            borderColor: '#EE0033',
                            backgroundColor: 'rgba(238, 0, 51, 0.1)',
                            borderWidth: 3,
                            fill: true,
                            tension: 0.35,
                            pointBackgroundColor: '#EE0033',
                            pointBorderColor: '#FFFFFF',
                            pointBorderWidth: 2,
                            pointRadius: 6,
                            pointHoverRadius: 8
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            x: {
                                grid: { color: gridColor },
                                ticks: { color: labelColor, font: { family: 'Inter', size: 11 } }
                            },
                            y: {
                                grid: { color: gridColor },
                                ticks: { color: labelColor, font: { family: 'Inter', size: 11 } },
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            // 2. Doughnut Chart: Ticket Status
            const statusCtx = document.getElementById('ticketStatusChart');
            if (statusCtx) {
                new Chart(statusCtx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Chờ tiếp nhận', 'Đang xử lý', 'Đã hoàn thành'],
                        datasets: [{
                            data: [@Model.ChoTiepNhan, @Model.DangXuLy, @Model.DaHoanThanh],
                            backgroundColor: [
                                '#F59E0B', // Warning
                                '#EE0033', // Primary/Red
                                '#10B981'  // Success/Green
                            ],
                            borderWidth: isDark ? 2 : 1,
                            borderColor: isDark ? '#1E293B' : '#FFFFFF'
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    color: labelColor,
                                    font: { family: 'Inter', size: 12 },
                                    padding: 15
                                }
                            }
                        },
                        cutout: '65%'
                    }
                });
            }

            // 3. Bar Chart: Ticket Service distribution
            const serviceLabels = @Html.Raw(Json.Serialize(Model.ThongKeTheoDichVu.Select(x => x.TenDichVu)));
            const serviceData = @Html.Raw(Json.Serialize(Model.ThongKeTheoDichVu.Select(x => x.SoLuong)));
            const serviceCtx = document.getElementById('ticketServiceChart');
            if (serviceCtx) {
                new Chart(serviceCtx, {
                    type: 'bar',
                    data: {
                        labels: serviceLabels,
                        datasets: [{
                            label: 'Số phiếu',
                            data: serviceData,
                            backgroundColor: 'rgba(238, 0, 51, 0.85)',
                            hoverBackgroundColor: '#EE0033',
                            borderRadius: 6
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            x: {
                                grid: { display: false },
                                ticks: { color: labelColor, font: { family: 'Inter', size: 10 } }
                            },
                            y: {
                                grid: { color: gridColor },
                                ticks: { color: labelColor, font: { family: 'Inter', size: 11 } },
                                beginAtZero: true
                            }
                        }
                    }
                });
            }

            // 4. Radar Chart: Star Ratings satisfaction
            const radarCtx = document.getElementById('ticketRatingChart');
            if (radarCtx) {
                new Chart(radarCtx, {
                    type: 'radar',
                    data: {
                        labels: ['1 Sao (Tệ)', '2 Sao (Kém)', '3 Sao (Bình thường)', '4 Sao (Tốt)', '5 Sao (Rất Tốt)'],
                        datasets: [{
                            label: 'Số lượng đánh giá',
                            data: [@Model.DanhGiaSao.Sao1, @Model.DanhGiaSao.Sao2, @Model.DanhGiaSao.Sao3, @Model.DanhGiaSao.Sao4, @Model.DanhGiaSao.Sao5],
                            backgroundColor: 'rgba(16, 185, 129, 0.2)',
                            borderColor: '#10B981',
                            pointBackgroundColor: '#10B981',
                            borderWidth: 2
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false }
                        },
                        scales: {
                            r: {
