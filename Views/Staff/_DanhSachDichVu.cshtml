@model List<SupportTicketSysterm.Data.DichVu>

<div class="table-responsive">
    <table class="table table-hover align-middle mb-0" id="servicesMainTable" aria-label="Bảng quản lý dịch vụ">
        <thead class="table-light">
            <tr>
                <th style="padding-left: 20px; width: 50px;">#</th>
                <th style="width: 90px;">ID</th>
                <th style="width: 200px;">Tên dịch vụ</th>
                <th style="width: 150px;">Danh mục</th>
                <th>Mô tả</th>
                <th style="width: 120px;">Trạng thái</th>
                <th style="width: 110px;">Ngày tạo</th>
                <th style="padding-right: 20px; width: 150px; text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="servicesBody">
            @if (Model == null || !Model.Any())
            {
                <tr>
                    <td colspan="8" class="text-center py-4 text-muted">
                        <i class="fa-solid fa-folder-open fs-3 d-block mb-2 text-secondary"></i>
                        Không tìm thấy dịch vụ nào phù hợp.
                    </td>
                </tr>
            }
            else
            {
                int stt = ViewBag.StartItem ?? 1;
                @foreach (var item in Model)
                {
                    <tr>
                        <td style="padding-left: 20px;">@stt</td>
                        <td><strong>DV@(item.IdDichVu.ToString("D3"))</strong></td>
                        <td><span class="fw-semibold">@item.TenDichVu</span></td>
                        <td>
                            <span class="badge bg-light text-dark border">
                                <i class="fa-solid fa-folder me-1 text-danger"></i>
                                @(item.IdDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")
                            </span>
                        </td>
                        <td>
                            <div class="text-truncate" style="max-width: 250px;" title="@item.MoTa">
                                @(string.IsNullOrEmpty(item.MoTa) ? "—" : item.MoTa)
                            </div>
                        </td>
                        <td>
                            @if (item.TrangThai == "Hoạt động")
                            {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-2.5 py-1">
                                    <i class="fa-solid fa-circle-check me-1"></i>Hoạt động
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill px-2.5 py-1">
                                    <i class="fa-solid fa-lock me-1"></i>Tạm khóa
                                </span>
                            }
                        </td>
                        <td>@(item.NgayTao?.ToString("dd/MM/yyyy") ?? "—")</td>
                        <td style="padding-right: 20px; text-align: center;">
                            <div class="d-flex justify-content-center gap-1">
                                <button class="btn-action-custom view" onclick="viewServiceDetail(@item.IdDichVu)" title="Xem chi tiết">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="btn-action-custom edit" onclick="openEditModal(@item.IdDichVu)" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                                <button class="btn-action-custom @(item.TrangThai == "Hoạt động" ? "lock" : "unlock")" 
                                        onclick="toggleServiceStatus(@item.IdDichVu, '@item.TrangThai', '@(item.IdDanhMucNavigation?.TrangThai)')"
                                        title="@(item.TrangThai == "Hoạt động" ? "Tạm khóa dịch vụ" : "Kích hoạt dịch vụ")">
                                    <i class="fa-solid @(item.TrangThai == "Hoạt động" ? "fa-lock" : "fa-lock-open")"></i>
                                </button>
                                <button class="btn-action-custom delete" onclick="openDeleteModal(@item.IdDichVu)" title="Xóa">
                                    <i class="fa-solid fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    stt++;
                }
            }
        </tbody>
    </table>
</div>

<!-- Mobile Card List View -->
<div id="servicesMobileContainer" class="d-lg-none px-3 pb-3 mt-3">
    @if (Model != null && Model.Any())
    {
        @foreach (var item in Model)
        {
            <div class="card border border-light-subtle shadow-sm mb-3" style="border-radius: 12px; overflow: hidden;">
                <div class="card-header bg-light d-flex justify-content-between align-items-center py-2 px-3">
                    <span class="fw-bold font-monospace" style="color: var(--vt-red);">DV@(item.IdDichVu.ToString("D3"))</span>
                    @if (item.TrangThai == "Hoạt động")
                    {
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle rounded-pill">Tạm khóa</span>
                    }
                </div>
                <div class="card-body p-3">
                    <h6 class="card-title fw-bold mb-1">@item.TenDichVu</h6>
                    <p class="card-text text-muted mb-2" style="font-size: 0.82rem;">
                        @(string.IsNullOrEmpty(item.MoTa) ? "Không có mô tả" : item.MoTa)
                    </p>
                    <div class="d-flex justify-content-between align-items-center pt-2 border-top" style="font-size: 0.78rem;">
                        <div>
                            <i class="fa-solid fa-folder me-1 text-danger"></i>
                            @(item.IdDanhMucNavigation?.TenDanhMuc ?? "Chưa phân loại")
                        </div>
                        <div class="text-muted">
                            <i class="fa-solid fa-calendar-day me-1"></i>
                            @(item.NgayTao?.ToString("dd/MM/yyyy") ?? "—")
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-transparent d-flex justify-content-end gap-1 p-2">
                    <button class="btn btn-sm btn-outline-primary" onclick="viewServiceDetail(@item.IdDichVu)"><i class="fa-solid fa-eye me-1"></i> Xem</button>
                    <button class="btn btn-sm btn-outline-warning" onclick="openEditModal(@item.IdDichVu)"><i class="fa-solid fa-pen me-1"></i> Sửa</button>
                    <button class="btn btn-sm btn-outline-secondary" onclick="toggleServiceStatus(@item.IdDichVu, '@item.TrangThai', '@(item.IdDanhMucNavigation?.TrangThai)')">
                        <i class="fa-solid @(item.TrangThai == "Hoạt động" ? "fa-lock" : "fa-lock-open")"></i> Status
                    </button>
                    <button class="btn btn-sm btn-outline-danger" onclick="openDeleteModal(@item.IdDichVu)"><i class="fa-solid fa-trash me-1"></i> Xóa</button>
                </div>
            </div>
        }
    }
</div>

<!-- Table Pagination Footer -->
<div class="d-flex align-items-center justify-content-between flex-wrap gap-3 p-4 border-top">
    <div class="d-flex align-items-center gap-2">
        <label for="pageSizeSelect" class="text-muted mb-0" style="font-size: 0.82rem; white-space: nowrap;">Hiển thị:</label>
        <select id="pageSizeSelect" class="form-select form-select-sm border" style="width: 75px; border-radius: 6px;" onchange="changePageSize(this.value)">
            <option value="10" selected="@(ViewBag.PageSize == 10 ? "selected" : null)">10</option>
            <option value="25" selected="@(ViewBag.PageSize == 25 ? "selected" : null)">25</option>
            <option value="50" selected="@(ViewBag.PageSize == 50 ? "selected" : null)">50</option>
            <option value="100" selected="@(ViewBag.PageSize == 100 ? "selected" : null)">100</option>
        </select>
        <span class="text-muted" style="font-size: 0.82rem; white-space: nowrap;">
            bản ghi từ @ViewBag.StartItem - @ViewBag.EndItem trong tổng số @ViewBag.TotalItems
        </span>
    </div>
    <nav aria-label="Điều hướng phân trang dịch vụ">
        <ul class="pagination pagination-sm mb-0" id="servicesPagination">
            @{
                int currentPage = ViewBag.CurrentPage ?? 1;
                int totalPages = ViewBag.TotalPages ?? 1;
            }
            
            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0)" onclick="goPage(@(currentPage - 1))" aria-label="Previous">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(currentPage == i ? "active" : "")">
                    <a class="page-link" href="javascript:void(0)" onclick="goPage(@i)">@i</a>
                </li>
            }

            <li class="page-item @(currentPage == totalPages ? "disabled" : "")">
                <a class="page-link" href="javascript:void(0)" onclick="goPage(@(currentPage + 1))" aria-label="Next">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
</div>
