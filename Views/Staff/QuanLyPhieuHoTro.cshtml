@model SupportTicketSysterm.Models.QuanLyPhieuHoTroViewModel
@{
    ViewData["Title"] = "Quản Lý Phiếu Hỗ Trợ Kỹ Thuật - TechSupport Viettel";
    ViewData["HeaderTitle"] = "Quản lý Phiếu Hỗ Trợ";
    ViewData["HeaderSubtitle"] = "Hệ thống tiếp nhận & xử lý yêu cầu kỹ thuật";
}

@section Styles {
    <!-- Page-specific CSS -->
    <link rel="stylesheet" href="~/assets/css/staff/staff-ticket-management.css">
    
    <style>
        /* Custom status badge */
        .badge-status {
            display: inline-flex;
            align-items: center;
            gap: 5px;
            padding: 5px 12px;
            border-radius: 9999px;
            font-size: 0.78rem;
            font-weight: 600;
            border: 1px solid transparent;
            white-space: nowrap;
        }
        .badge-status.waiting {
            background-color: rgba(245, 158, 11, 0.08);
            color: #D97706;
            border-color: rgba(245, 158, 11, 0.2);
        }
        .badge-status.processing {
            background-color: rgba(59, 130, 246, 0.08);
            color: #2563EB;
            border-color: rgba(59, 130, 246, 0.2);
        }
        .badge-status.feedback {
            background-color: rgba(6, 182, 212, 0.08);
            color: #0891B2;
            border-color: rgba(6, 182, 212, 0.2);
        }
        .badge-status.completed {
            background-color: rgba(16, 185, 129, 0.08);
            color: #059669;
            border-color: rgba(16, 185, 129, 0.2);
        }
        .badge-status.cancelled {
            background-color: rgba(239, 68, 68, 0.08);
            color: #DC2626;
            border-color: rgba(239, 68, 68, 0.2);
        }

        /* Custom priority badge */
        .badge-priority {
            display: inline-flex;
            align-items: center;
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.75rem;
            font-weight: 600;
            border: 1px solid transparent;
            white-space: nowrap;
        }
        .badge-priority.low {
            background-color: rgba(16, 185, 129, 0.08);
            color: #059669;
            border-color: rgba(16, 185, 129, 0.15);
        }
        .badge-priority.medium {
            background-color: rgba(245, 158, 11, 0.08);
            color: #D97706;
            border-color: rgba(245, 158, 11, 0.15);
        }
        .badge-priority.high {
            background-color: rgba(238, 0, 51, 0.08);
            color: #EE0033;
            border-color: rgba(238, 0, 51, 0.2);
        }
        .badge-priority.emergency {
            background-color: #EE0033;
            color: #FFFFFF;
            border-color: #EE0033;
            box-shadow: 0 2px 4px rgba(238, 0, 51, 0.25);
        }

        /* Custom action button inside table row */
        .btn-action-custom {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            border: 1px solid var(--border-color, #e5e7eb);
            background-color: var(--bg-card, #fff);
            color: var(--text-muted, #6b7280);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 0.82rem;
            cursor: pointer;
            transition: all 0.25s ease;
            text-decoration: none;
        }
        .btn-action-custom.view:hover {
            color: #3B82F6;
            border-color: rgba(59, 130, 246, 0.4);
            background-color: rgba(59, 130, 246, 0.05);
            transform: translateY(-2px);
        }
        .btn-action-custom.assign:hover {
            color: #10B981;
            border-color: rgba(16, 185, 129, 0.4);
            background-color: rgba(16, 185, 129, 0.05);
            transform: translateY(-2px);
        }
        .btn-action-custom.status:hover {
            color: #F59E0B;
            border-color: rgba(245, 158, 11, 0.4);
            background-color: rgba(245, 158, 11, 0.05);
            transform: translateY(-2px);
        }
        .btn-action-custom.history:hover {
            color: #8B5CF6;
            border-color: rgba(139, 92, 246, 0.4);
            background-color: rgba(139, 92, 246, 0.05);
            transform: translateY(-2px);
        }
        .btn-action-custom.print:hover {
            color: #1F2937;
            border-color: rgba(31, 41, 55, 0.4);
            background-color: rgba(31, 41, 55, 0.05);
            transform: translateY(-2px);
        }

        /* AJAX Loading Overlay for Staff Table */
        .table-responsive-wrapper {
            position: relative;
            transition: opacity 0.3s ease;
        }
        .table-responsive-wrapper.loading-ajax {
            opacity: 0.55;
            pointer-events: none;
        }
        .loading-overlay-ajax {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            min-height: 200px;
            background: rgba(255, 255, 255, 0.65);
            backdrop-filter: blur(2px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .loading-spinner-ajax {
            width: 48px;
            height: 48px;
            border: 4px solid rgba(238, 0, 51, 0.1);
            border-top: 4px solid #EE0033;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @@keyframes spin {
            0% { transform: rotate(0deg); }
            100% { transform: rotate(360deg); }
        }
    </style>
}

<!-- Navigation Breadcrumbs -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb" style="font-size: 0.82rem; margin: 0; padding: 0;">
        <li class="breadcrumb-item">
            <a href="/Staff/Dashboard" class="text-danger text-decoration-none">
                <i class="fa-solid fa-gauge-high me-1"></i>Dashboard
            </a>
        </li>
        <li class="breadcrumb-item active fw-semibold" style="color: var(--text-main);">
            Quản lý phiếu hỗ trợ
        </li>
    </ol>
</nav>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 rounded-3 mb-4 shadow-sm animate-fade-up">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
    </div>
}

<!-- Page Header Title block -->
<div class="row align-items-center mb-4 g-3">
    <div class="col-12">
        <h1 class="h3 fw-bold mb-1" style="color: var(--text-main);">
            🎫 QUẢN LÝ PHIẾU HỖ TRỢ KỸ THUẬT
        </h1>
        <p class="text-muted mb-0" style="font-size: 0.9rem;">
            Quản lý, phân công và cập nhật trạng thái toàn bộ phiếu hỗ trợ của khách hàng.
        </p>
    </div>
</div>

<!-- =============================================================
     SECTION 1: DASHBOARD KPI CARDS
     ============================================================= -->
<section aria-label="KPI Thống kê phiếu" class="mb-4">
    <div class="row g-3 kpi-grid">
        <!-- Total Tickets -->
        <div class="col-xl-3 col-md-6 col-12">
            <div class="kpi-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1"
                           style="letter-spacing:0.5px;">Tổng phiếu hỗ trợ</p>
                        <h3 class="fw-bold mb-0" id="kpi-total">@Model.TotalTickets</h3>
                    </div>
                    <div class="kpi-icon-box bg-secondary-subtle text-secondary">
                        <i class="fa-solid fa-ticket"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Waiting -->
        <div class="col-xl-3 col-md-6 col-12">
            <div class="kpi-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1"
                           style="letter-spacing:0.5px;">Chờ tiếp nhận</p>
                        <h3 class="fw-bold mb-0 text-muted" id="kpi-waiting">@Model.WaitingTickets</h3>
                    </div>
                    <div class="kpi-icon-box bg-light text-muted">
                        <i class="fa-solid fa-clock"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Processing -->
        <div class="col-xl-3 col-md-6 col-12">
            <div class="kpi-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1"
                           style="letter-spacing:0.5px;">Đang xử lý</p>
                        <h3 class="fw-bold mb-0 text-primary" id="kpi-processing">@Model.ProcessingTickets</h3>
                    </div>
                    <div class="kpi-icon-box bg-primary-subtle text-primary">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Completed -->
        <div class="col-xl-3 col-md-6 col-12">
            <div class="kpi-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1"
                           style="letter-spacing:0.5px;">Hoàn thành</p>
                        <h3 class="fw-bold mb-0 text-success" id="kpi-completed">@Model.CompletedTickets</h3>
                    </div>
                    <div class="kpi-icon-box bg-success-subtle text-success">
                        <i class="fa-solid fa-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <!-- Cancelled -->
        <div class="col-xl-3 col-md-6 col-12 text-md-start">
            <div class="kpi-card p-4">
                <div class="d-flex align-items-center justify-content-between">
                    <div>
                        <p class="text-muted fw-bold small text-uppercase mb-1"
                           style="letter-spacing:0.5px;">Đã hủy</p>
                        <h3 class="fw-bold mb-0 text-danger" id="kpi-cancelled">@Model.CancelledTickets</h3>
                    </div>
                    <div class="kpi-icon-box bg-danger-subtle text-danger">
                        <i class="fa-solid fa-circle-xmark"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- =============================================================
     SECTION 2: ADVANCED FILTERS PANEL
     ============================================================= -->
<section aria-label="Bộ lọc nâng cao" class="mb-4">
    <form method="get" action="@Url.Action("QuanLyPhieuHoTro", "Staff")" class="kpi-card p-4 glass-panel" id="filterForm">
        <input type="hidden" name="sort" value="@Model.Sort" />
        <input type="hidden" name="pageSize" value="@Model.PageSize" />
        
        <div class="d-flex align-items-center mb-3">
            <h5 class="fw-bold mb-0 text-dark-emphasis">
                <i class="bi bi-filter me-2 text-danger"></i>BỘ LỌC TÌM KIẾM NÂNG CAO
            </h5>
        </div>
        
        <div class="row g-3">
            <!-- Keyword search -->
            <div class="col-lg-3 col-md-6 col-12">
                <label for="keyword" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Từ khóa</label>
                <div class="input-group">
                    <span class="input-group-text bg-transparent border-end-0 border">
                        <i class="bi bi-magnifying-glass text-muted"></i>
                    </span>
                    <input type="text" name="keyword" id="keyword"
                           class="form-control form-control-custom border-start-0"
                           placeholder="Mã phiếu, tiêu đề, khách hàng..." value="@Model.Keyword">
                </div>
            </div>

            <!-- Status filter -->
            <div class="col-lg-2 col-md-3 col-6">
                <label for="status" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Trạng thái</label>
                <select name="status" id="status" class="form-select form-select-custom border">
                    <option value="all" selected="@(Model.Status == "all" || string.IsNullOrEmpty(Model.Status))">Tất cả</option>
                    <option value="waiting" selected="@(Model.Status == "waiting")">Chờ tiếp nhận</option>
                    <option value="processing" selected="@(Model.Status == "processing")">Đang xử lý</option>
                    <option value="feedback" selected="@(Model.Status == "feedback")">Chờ khách phản hồi</option>
                    <option value="completed" selected="@(Model.Status == "completed")">Hoàn thành</option>
                    <option value="cancelled" selected="@(Model.Status == "cancelled")">Hủy bỏ</option>
                </select>
            </div>

            <!-- Priority filter -->
            <div class="col-lg-2 col-md-3 col-6">
                <label for="priority" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Mức ưu tiên</label>
                <select name="priority" id="priority" class="form-select form-select-custom border">
                    <option value="all" selected="@(Model.Priority == "all" || string.IsNullOrEmpty(Model.Priority))">Tất cả</option>
                    <option value="Thấp" selected="@(Model.Priority == "Thấp")">Thấp</option>
                    <option value="Trung Bình" selected="@(Model.Priority == "Trung Bình" || Model.Priority == "Trung Binh")">Trung bình</option>
                    <option value="Cao" selected="@(Model.Priority == "Cao")">Cao</option>
                    <option value="Khẩn Cấp" selected="@(Model.Priority == "Khẩn Cấp" || Model.Priority == "Khẩn cấp")">Khẩn cấp</option>
                </select>
            </div>

            <!-- Category filter -->
            <div class="col-lg-2 col-md-6 col-12">
                <label for="categoryId" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Danh mục</label>
                <select name="categoryId" id="categoryId" class="form-select form-select-custom border">
                    <option value="" selected="@(!Model.CategoryId.HasValue)">Tất cả danh mục</option>
                    @if (ViewBag.DanhMucs != null)
                    {
                        @foreach (var dm in ViewBag.DanhMucs)
                        {
                            <option value="@dm.IdDanhMuc" selected="@(Model.CategoryId == dm.IdDanhMuc)">@dm.TenDanhMuc</option>
                        }
                    }
                </select>
            </div>

            <!-- Service filter -->
            <div class="col-lg-3 col-md-6 col-12">
                <label for="serviceId" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Dịch vụ</label>
                <select name="serviceId" id="serviceId" class="form-select form-select-custom border">
                    <option value="" selected="@(!Model.ServiceId.HasValue)">Tất cả dịch vụ</option>
                    @if (ViewBag.DichVus != null)
                    {
                        @foreach (var dv in ViewBag.DichVus)
                        {
                            <option value="@dv.IdDichVu" selected="@(Model.ServiceId == dv.IdDichVu)">@dv.TenDichVu</option>
                        }
                    }
                </select>
            </div>

            <!-- Staff filter -->
            <div class="col-lg-3 col-md-6 col-12">
                <label for="staffId" class="form-label fw-bold text-muted small text-uppercase mb-1"
                       style="font-size:0.75rem;">Nhân viên phụ trách</label>
                <select name="staffId" id="staffId" class="form-select form-select-custom border">
                    <option value="" selected="@(!Model.StaffId.HasValue)">Tất cả nhân viên</option>
                    @if (ViewBag.NhanViens != null)
                    {
                        @foreach (var nv in ViewBag.NhanViens)
                        {
                            <option value="@nv.IdNhanVien" selected="@(Model.StaffId == nv.IdNhanVien)">@nv.HoTen</option>
                        }
                    }
                </select>
            </div>

            <!-- Action Buttons -->
            <div class="col-lg-9 col-12 d-flex align-items-end justify-content-md-end gap-2 flex-wrap">
                <button type="submit" class="btn btn-viettel fw-bold px-4 py-2 flex-grow-1 flex-md-grow-0" style="height:44px;">
                    <i class="fa-solid fa-search me-1"></i> Lọc
                </button>
                <a href="@Url.Action("QuanLyPhieuHoTro", "Staff")" class="btn btn-outline-secondary fw-bold px-4 py-2 flex-grow-1 flex-md-grow-0 d-inline-flex align-items-center justify-content-center" style="border-radius:12px; height:44px;">
                    <i class="bi bi-rotate-right me-1"></i> Làm mới
                </a>
            </div>
        </div>
    </form>
</section>

<!-- =============================================================
     SECTION 3: DATATABLE DATA LIST
     ============================================================= -->
<section aria-label="Danh sách phiếu hỗ trợ" class="mb-4">
    <div class="kpi-card p-0" style="overflow:hidden;">
        <!-- Header Details card -->
        <div class="p-4 d-flex justify-content-between align-items-center flex-wrap gap-2 border-bottom">
            <div>
                <h5 class="fw-bold mb-0 text-dark-emphasis">📋 Danh sách phiếu hỗ trợ kỹ thuật</h5>
                <p class="text-muted small mb-0 mt-1">
                    Sắp xếp và quản lý trực tiếp bằng dữ liệu hệ thống SQL Server.
                </p>
            </div>
            <div class="d-flex align-items-center gap-2">
                <label for="pageSizeSelect" class="text-muted mb-0 small" style="white-space:nowrap;">Dòng mỗi trang:</label>
                <select id="pageSizeSelect" class="form-select form-select-sm" style="width:75px; border-radius:6px;" onchange="updatePageSize(this.value)">
                    <option value="10" selected="@(Model.PageSize == 10)">10</option>
                    <option value="20" selected="@(Model.PageSize == 20)">20</option>
                    <option value="50" selected="@(Model.PageSize == 50)">50</option>
                </select>
            </div>
        </div>

        <!-- Desktop Table view -->
        <div class="table-responsive-wrapper">
            <table class="table align-middle custom-table table-hover" aria-label="Bảng quản lý phiếu hỗ trợ">
                <thead>
                    <tr>
                        <th scope="col">STT</th>
                        <th scope="col">Mã phiếu</th>
                        <th scope="col">Tiêu đề</th>
                        <th scope="col">Khách hàng</th>
                        <th scope="col">Điện thoại</th>
                        <th scope="col">Danh mục</th>
                        <th scope="col">Dịch vụ</th>
                        <th scope="col">Nhân viên</th>
                        <th scope="col">Mức ưu tiên</th>
                        <th scope="col">Trạng thái</th>
                        <th scope="col">Ngày tạo</th>
                        <th scope="col">Ngày hẹn</th>
                        <th scope="col">Đánh giá</th>
                        <th scope="col" style="text-align:center;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DanhSachPhieu == null || Model.DanhSachPhieu.Count == 0)
                    {
                        <tr>
                            <td colspan="14" class="text-center text-muted py-4">
                                Không có phiếu hỗ trợ nào phù hợp với bộ lọc.
                            </td>
                        </tr>
                    }
                    else
                    {
                        int stt = Model.StartItem;
                        @foreach (var item in Model.DanhSachPhieu)
                        {
                            <tr>
                                <td>@stt</td>
                                <td class="fw-semibold text-danger">@item.MaPhieu</td>
                                <td style="max-width: 200px;" class="text-truncate" title="@item.TieuDe">@item.TieuDe</td>
                                <td>@item.HoTenKhachHang</td>
                                <td>@item.SoDienThoai</td>
                                <td>@item.TenDanhMuc</td>
                                <td>@item.TenDichVu</td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.NhanVienPhuTrach))
                                    {
                                        <span class="text-danger small italic">Chưa phân công</span>
                                    }
                                    else
                                    {
                                        <span class="fw-semibold">@item.NhanVienPhuTrach</span>
                                    }
                                </td>
                                <td>
                                    @switch (item.MucDoUuTien)
                                    {
                                        case 1:
                                            <span class="badge-priority low">Thấp</span>
                                            break;
                                        case 2:
                                            <span class="badge-priority medium">Trung bình</span>
                                            break;
                                        case 3:
                                            <span class="badge-priority high">Cao</span>
                                            break;
                                        case 4:
                                            <span class="badge-priority emergency">Khẩn cấp</span>
                                            break;
                                        default:
                                            <span class="badge-priority low">Thấp</span>
                                            break;
                                    }
                                </td>
                                <td>
                                    @if (item.TrangThai == "Chờ tiếp nhận" || item.TrangThai == "ChoTiepNhan")
                                    {
                                        <span class="badge-status waiting">
                                            <i class="fa-solid fa-clock me-1"></i>Chờ tiếp nhận
                                        </span>
                                    }
                                    else if (item.TrangThai == "Đang xử lý" || item.TrangThai == "DangXuLy")
                                    {
                                        <span class="badge-status processing">
                                            <i class="fa-solid fa-spinner fa-spin-pulse me-1"></i>Đang xử lý
                                        </span>
                                    }
                                    else if (item.TrangThai == "Chờ phản hồi" || item.TrangThai == "ChoKhachHangPhanHoi")
                                    {
                                        <span class="badge-status feedback">
                                            <i class="fa-solid fa-comment-dots me-1"></i>Chờ phản hồi
                                        </span>
                                    }
                                    else if (item.TrangThai == "Hoàn thành" || item.TrangThai == "DaHoanThanh" || item.TrangThai == "Đã hoàn thành")
                                    {
                                        <span class="badge-status completed">
                                            <i class="fa-solid fa-circle-check me-1"></i>Hoàn thành
                                        </span>
                                    }
                                    else if (item.TrangThai == "Đã hủy" || item.TrangThai == "DaHuy")
                                    {
                                        <span class="badge-status cancelled">
                                            <i class="fa-solid fa-circle-xmark me-1"></i>Đã hủy
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge-status waiting">@item.TrangThai</span>
                                    }
                                </td>
                                <td>@(item.NgayTao.HasValue ? item.NgayTao.Value.ToString("dd/MM/yyyy") : "--")</td>
                                <td>@(item.NgayHen.HasValue ? item.NgayHen.Value.ToString("dd/MM/yyyy") : "Chưa hẹn")</td>
                                <td>
                                    @if (item.ChatLuongDanhGia == "Chưa đánh giá")
                                    {
                                        <span class="text-muted small">@item.ChatLuongDanhGia</span>
                                    }
                                    else
                                    {
                                        <span class="text-warning fw-bold"><i class="bi bi-star-fill me-1"></i>@item.ChatLuongDanhGia</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center gap-1">
                                        <a asp-controller="Staff" asp-action="_ChiTietPhieuHoTro" asp-route-id="@item.IdPhieu" class="btn-action-custom view" title="Xem chi tiết">
                                            <i class="fa-solid fa-eye"></i>
                                        </a>
                                        <a href="javascript:void(0);" onclick="openAssignModal(@item.IdPhieu)" class="btn-action-custom assign" title="Phân công">
                                             <i class="bi bi-person-fill-check" style="font-size: 1.15rem;"></i>
                                        </a>
                                        <a asp-controller="Staff" asp-action="CapNhatTrangThai" asp-route-id="@item.IdPhieu" class="btn-action-custom status" title="Cập nhật trạng thái">
                                            <i class="fa-solid fa-arrows-spin"></i>
                                        </a>
                                        <a asp-controller="Staff" asp-action="LichSuXuLy" asp-route-id="@item.IdPhieu" class="btn-action-custom history" title="Lịch sử xử lý">
                                            <i class="fa-solid fa-clock-rotate-left"></i>
                                        </a>
                                        <a asp-controller="Ticket" asp-action="InPhieu" asp-route-id="@item.IdPhieu" target="_blank" class="btn-action-custom print" title="In phiếu">
                                            <i class="fa-solid fa-print"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                            stt++;
                        }
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination Footer -->
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3 p-4 border-top">
            <div class="small text-muted" id="tableCountDetails">
                Đang hiển thị @Model.StartItem-@Model.EndItem / @Model.TotalItems phiếu hỗ trợ
            </div>
            <nav aria-label="Điều hướng phân trang">
                <ul class="pagination pagination-sm mb-0" id="tablePagination">
                    @if (Model.CurrentPage > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("QuanLyPhieuHoTro", "Staff", new { keyword = Model.Keyword, status = Model.Status, priority = Model.Priority, categoryId = Model.CategoryId, serviceId = Model.ServiceId, staffId = Model.StaffId, page = Model.CurrentPage - 1, pageSize = Model.PageSize, sort = Model.Sort })">Trước</a>
                        </li>
                    }
                    @for (int i = 1; i <= Model.TotalPages; i++)
                    {
                        <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" href="@Url.Action("QuanLyPhieuHoTro", "Staff", new { keyword = Model.Keyword, status = Model.Status, priority = Model.Priority, categoryId = Model.CategoryId, serviceId = Model.ServiceId, staffId = Model.StaffId, page = i, pageSize = Model.PageSize, sort = Model.Sort })">@i</a>
                        </li>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="@Url.Action("QuanLyPhieuHoTro", "Staff", new { keyword = Model.Keyword, status = Model.Status, priority = Model.Priority, categoryId = Model.CategoryId, serviceId = Model.ServiceId, staffId = Model.StaffId, page = Model.CurrentPage + 1, pageSize = Model.PageSize, sort = Model.Sort })">Sau</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    </div>
</section>

<!-- Modal Container for AJAX Loading -->
<div id="modalContainer"></div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            initStaffAjaxFilter();
        });

        function initStaffAjaxFilter() {
            const filterForm = document.getElementById('filterForm');
            if (filterForm) {
                filterForm.addEventListener('submit', function (e) {
                    e.preventDefault();
                    triggerStaffAjaxFilter();
                });
            }

            // Bind change events
            const dropdowns = ['status', 'priority', 'serviceId', 'staffId'];
            dropdowns.forEach(id => {
                const el = document.getElementById(id);
                if (el) {
                    el.addEventListener('change', function() {
                        triggerStaffAjaxFilter();
                    });
                }
            });

            // Bind category change to dynamically load services
            const categoryEl = document.getElementById('categoryId');
            if (categoryEl) {
                categoryEl.addEventListener('change', function () {
                    const categoryId = this.value;
                    const serviceSelect = document.getElementById('serviceId');
                    if (!serviceSelect) return;

                    if (!categoryId) {
                        serviceSelect.innerHTML = '<option value="">Tất cả dịch vụ</option>';
                        triggerStaffAjaxFilter();
                        return;
                    }

                    // Show loader in service dropdown during load
                    serviceSelect.innerHTML = '<option value="">Đang tải dịch vụ...</option>';
                    serviceSelect.disabled = true;

                    fetch(`/Ticket/GetDichVu?idDanhMuc=${categoryId}`)
                        .then(res => res.json())
                        .then(data => {
                            let html = '<option value="">Tất cả dịch vụ</option>';
                            data.forEach(item => {
                                html += `<option value="${item.idDichVu}">${item.tenDichVu}</option>`;
                            });
                            serviceSelect.innerHTML = html;
                        })
                        .catch(err => {
                            console.error('Error fetching services:', err);
                            serviceSelect.innerHTML = '<option value="">Tất cả dịch vụ</option>';
                        })
                        .finally(() => {
                            serviceSelect.disabled = false;
                            triggerStaffAjaxFilter();
                        });
                });
            }

            // Keyword search debounce
            const keywordInp = document.getElementById('keyword');
            let debounceTimer;
            if (keywordInp) {
                keywordInp.addEventListener('input', function () {
                    clearTimeout(debounceTimer);
                    debounceTimer = setTimeout(() => {
                        triggerStaffAjaxFilter();
                    }, 400);
                });
            }

            // Refresh/Reset button
            const resetBtn = document.querySelector('a[href*="QuanLyPhieuHoTro"][class*="btn-outline-secondary"]');
            if (resetBtn) {
                resetBtn.removeAttribute('href');
                resetBtn.style.cursor = 'pointer';
                resetBtn.addEventListener('click', function(e) {
                    e.preventDefault();
                    resetStaffFilters();
                });
            }

            // Bind pagination clicks
            bindStaffPagination();
        }

        function bindStaffPagination() {
            const pageLinks = document.querySelectorAll('#tablePagination .page-link');
            pageLinks.forEach(link => {
                link.addEventListener('click', function (e) {
                    e.preventDefault();
                    const href = this.getAttribute('href');
                    if (href && href !== '#') {
                        triggerStaffAjaxFilter(href);
                    }
                });
            });
        }

        function resetStaffFilters() {
            const keyword = document.getElementById('keyword');
            if (keyword) keyword.value = '';

            const status = document.getElementById('status');
            if (status) status.selectedIndex = 0;

            const priority = document.getElementById('priority');
            if (priority) priority.selectedIndex = 0;

            const categoryId = document.getElementById('categoryId');
            if (categoryId) categoryId.selectedIndex = 0;

            const serviceId = document.getElementById('serviceId');
            if (serviceId) serviceId.innerHTML = '<option value="">Tất cả dịch vụ</option>';

            const staffId = document.getElementById('staffId');
            if (staffId) staffId.selectedIndex = 0;

            const pageSizeSelect = document.getElementById('pageSizeSelect');
            if (pageSizeSelect) pageSizeSelect.selectedIndex = 0;
            const pageSizeInput = document.querySelector('#filterForm input[name="pageSize"]');
            if (pageSizeInput) pageSizeInput.value = '10';

            triggerStaffAjaxFilter();
        }

        function updatePageSize(size) {
            const pageSizeInput = document.querySelector('#filterForm input[name="pageSize"]');
            if (pageSizeInput) {
                pageSizeInput.value = size;
            }
            triggerStaffAjaxFilter();
        }

        function triggerStaffAjaxFilter(pageUrl = null) {
            const tableWrapper = document.querySelector('.table-responsive-wrapper');
            if (!tableWrapper) return;

            // Show loading spinner
            tableWrapper.classList.add('loading-ajax');
            let overlay = tableWrapper.querySelector('.loading-overlay-ajax');
            if (!overlay) {
                overlay = document.createElement('div');
                overlay.className = 'loading-overlay-ajax';
                overlay.innerHTML = '<div class="loading-spinner-ajax"></div>';
                tableWrapper.appendChild(overlay);
            }

            let url;
            if (pageUrl) {
                url = pageUrl;
            } else {
                const form = document.getElementById('filterForm');
                const params = new URLSearchParams();
                
                const kw = document.getElementById('keyword')?.value || '';
                const st = document.getElementById('status')?.value || '';
                const pr = document.getElementById('priority')?.value || '';
                const cat = document.getElementById('categoryId')?.value || '';
                const sv = document.getElementById('serviceId')?.value || '';
                const staff = document.getElementById('staffId')?.value || '';
                const ps = form.querySelector('input[name="pageSize"]')?.value || '10';
                const sort = form.querySelector('input[name="sort"]')?.value || 'newest';

                if (kw.trim()) params.set('keyword', kw.trim());
                if (st) params.set('status', st);
                if (pr) params.set('priority', pr);
                if (cat) params.set('categoryId', cat);
                if (sv) params.set('serviceId', sv);
                if (staff) params.set('staffId', staff);
                params.set('pageSize', ps);
                params.set('sort', sort);
                params.set('page', '1');

                url = window.location.pathname + '?' + params.toString();
            }

            fetch(url)
                .then(res => {
                    if (!res.ok) throw new Error('Failed to load tickets.');
                    return res.text();
                })
                .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');

                    // 1. Swap table body
                    const newTableBody = doc.querySelector('.custom-table tbody');
                    const currentTableBody = document.querySelector('.custom-table tbody');
                    if (newTableBody && currentTableBody) {
                        currentTableBody.innerHTML = newTableBody.innerHTML;
                    }

                    // 2. Swap count info
                    const countDetails = document.getElementById('tableCountDetails');
                    const newCountDetails = doc.getElementById('tableCountDetails');
                    if (countDetails && newCountDetails) {
                        countDetails.innerHTML = newCountDetails.innerHTML;
                    }

                    // 3. Swap pagination nav
                    const pagination = document.getElementById('tablePagination');
                    const newPagination = doc.getElementById('tablePagination');
                    if (pagination && newPagination) {
                        pagination.innerHTML = newPagination.innerHTML;
                    } else if (pagination && !newPagination) {
                        pagination.innerHTML = '';
                    }

                    // 4. Update KPI numbers
                    const kpiIds = ['kpi-total', 'kpi-waiting', 'kpi-processing', 'kpi-completed', 'kpi-cancelled'];
                    kpiIds.forEach(id => {
                        const el = document.getElementById(id);
                        const newEl = doc.getElementById(id);
                        if (el && newEl) {
                            el.textContent = newEl.textContent;
                        }
                    });

                    // Re-bind pagination clicks
                    bindStaffPagination();

                    // Update URL
                    history.pushState(null, '', url);
                })
                .catch(err => {
                    console.error('Error loading tickets via AJAX:', err);
                })
                .finally(() => {
                    tableWrapper.classList.remove('loading-ajax');
                    const newOverlay = tableWrapper.querySelector('.loading-overlay-ajax');
                    if (newOverlay) newOverlay.remove();
                });
        }

        function openAssignModal(ticketId) {
            fetch(`/Staff/PhanCongNhanVien/${ticketId}`)
                .then(res => {
                    if (!res.ok) throw new Error('Không thể tải popup phân công.');
                    return res.text();
                })
                .then(html => {
                    const container = document.getElementById('modalContainer');
                    if (container) {
                        container.innerHTML = html;
                        const modalEl = document.getElementById('assignModal');
                        const modal = new bootstrap.Modal(modalEl);
                        modal.show();
                    }
                })
                .catch(err => {
                    console.error(err);
                    alert('Lỗi: ' + err.message);
                });
        }

        function submitAssignForm(form) {
            const formData = new FormData(form);
            fetch(form.action, {
                method: 'POST',
                body: formData
            })
            .then(res => res.json())
            .then(data => {
                if (data.success) {
                    const modalEl = document.getElementById('assignModal');
                    const modal = bootstrap.Modal.getInstance(modalEl);
                    if (modal) modal.hide();

                    showStaffNotification(data.message, 'success');
                    triggerStaffAjaxFilter();
                } else {
                    alert(data.message || 'Lỗi phân công');
                }
            })
            .catch(err => {
                console.error(err);
                alert('Có lỗi xảy ra trong quá trình xử lý.');
            });
            return false;
        }

        function showStaffNotification(msg, type = 'success') {
            let alertBox = document.querySelector('.alert.alert-success');
            if (!alertBox) {
                const header = document.querySelector('.row.align-items-center.mb-4.g-3');
                if (header) {
                    alertBox = document.createElement('div');
                    alertBox.className = 'alert alert-success border-0 rounded-3 mb-4 shadow-sm animate-fade-up';
                    alertBox.innerHTML = '<i class="bi bi-check-circle-fill me-2"></i> <span class="msg-content"></span>';
                    header.parentNode.insertBefore(alertBox, header);
                }
            }
            if (alertBox) {
                const contentSpan = alertBox.querySelector('.msg-content');
                if (contentSpan) {
                    contentSpan.textContent = msg;
                } else {
                    alertBox.innerHTML = `<i class="bi bi-check-circle-fill me-2"></i> <span class="msg-content">${msg}</span>`;
                }
                alertBox.style.display = 'block';
                setTimeout(() => {
                    alertBox.style.display = 'none';
                }, 4000);
            }
        }
    </script>
}
