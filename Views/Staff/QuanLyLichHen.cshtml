                                @foreach (var ktv in Model.DanhSachKTV)
                                {
                                    <option value="@ktv.Value">@ktv.Text</option>
                                }
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-secondary">Ngày hẹn</label>
                            <input type="date" name="NgayHenStr" class="form-control px-3 py-2" required style="border-radius:10px;" value="@DateTime.Today.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small text-secondary">Giờ bắt đầu</label>
                            <input type="time" name="GioBatDauStr" class="form-control px-3 py-2" required style="border-radius:10px;" value="08:00">
                        </div>
                        <div class="col-6">
                            <label class="form-label fw-bold small text-secondary">Giờ kết thúc</label>
                            <input type="time" name="GioKetThucStr" class="form-control px-3 py-2" required style="border-radius:10px;" value="10:00">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-secondary">Địa chỉ hỗ trợ</label>
                            <input type="text" name="DiaChiHoTro" class="form-control px-3 py-2" placeholder="Nhập địa chỉ cụ thể..." style="border-radius:10px;">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-secondary">Ghi chú</label>
                            <textarea name="GhiChu" class="form-control px-3 py-2" rows="2" placeholder="Nội dung/yêu cầu công việc..." style="border-radius:10px;"></textarea>
                        </div>
                    </div>
                    <div class="d-flex gap-2 justify-content-end mt-4">
                        <button type="button" class="btn btn-light fw-bold px-4" data-bs-dismiss="modal" style="border-radius:10px;">Hủy bỏ</button>
                        <button type="submit" class="btn btn-danger fw-bold px-4 btn-ripple border-0" style="border-radius:10px; background-color: var(--vt-primary);">Lưu lịch hẹn</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

