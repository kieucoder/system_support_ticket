<!-- Scripts -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
<script src="~/assets/js/staff/sidebar-loader.js"></script>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        // --- 1. THEME MANAGEMENT (DARK MODE) ---
        const htmlElement = document.documentElement;
        const themeToggleBtn = document.getElementById("darkThemeToggle");
        const toggleIcon = themeToggleBtn.querySelector("i");

        // Load saved theme
        const savedTheme = localStorage.getItem("staff-theme") || "light";
        htmlElement.setAttribute("data-bs-theme", savedTheme);
        updateThemeIcon(savedTheme);

        themeToggleBtn.addEventListener("click", function() {
            const currentTheme = htmlElement.getAttribute("data-bs-theme");
            const newTheme = currentTheme === "dark" ? "light" : "dark";
            htmlElement.setAttribute("data-bs-theme", newTheme);
            localStorage.setItem("staff-theme", newTheme);
            updateThemeIcon(newTheme);
        });

        function updateThemeIcon(theme) {
            if (theme === "dark") {
                toggleIcon.className = "bi bi-sun-fill text-warning";
            } else {
                toggleIcon.className = "bi bi-moon-stars-fill text-secondary";
            }
        }

        // --- 2. CALENDAR VIEW MODE CONTROLLER (JS ONLY UI FILTERS) ---
        let currentViewMode = "month"; // month, week, day
        const viewModeButtons = document.querySelectorAll(".btn-view-mode");
        const viewIndicator = document.getElementById("viewIndicator");
        
        // Find reference date (selected day or today)
        let refDateStr = "@(chiTiet?.NgayHen?.ToString("yyyy-MM-dd") ?? today.ToString("yyyy-MM-dd"))";
        
        viewModeButtons.forEach(btn => {
            btn.addEventListener("click", function() {
                viewModeButtons.forEach(b => b.classList.remove("active"));
                this.classList.add("active");
                
                const mode = this.getAttribute("data-mode");
                setViewMode(mode);
            });
        });

        function setViewMode(mode) {
            currentViewMode = mode;
            
            if (mode === "month") {
                viewIndicator.innerText = "Chế độ xem: Tháng";
                showMonthView();
            } else if (mode === "week") {
                viewIndicator.innerText = "Chế độ xem: Tuần";
                showWeekView(refDateStr);
            } else if (mode === "day") {
                viewIndicator.innerText = "Chế độ xem: Ngày";
                showDayView(refDateStr);
            }
        }

        function showMonthView() {
            document.querySelectorAll(".calendar-day-cell").forEach(cell => {
                cell.classList.remove("hidden-by-view");
                cell.style.width = "";
            });
            document.querySelector(".calendar-header-grid").style.display = "";
        }

        function showWeekView(referenceDateStr) {
            let refDate = new Date(referenceDateStr);
            // Get day of week (0 = Sun, 1 = Mon, ..., 6 = Sat)
            let day = refDate.getDay();
            let diff = refDate.getDate() - day + (day === 0 ? -6 : 1); // Adjust for Monday start
            let monday = new Date(refDate.setDate(diff));
            monday.setHours(0,0,0,0);
            
            let sunday = new Date(monday);
            sunday.setDate(monday.getDate() + 6);
            sunday.setHours(23,59,59,999);
            
            document.querySelectorAll(".calendar-day-cell").forEach(cell => {
                if (cell.classList.contains("empty-day")) {
                    cell.classList.add("hidden-by-view");
                    return;
                }
                let cellDate = new Date(cell.getAttribute("data-date"));
                if (cellDate >= monday && cellDate <= sunday) {
                    cell.classList.remove("hidden-by-view");
                } else {
                    cell.classList.add("hidden-by-view");
                }
            });
            document.querySelector(".calendar-header-grid").style.display = "";
        }

        function showDayView(referenceDateStr) {
            document.querySelectorAll(".calendar-day-cell").forEach(cell => {
                if (cell.getAttribute("data-date") === referenceDateStr) {
                    cell.classList.remove("hidden-by-view");
                    cell.style.width = "100%";
                } else {
                    cell.classList.add("hidden-by-view");
                }
            });
            document.querySelector(".calendar-header-grid").style.display = "none";
        }

        // Today Button Navigation click
        const todayBtn = document.getElementById("btnToday");
        todayBtn.addEventListener("click", function() {
            // Check if current calendar has today's month & year
            const todayThang = @today.Month;
            const todayNam = @today.Year;
            const currentThang = @Model.CalendarThang;
            const currentNam = @Model.CalendarNam;

            if (currentThang !== todayThang || currentNam !== todayNam) {
                // Redirect to current month
                window.location.href = "@Url.Action("QuanLyLichHen", "Staff")";
            } else {
                // Just select today's cell and highlight it
                const todayCellStr = "@today.ToString("yyyy-MM-dd")";
                const cell = document.querySelector(`.calendar-day-cell[data-date="${todayCellStr}"]`);
                if (cell) {
                    cell.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    cell.classList.add("flash-highlight");
                    setTimeout(() => cell.classList.remove("flash-highlight"), 2000);
                    
                    // Trigger click to view
                    const eventLink = cell.querySelector(".calendar-event-card");
                    if (eventLink) {
                        eventLink.click();
                    }
                }
            }
        });

        // --- 3. TIMELINE & HOURS CLICK INTEGRATION ---
        document.querySelectorAll(".hour-event-tag[data-id]").forEach(tag => {
            tag.addEventListener("click", function(e) {
                e.stopPropagation();
                let apptId = this.getAttribute("data-id");
                let card = document.querySelector(`.calendar-event-card[data-id="${apptId}"]`);
                if (card) {
                    card.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    card.classList.add("flash-highlight");
                    setTimeout(() => card.classList.remove("flash-highlight"), 2000);
                    
                    // Click the card to navigate
                    setTimeout(() => {
                        window.location.href = card.getAttribute("href");
                    }, 400);
                }
            });
        });

        // Click on hourly point to navigate
        document.querySelectorAll(".timeline-hour-point").forEach(point => {
            point.addEventListener("click", function() {
                const tag = this.querySelector(".hour-event-tag[data-id]");
                if (tag) {
                    tag.click();
                }
            });
        });

        // --- 4. RESPONSIVE SIDEBAR DRAWER SYSTEM ---
        const sidebarContainer = document.getElementById("sidebarContainer");
        const drawerBackdrop = document.getElementById("drawerBackdrop");
        const closeDrawerBtn = document.getElementById("closeSidebarDrawer");

        // Automatically show drawer on mobile/tablet if selectedId exists
        const hasSelected = @(chiTiet != null ? "true" : "false");
        if (hasSelected && window.innerWidth < 1200) {
            openDrawer();
        }

        if (closeDrawerBtn) {
            closeDrawerBtn.addEventListener("click", closeDrawer);
        }
        if (drawerBackdrop) {
            drawerBackdrop.addEventListener("click", closeDrawer);
        }

        function openDrawer() {
            sidebarContainer.classList.add("show-drawer");
            drawerBackdrop.classList.add("show-drawer");
        }

        function closeDrawer() {
            sidebarContainer.classList.remove("show-drawer");
            drawerBackdrop.classList.remove("show-drawer");
        }

        // --- 5. RIPPLE CLICK ANIMATION EFFECT ---
        document.querySelectorAll(".btn-ripple").forEach(btn => {
            btn.addEventListener("click", function(e) {
                let x = e.clientX - e.target.getBoundingClientRect().left;
                let y = e.clientY - e.target.getBoundingClientRect().top;
                
                let ripple = document.createElement("span");
                ripple.style.left = x + "px";
                ripple.style.top = y + "px";
                ripple.className = "ripple-span"; // Add standard style or animate directly
                
                this.appendChild(ripple);
                setTimeout(() => ripple.remove(), 1000);
            });
        });

        // Scroll active elements into view on startup
        const activeCard = document.querySelector(".calendar-event-card.active");
        if (activeCard) {
            activeCard.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
        
        // Scroll horizontal timeline to center current hour if today
        const currentHourPoint = document.querySelector(".timeline-hour-point.is-current");
        if (currentHourPoint) {
            currentHourPoint.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
        }
    });
</script>
</body>
</html>