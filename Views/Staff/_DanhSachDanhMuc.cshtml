@model List<SupportTicketSysterm.Data.DanhMuc>

<div class="vt-table-header">
    <div class="vt-table-header-left">
        <h2>Danh sách danh mục</h2>
        <p id="catTableMeta">Đang hiển thị @ViewBag.StartItem - @ViewBag.EndItem trong tổng số @ViewBag.TotalItems danh mục</p>
    </div>
    <span class="vt-count-badge">
        <i class="bi bi-layer-group me-1"></i>
        <span id="catCount">@ViewBag.TotalItems</span> danh mục
    </span>
</div>

<!-- Desktop Table View -->
<div class="vt-custom-table-container">
    <table class="vt-table" aria-label="Danh sách danh mục sự cố">
        <thead>
            <tr>
                <th style="width: 60px;">#</th>
                <th>Tên danh mục</th>
                <th>Mô tả</th>
                <th style="width: 150px;">Trạng thái</th>
                <th style="width: 150px;">Ngày tạo</th>
                <th style="width: 150px; text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="6">
                        <div style="text-align: center; padding: 48px 20px;">
                            <div style="width: 64px; height: 64px; border-radius: 50%; background-color: var(--vt-red-glow); color: var(--vt-red); display: inline-flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 12px;">
                                <i class="fa-solid fa-folder-open"></i>
                            </div>
                            <h6 style="font-weight: 700; margin-bottom: 4px; color: var(--text-main);">Không tìm thấy danh mục</h6>
                            <p style="font-size: 0.82rem; color: var(--text-muted); margin: 0;">Thử thay đổi từ khóa tìm kiếm hoặc bộ lọc trạng thái.</p>
                        </div>
                    </td>
                </tr>
            }
            else
            {
                int stt = ViewBag.StartItem;
                @foreach (var item in Model)
                {
                    var isActive = item.TrangThai == "Hoạt động" || item.TrangThai == "Hoạt Động";
                    <tr>
                        <td style="color: var(--text-muted); font-weight: 600; font-size: 0.8rem;">@stt</td>
                        <td>
                            <div class="vt-cat-name-group">
                                <div class="vt-cat-avatar"><i class="fa-solid fa-layer-group"></i></div>
                                <span class="vt-cat-name">@item.TenDanhMuc</span>
                            </div>
                        </td>
                        <td>
                            <div class="vt-cat-desc" title="@item.MoTa">@(item.MoTa ?? "—")</div>
                        </td>
                        <td>
                            <span class="vt-badge @(isActive ? "active" : "locked")">
                                <i class="fa-solid @(isActive ? "fa-circle-check" : "fa-circle-pause")"></i>
                                @item.TrangThai
                            </span>
                        </td>
                        <td>
                            <span style="font-size: 0.82rem; color: var(--text-muted);">
                                <i class="fa-regular fa-calendar me-1"></i>@(item.NgayTao?.ToString("yyyy-MM-dd") ?? "—")
                            </span>
                        </td>
                        <td>
                            <div class="vt-action-wrap" style="justify-content: center;">
                                <button class="vt-btn-action view" data-tooltip="Chi tiết" onclick="openViewModalServer(@item.IdDanhMuc)">
                                    <i class="fa-solid fa-eye"></i>
                                </button>
                                <button class="vt-btn-action edit" data-tooltip="Chỉnh sửa" onclick="openEditModalServer(@item.IdDanhMuc)">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </button>
                                @if (isActive)
                                {
                                    <button class="vt-btn-action lock text-warning" data-tooltip="Tạm khóa" onclick="toggleLockServer(@item.IdDanhMuc)">
                                        <i class="fa-solid fa-lock"></i>
                                    </button>
                                }
                                else
                                {
                                    <button class="vt-btn-action unlock text-success" data-tooltip="Kích hoạt" onclick="toggleLockServer(@item.IdDanhMuc)">
                                        <i class="fa-solid fa-lock-open"></i>
                                    </button>
                                }
                                <button class="vt-btn-action delete" data-tooltip="Xóa" onclick="openDeleteModalServer(@item.IdDanhMuc, '@Html.Raw(item.TenDanhMuc)')">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    stt++;
                }
            }
        </tbody>
    </table>
</div>

<!-- Mobile Card View -->
<div class="vt-mobile-cards" id="categoriesMobileContainer">
    @if (Model.Count == 0)
    {
        <div style="text-align: center; padding: 48px 20px;">
            <div style="width: 64px; height: 64px; border-radius: 50%; background-color: var(--vt-red-glow); color: var(--vt-red); display: inline-flex; align-items: center; justify-content: center; font-size: 1.5rem; margin-bottom: 12px;">
                <i class="fa-solid fa-folder-open"></i>
            </div>
            <h6 style="font-weight: 700; margin-bottom: 4px; color: var(--text-main);">Không tìm thấy danh mục</h6>
            <p style="font-size: 0.82rem; color: var(--text-muted); margin: 0;">Thử thay đổi từ khóa tìm kiếm hoặc bộ lọc trạng thái.</p>
        </div>
    }
    else
    {
        @foreach (var item in Model)
        {
            var isActive = item.TrangThai == "Hoạt động" || item.TrangThai == "Hoạt Động";
            <div class="vt-mobile-card">
                <div class="vt-mobile-card-header">
                    <span class="vt-id-tag">DM@(item.IdDanhMuc)</span>
                    <span class="vt-badge @(isActive ? "active" : "locked")">
                        <i class="fa-solid @(isActive ? "fa-circle-check" : "fa-circle-pause")"></i>
                        @item.TrangThai
                    </span>
                </div>
                <div class="vt-mobile-card-title">@item.TenDanhMuc</div>
                <div class="vt-mobile-card-body">@(item.MoTa ?? "—")</div>
                <div class="vt-mobile-card-meta">
                    <span><i class="fa-regular fa-calendar-days me-1"></i> @(item.NgayTao?.ToString("yyyy-MM-dd") ?? "—")</span>
                    <div class="vt-action-wrap">
                        <button class="vt-btn-action view" data-tooltip="Chi tiết" onclick="openViewModalServer(@item.IdDanhMuc)">
                            <i class="fa-solid fa-eye"></i>
                        </button>
                        <button class="vt-btn-action edit" data-tooltip="Sửa" onclick="openEditModalServer(@item.IdDanhMuc)">
                            <i class="fa-solid fa-pen-to-square"></i>
                        </button>
                        @if (isActive)
                        {
                            <button class="vt-btn-action lock text-warning" data-tooltip="Tạm khóa" onclick="toggleLockServer(@item.IdDanhMuc)">
                                <i class="fa-solid fa-lock"></i>
                            </button>
                        }
                        else
                        {
                            <button class="vt-btn-action unlock text-success" data-tooltip="Kích hoạt" onclick="toggleLockServer(@item.IdDanhMuc)">
                                <i class="fa-solid fa-lock-open"></i>
                            </button>
                        }
                        <button class="vt-btn-action delete" data-tooltip="Xóa" onclick="openDeleteModalServer(@item.IdDanhMuc, '@Html.Raw(item.TenDanhMuc)')">
                            <i class="fa-solid fa-trash-can"></i>
                        </button>
                    </div>
                </div>
            </div>
        }
    }
</div>

<!-- Pagination -->
<div class="vt-pagination-wrap">
    <span class="vt-pagination-info" id="catPaginationInfo">
        Đang hiển thị @ViewBag.StartItem đến @ViewBag.EndItem trong tổng số @ViewBag.TotalItems danh mục
    </span>
    <div id="catPagination" class="vt-pagination" role="navigation" aria-label="Phân trang">
        <button class="vt-page-btn" onclick="goPage(@(ViewBag.CurrentPage - 1))" @(ViewBag.CurrentPage <= 1 ? "disabled" : "") title="Trang trước">
            <i class="fa-solid fa-chevron-left" style="font-size:0.7rem;"></i>
        </button>

        @{
            int totalPages = ViewBag.TotalPages;
            int currentPage = ViewBag.CurrentPage;
            // Generate list of page numbers to display
            List<string> pages = new List<string>();
            int maxVisible = 5;
            if (totalPages <= maxVisible)
            {
                for (int i = 1; i <= totalPages; i++) pages.Add(i.ToString());
            }
            else
            {
                int half = maxVisible / 2;
                int start = Math.Max(1, currentPage - half);
                int end = Math.Min(totalPages, start + maxVisible - 1);
                if (end - start < maxVisible - 1)
                {
                    start = Math.Max(1, end - maxVisible + 1);
                }

                if (start > 1)
                {
                    pages.Add("1");
                    if (start > 2) pages.Add("…");
                }
                for (int p = start; p <= end; p++)
                {
                    pages.Add(p.ToString());
                }
                if (end < totalPages)
                {
                    if (end < totalPages - 1) pages.Add("…");
                    pages.Add(totalPages.ToString());
                }
            }
        }

        @foreach (var p in pages)
        {
            if (p == "…")
            {
                <button class="vt-page-btn" disabled>…</button>
            }
            else
            {
                int pageNum = int.Parse(p);
                <button class="vt-page-btn @(pageNum == currentPage ? "active" : "")" onclick="goPage(@pageNum)">@pageNum</button>
            }
        }

        <button class="vt-page-btn" onclick="goPage(@(ViewBag.CurrentPage + 1))" @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "") title="Trang sau">
            <i class="fa-solid fa-chevron-right" style="font-size:0.7rem;"></i>
        </button>
    </div>
</div>
