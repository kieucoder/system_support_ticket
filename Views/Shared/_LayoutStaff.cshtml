@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@{
    var hoTen = Context.Session?.GetString("HoTen") ?? User.FindFirstValue("HoTen") ?? User.Identity?.Name ?? "Nhân viên";
    var vaiTro = Context.Session?.GetString("Role") ?? User.FindFirstValue(ClaimTypes.Role) ?? "NhanVien";
    var vaiTroVn = vaiTro == "Admin" ? "Quản trị viên" : "Nhân viên hỗ trợ";
    var avatar = Context.Session?.GetString("Avatar");
    var avatarUrl = !string.IsNullOrEmpty(avatar) 
        ? "/uploads/avatar/" + avatar 
        : "https://ui-avatars.com/api/?name=" + System.Net.WebUtility.UrlEncode(hoTen) + "&background=EE0033&color=fff&size=38";
}
<!DOCTYPE html>
<html lang="vi" data-bs-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>@(ViewData["Title"] ?? "TechSupport Viettel Admin")</title>
    <meta name="description" content="Bảng điều khiển quản trị hệ thống phiếu hỗ trợ kỹ thuật Viettel Telecom 2026.">
    <meta name="robots" content="noindex, nofollow">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Font Awesome 6 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">
    <!-- Google Fonts Inter -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
          rel="stylesheet">
    <!-- Admin Dashboard CSS -->
    <link rel="stylesheet" href="~/assets/css/staff/dashboard.css">
    <!-- Page-specific CSS Section -->
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>
    <div id="adminLayout">

        <partial name="~/Views/Shared/SidebarStaff.cshtml" />

        <div class="main-wrapper">

            <!-- TOPBAR -->
            <header class="admin-topbar" role="banner">
                <div class="topbar-left">
                    <!-- Hamburger for Mobile -->
                    <button class="sidebar-toggle-btn d-lg-none" id="toggleMobileSidebar"
                            data-bs-toggle="offcanvas" data-bs-target="#adminSidebar"
                            aria-label="Open sidebar menu">
                        <i class="bi bi-bars"></i>
                    </button>
                    <!-- Collapse for Desktop -->
                    <button class="sidebar-toggle-btn d-none d-lg-flex" id="toggleSidebar" aria-label="Toggle sidebar">
                        <i class="bi bi-bars"></i>
                    </button>

                    <!-- Page Title breadcrumb -->
                    <div class="d-none d-md-block">
                        <p class="mb-0 fw-semibold" style="font-size:0.95rem; color: var(--text-main);">
                            @(ViewData["HeaderTitle"] ?? "Tổng Quan Hệ Thống")
                        </p>
                        <p class="mb-0" style="font-size: 0.75rem; color: var(--text-muted);">
                            @(ViewData["HeaderSubtitle"] ?? "Cập nhật lần cuối hôm nay")
                        </p>
                    </div>
                </div>

                <!-- Global Search (Desktop) -->
                <form class="topbar-search-form d-none d-md-block" role="search" aria-label="Global search">
                    <div class="search-input-group">
                        <i class="fa-solid fa-search" aria-hidden="true"></i>
                        <input type="search" class="form-control search-bar-input" id="globalSearchInput"
                               placeholder="Tìm phiếu, dịch vụ, khách hàng..." autocomplete="off"
                               aria-label="Tìm kiếm hệ thống">
                    </div>
                </form>

                <div class="topbar-right">
                    <!-- Theme Toggle -->
                    <button class="topbar-action-btn" id="toggleTheme" title="Chuyển Dark Mode"
                            aria-label="Toggle theme">
                        <i class="bi bi-moon"></i>
                    </button>

                    <!-- Notification Bell -->
                    <button class="topbar-action-btn" title="Thông báo hệ thống" aria-label="Notifications">
                        <i class="fa-solid fa-bell"></i>
                        <span class="notification-badge" aria-label="5 thông báo mới">5</span>
                    </button>

                    <!-- User Avatar Dropdown -->
                    <div class="dropdown">
                        <a class="user-profile-dropdown" href="#" role="button" data-bs-toggle="dropdown"
                           aria-expanded="false" id="userDropdown" aria-label="User profile menu">
                            <img src="@avatarUrl" alt="Avatar nhân viên" class="user-avatar" style="object-fit: cover;">
                            <div class="d-none d-sm-block">
                                <p class="user-profile-name mb-0">@hoTen</p>
                                <p class="mb-0 user-profile-role">
                                    @vaiTroVn
                                </p>
                            </div>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2"
                            style="border-radius:12px; min-width:200px;">
                            <li>
                                <a class="dropdown-item py-2" asp-controller="Staff" asp-action="TaiKhoanNhanVien">
                                    <i class="fa-solid fa-user me-2 text-primary"></i>Thông tin cá nhân
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item py-2" asp-controller="Staff" asp-action="TaiKhoanNhanVien" asp-fragment="changePassword">
                                    <i class="fa-solid fa-key me-2 text-warning"></i>Đổi mật khẩu
                                </a>
                            </li>
                            <li>
                                <hr class="dropdown-divider">
                            </li>
                            <li>
                                <a class="dropdown-item py-2 text-danger" asp-controller="Auth" asp-action="DangXuat">
                                    <i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </header>

            <!-- MAIN CONTENT AREA -->
            <main class="admin-content" id="mainContent">
                @RenderBody()
            </main>
            <!-- END MAIN CONTENT -->

        </div>
        <!-- END MAIN WRAPPER -->

    </div>
    <!-- END ADMIN LAYOUT -->
    <!-- Bootstrap 5 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Chart.js CDN -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
    <!-- SweetAlert2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.all.min.js"></script>
    <!-- Flatpickr (Calendar Picker used in appointments) -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
    <!-- Dashboard JS -->
    <script src="~/assets/js/staff/dashboard.js"></script>
    <!-- Sidebar loader (dùng chung) -->
    <script src="~/assets/js/staff/sidebar-loader.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>