    <div id="chatbox-container" class="chatbox-wrapper">
        <!-- 1. Floating Chat Launcher -->
        <button class="chat-launcher" id="chatLauncher" aria-label="Mở Trợ lý Hỗ trợ Kỹ thuật">
            <i class="bi bi-chat-dots chat-icon-open" style="font-size: 1.75rem;"></i>
            <i class="bi bi-x-lg chat-icon-close" style="font-size: 1.5rem;"></i>
            <span class="chat-launcher-badge" id="launcherBadge">2</span>
            <span class="chat-launcher-online-dot"></span>
        </button>

        <!-- 2. Chat Window Box -->
        <div class="chat-window" id="chatWindow">

            <!-- Fixed Header Area -->
            <div class="chat-header">
                <div class="chat-header-brand">
                    <div class="chat-header-avatar">
                        <i class="bi bi-robot"></i>
                        <span class="chat-header-online-status"></span>
                    </div>
                    <div class="chat-header-text">
                        <span class="chat-header-title">TechSupport AI</span>
                        <span class="chat-header-status-badge-top"><span class="status-dot"></span> Online</span>
                    </div>
                </div>
                <div class="chat-header-actions">
                    <button class="chat-header-btn" id="chatMinimize" title="Thu nhỏ" aria-label="Minimize">
                        <i class="bi bi-dash-lg"></i>
                    </button>
                    <button class="chat-header-btn" id="chatMaximize" title="Phóng to" aria-label="Maximize">
                        <i class="bi bi-arrows-fullscreen"></i>
                    </button>
                    <button class="chat-header-btn" id="chatRefresh" title="Làm mới cuộc trò chuyện"
                            aria-label="Refresh"
                            onclick="document.getElementById('chatMessagesContainer').innerHTML = ''; document.getElementById('chatWindow').classList.remove('chat-active-stream'); document.querySelectorAll('.convo-row').forEach(row => row.classList.remove('active'));">
                        <i class="bi bi-arrow-clockwise"></i>
                    </button>
                    <button class="chat-header-btn" id="chatClose" title="Đóng" aria-label="Close">
                        <i class="bi bi-x-lg"></i>
                    </button>
                </div>
            </div>

            <!-- Main Chat Body Sliding Containers -->
            <div class="chat-body-container">

                <!-- Screen 1: Welcome & Actions & Conversations -->
                <div class="chat-screen" id="screenWelcome">
                    <div class="welcome-scrollable">
                        <!-- Greeting message -->
                        <div class="welcome-greeting-box">
                            <div class="welcome-avatar-robot-container">
                                <span class="welcome-avatar-robot"><i class="bi bi-robot"></i></span>
                            </div>
                            <h2 class="welcome-greeting-title">Xin chào 👋</h2>
                            <p class="welcome-greeting-desc">
                                Tôi là TechSupport AI. Tôi có thể hỗ trợ bạn xử lý sự cố kỹ
                                thuật, tạo phiếu hỗ trợ và kết nối với kỹ thuật viên nhanh chóng.
                            </p>
                        </div>

                        <!-- Checklist -->
                        <div class="welcome-checklist">
                            <div class="welcome-checklist-title">
                                <i class="bi bi-lightning-charge-fill text-danger me-2"></i>Tôi có thể hỗ trợ bạn
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-ticket-perforated"></i></span>
                                <span>Tạo phiếu hỗ trợ</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-search"></i></span>
                                <span>Tra cứu trạng thái phiếu</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-globe"></i></span>
                                <span>Khắc phục lỗi Internet</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-tv"></i></span>
                                <span>Khắc phục lỗi TV</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-calendar-event"></i></span>
                                <span>Đặt lịch kỹ thuật</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-chat-dots"></i></span>
                                <span>Chat với nhân viên</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-graph-up-arrow"></i></span>
                                <span>Theo dõi tiến độ</span>
                            </div>
                            <div class="welcome-checklist-item">
                                <span class="checklist-icon"><i class="bi bi-star"></i></span>
                                <span>Đánh giá dịch vụ</span>
                            </div>
                        </div>

                        <!-- Quick Actions Grid -->
                        <div class="quick-actions-section">
                            <h3 class="welcome-section-title">
                                <i class="bi bi-lightning-fill text-warning me-1"></i> Yêu
                                cầu nhanh
                            </h3>
                            <div class="quick-actions-list">
                                <button class="quick-action-card" data-action="create-ticket">
                                    <div class="quick-action-icon-wrapper"><i class="bi bi-ticket-perforated"></i></div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Tạo phiếu hỗ trợ</span>
                                        <span class="quick-action-card-desc">
                                            Gửi yêu cầu hỗ trợ kỹ thuật nhanh
                                            chóng
                                        </span>
                                    </div>
                                </button>
                                <button class="quick-action-card" data-action="lookup-ticket">
                                    <div class="quick-action-icon-wrapper"><i class="bi bi-search"></i></div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Tra cứu trạng thái</span>
                                        <span class="quick-action-card-desc">
                                            Theo dõi tiến độ xử lý phiếu kỹ
                                            thuật
                                        </span>
                                    </div>
                                </button>
                                <button class="quick-action-card" data-action="troubleshoot">
                                    <div class="quick-action-icon-wrapper"><i class="bi bi-globe"></i></div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Khắc phục Internet</span>
                                        <span class="quick-action-card-desc">Tự hướng dẫn khắc phục sự cố mạng</span>
                                    </div>
                                </button>
                                <button class="quick-action-card" data-action="scheduler">
                                    <div class="quick-action-icon-wrapper"><i class="bi bi-speedometer2"></i></div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Mạng chậm</span>
                                        <span class="quick-action-card-desc">Đặt lịch hẹn kiểm tra tốc độ mạng</span>
                                    </div>
                                </button>
                                <button class="quick-action-card" data-action="rate">
                                    <div class="quick-action-icon-wrapper"><i class="bi bi-credit-card"></i></div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Thanh toán</span>
                                        <span class="quick-action-card-desc">
                                            Đánh giá và kiểm tra thanh toán dịch
                                            vụ
                                        </span>
                                    </div>
                                </button>
                                <button class="quick-action-card" data-action="agent">
                                    <div class="quick-action-icon-wrapper">
                                        <i class="bi bi-telephone-outbound"></i>
                                    </div>
                                    <div class="quick-action-info">
                                        <span class="quick-action-card-title">Gặp kỹ thuật viên</span>
                                        <span class="quick-action-card-desc">Kết nối trực tiếp tổng đài viên trạm</span>
                                    </div>
                                </button>
                            </div>
                        </div>

                        <!-- Past Conversation History list -->
                        <div class="history-section">
                            <h3 class="welcome-section-title">
                                <i class="bi bi-clock-history text-secondary me-1"></i>
                                Lịch sử trò chuyện
                            </h3>
                            <div class="history-toolbar">
                                <div class="history-search">
                                    <i class="bi bi-search"></i>
                                    <input type="text" id="convoSearchInput" placeholder="Tìm theo mã phiếu...">
                                </div>
                                <select class="history-filter" id="convoFilterSelect">
                                    <option value="all">Tất cả</option>
                                    <option value="processing">Đang xử lý</option>
                                    <option value="completed">Hoàn thành</option>
                                </select>
                            </div>

                            <div id="convoListContainer">
                                <!-- Injected dynamically in chatbox.js -->
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Screen 2: Active Chat Room Stream -->
                <div class="chat-screen" id="screenStream">
                    <!-- Subheader Bar with Ticket status -->
                    <div class="stream-header-bar">
                        <button class="stream-back-btn" id="btnBackToWelcome" title="Quay lại" aria-label="Quay lại">
                            <i class="bi bi-chevron-left"></i>
                        </button>
                        <div class="stream-header-info">
                            <div class="stream-header-title-row">
                                <span class="stream-header-title" id="streamTicketTitle">Hội thoại hỗ trợ</span>
                                <span class="stream-header-status-badge" id="streamTicketStatus">Hỗ trợ</span>
                            </div>
                            <span class="stream-header-desc" id="streamTicketDesc">
                                Trò chuyện tự động với trợ lý
                                ảo
                            </span>
                        </div>
                    </div>

                    <!-- Messages List Box -->
                    <div class="messages-scrollable" id="chatMessagesContainer">
                        <!-- Dynamic chat bubbles here -->
                    </div>

                    <!-- AI Typing Indicator Bubble -->
                    <div class="messages-scrollable py-0" style="flex-grow: 0; background-color: #F8FAFC;">
                        <div class="ai-typing-row" id="aiTypingIndicator">
                            <div class="msg-avatar">
                                <i class="bi bi-robot"></i>
                            </div>
                            <div class="ai-typing-bubble">
                                <span class="ai-typing-text">TechSupport AI đang soạn tin</span>
                                <div class="ai-typing-dots">
                                    <span></span>
                                    <span></span>
                                    <span></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Footer with Input -->
                    <div class="stream-footer">
                        <div class="chatgpt-input-capsule">
                            <button class="capsule-icon-btn" id="chatUploadFileBtn" title="Đính kèm tài liệu">
                                <i class="bi bi-paperclip"></i>
                            </button>
                            <button class="capsule-icon-btn" id="chatEmojiBtn" title="Thêm biểu tượng cảm xúc">
                                <i class="bi bi-emoji-smile"></i>
                            </button>

                            <textarea class="stream-textarea" id="chatInputField"
                                      placeholder="Hãy nhập câu hỏi hoặc mô tả sự cố..." rows="1" maxlength="500"></textarea>

                            <button class="capsule-icon-btn" id="chatVoiceBtn" title="Nhập bằng giọng nói">
                                <i class="bi bi-mic"></i>
                            </button>
                            <button class="stream-send-btn" id="btnSendChat" aria-label="Gửi tin nhắn">
                                <i class="bi bi-send-fill"></i>
                            </button>
                        </div>
                        <div class="stream-footer-meta d-flex justify-content-between px-2 pb-1 pt-1">
                            <span class="small text-muted" style="font-size: 10px; opacity: 0.6;">
                                TechSupport AI có thể
                                đưa ra câu trả lời không chính xác.
                            </span>
                            <span class="toolbar-char-counter text-muted" id="chatCharCounter"
                                  style="font-size: 10px; opacity: 0.6;">0/500</span>
                        </div>
                    </div>
                </div>
                @RenderBody()
            </div>
        </div>
    </div>
    </div>
    </div>

    <!-- Bootstrap 5.3 JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

    <!-- Component-Based JS -->
    <script src="~/assets/js/header.js?v=2.6.0"></script>
    <script src="~/assets/js/sidebar.js?v=2.6.0"></script>
    <script src="~/assets/js/footer.js?v=2.6.0"></script>
    <script src="~/assets/js/chatbox.js?v=2.6.0"></script>
    <script src="~/assets/js/main.js?v=2.6.0"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>