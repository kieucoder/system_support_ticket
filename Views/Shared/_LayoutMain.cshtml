@using Microsoft.EntityFrameworkCore
@inject SupportTicketSysterm.Data.TechSupportContext DbContext
@{
    var isHomePage = (ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && 
                      ViewContext.RouteData.Values["action"]?.ToString() == "Index") ||
                     (ViewContext.RouteData.Values["controller"]?.ToString() == "Customers" && 
                      ViewContext.RouteData.Values["action"]?.ToString() == "TrangChu");

    List<SupportTicketSysterm.Data.DanhMuc>? categories = null;
    if (isHomePage)
    {
        categories = await DbContext.DanhMucs
            .Where(c => c.TrangThai == "Hoạt động" || c.TrangThai == "Hoạt Động")
            .ToListAsync();
    }
}
<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>TechSupport - Hệ Thống Quản Lý Phiếu Hỗ Trợ Kỹ Thuật Viettel Telecom 2026</title>

    <!-- SEO Optimization -->
    <meta name="description"
          content="Hệ thống quản lý phiếu hỗ trợ kỹ thuật thông minh từ Viettel Telecom. Tiếp nhận ticket nhanh chóng, xử lý sự cố internet, camera, server, phần mềm 24/7 và theo dõi tiến độ realtime.">
    <meta name="keywords"
          content="quan ly ticket, phieu ho tro, ho tro ky thuat, viettel techsupport, bao hong internet, camera viettel, support ticket system">
    <meta name="author" content="Viettel Telecom TechSupport">
    <meta name="robots" content="index, follow">

    <!-- Open Graph Data -->
    <meta property="og:title" content="TechSupport - Giải Pháp Hỗ Trợ Kỹ Thuật Thông Minh">
    <meta property="og:description"
          content="Quản lý và giải quyết nhanh chóng mọi yêu cầu hỗ trợ kỹ thuật. Tự động hóa quy trình, báo cáo trực quan, theo dõi SLA chuẩn Viettel.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://techsupport.viettel.vn">

    <!-- Favicon -->
    <link rel="icon" type="~/image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font Awesome 6.6.0 CDN (Enterprise) -->
    <link rel="stylesheet" id="fa-cdn-link"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <!-- FontAwesome Fallback Script -->
    <script>
        document.getElementById('fa-cdn-link').addEventListener('error', function () {
            document.documentElement.classList.add('fa-fallback-active');
            console.warn("FontAwesome failed to load. Falling back to Bootstrap Icons.");
        });
        window.addEventListener('load', function () {
            setTimeout(function () {
                if (!document.fonts.check('12px "Font Awesome 6 Free"')) {
                    document.documentElement.classList.add('fa-fallback-active');
                }
            }, 1200);
        });
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
          rel="stylesheet">

    <!-- Component-Based CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css?v=2.6.0">
    <link rel="stylesheet" href="~/assets/css/responsive.css?v=2.6.0">
    <link rel="stylesheet" href="~/assets/css/header.css?v=2.6.0">
    <link rel="stylesheet" href="~/assets/css/sidebar.css?v=2.6.0">
    <link rel="stylesheet" href="~/assets/css/footer.css?v=2.6.0">
    <link rel="stylesheet" href="~/assets/css/chatbox.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/chatbox-responsive.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/chat-message.css" asp-append-version="true">
    @if (isHomePage)
    {
        <link rel="stylesheet" href="~/assets/css/issue-category.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>

<body>

    @await Html.PartialAsync("~/Views/Shared/_Header.cshtml", Context.Session)

    <!-- Sidebar Component Container -->
    @await Html.PartialAsync("~/Views/Shared/_Sidebar.cshtml", Context.Session)

    @if (isHomePage)
    {
        <!-- 3. HERO CAROUSEL FULLSCREEN -->
        <section class="hero-section p-0 home-hero-carousel" id="heroSection">
        <div id="heroCarousel" class="carousel slide carousel-fade hero-carousel" data-bs-ride="carousel"
             data-bs-interval="6000">
            <!-- Custom Indicators -->
            <div class="carousel-indicators">
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"
                        aria-current="true" aria-label="Slide 1"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1" aria-label="Slide 2"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="2" aria-label="Slide 3"></button>
                <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="3" aria-label="Slide 4"></button>
            </div>

            <!-- Carousel Items -->
            <!-- Carousel Items -->
            <div class="carousel-inner">
                <!-- Slide 1 -->
                <div class="carousel-item active"
                     style="background-image: url('@Url.Content("~/assets/images/hero_telecom_service.png")');">
                    <div class="hero-carousel-overlay"></div>
                    <div class="hero-carousel-content">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-md-10 col-12 text-start">
                                        <span class="hero-badge animate-fade-up">HỆ THỐNG TECHSUPPORT THÔNG MINH</span>
                                    <h1 class="hero-title animate-fade-up delay-1 text-white">
                                        GIẢI PHÁP HỖ TRỢ KỸ THUẬT<br>THÔNG
                                        MINH & REALTIME
                                    </h1>
                                        <p class="hero-desc animate-fade-up delay-2 text-white">
                                        Tiếp nhận sự cố nhanh chóng, tự động
                                        phân công kỹ thuật viên và
                                        cho phép khách hàng theo dõi trực quan tiến độ xử lý phiếu 24/7.
                                    </p>
                                    <div class="hero-buttons animate-fade-up delay-3">
                                        <a href="#quickActionSection" class="btn btn-create-ticket-custom btn-ripple">
                                            <i class="bi bi-plus-circle me-2"></i>Tạo Phiếu
                                            Ngay
                                        </a>
                                        <a href="#quickActionSection" class="btn btn-outline-light-custom btn-ripple">
                                            <i class="fa-solid fa-search me-2"></i>Tra Cứu Phiếu
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 2 -->
                <div class="carousel-item" style="background-image: url('@Url.Content("~/assets/images/hero_smart_home.png")');">
                    <div class="hero-carousel-overlay"></div>
                    <div class="hero-carousel-content">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-md-10 col-12 text-start">
                                    <span class="hero-badge animate-fade-up">QUẢN LÝ SLA CHUẨN XÁC</span>
                                    <h2 class="hero-title animate-fade-up delay-1">
                                        QUẢN LÝ PHIẾU HỖ TRỢ<br>CHUYÊN NGHIỆP
                                        TỐI ƯU
                                    </h2>
                                    <p class="hero-desc animate-fade-up delay-2">
                                        Rút ngắn thời gian gián đoạn công việc
                                        của bạn. Phân cấp nhiệm
                                        vụ thông minh, kiểm soát chỉ số SLA nghiêm ngặt và tổng hợp báo cáo trực quan.
                                    </p>
                                    <div class="hero-buttons animate-fade-up delay-3">
                                        <a href="#quickActionSection" class="btn btn-create-ticket-custom btn-ripple">
                                            <i class="fa-solid fa-ticket me-2"></i>Tạo Ticket
                                        </a>
                                        <a href="#aboutSection" class="btn btn-outline-light-custom btn-ripple">
                                            <i class="fa-solid fa-gauge-high me-2"></i>Xem Chỉ
                                            Số SLA
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 3 -->
                <div class="carousel-item" style="background-image: url('@Url.Content("~/assets/images/hero_tv_entertainment.png")');">
                    <div class="hero-carousel-overlay"></div>
                    <div class="hero-carousel-content">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-md-10 col-12 text-start">
                                    <span class="hero-badge animate-fade-up">TIÊN PHONG CHẤT LƯỢNG DỊCH VỤ</span>
                                    <h2 class="hero-title animate-fade-up delay-1">
                                        NÂNG CAO TRẢI NGHIỆM<br>KHÁCH HÀNG SỐ
                                    </h2>
                                    <p class="hero-desc animate-fade-up delay-2">
                                        Tương tác trực tiếp với nhân viên kỹ
                                        thuật thông qua cổng chat
                                        thời gian thực. Đánh giá chất lượng dịch vụ minh bạch để cải tiến hệ thống.
                                    </p>
                                    <div class="hero-buttons animate-fade-up delay-3">
                                        <a asp-controller="Customers" asp-action="ChatTrucTuyen" class="btn btn-create-ticket-custom btn-ripple">
                                            <i class="bi bi-chat-left-dots me-2"></i>Chat Trực Tuyến
                                        </a>
                                        <a href="#feedbackSection" class="btn btn-outline-light-custom btn-ripple">
                                            <i class="fa-regular fa-star-half me-2"></i>Đánh
                                            Giá Phản Hồi
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Slide 4 -->
                <div class="carousel-item" style="background-image:  url('@Url.Content("~/assets/images/hero_cloud_server.png")');">
                    <div class="hero-carousel-overlay"></div>
                    <div class="hero-carousel-content">
                        <div class="container">
                            <div class="row">
                                <div class="col-lg-8 col-md-10 col-12 text-start">
                                    <span class="hero-badge animate-fade-up">AN TOÀN & BẢO MẬT HỆ THỐNG</span>
                                    <h2 class="hero-title animate-fade-up delay-1">
                                        HẠ TẦNG CLOUD & SERVER<br>CHUYÊN
                                        NGHIỆP BẢO MẬT
                                    </h2>
                                    <p class="hero-desc animate-fade-up delay-2">
                                        Hỗ trợ khẩn cấp VPS, tối ưu hóa
                                        database, khôi phục hệ thống Cloud nhanh chóng và bảo đảm an toàn dữ liệu tuyệt
                                        đối.
                                    </p>
                                    <div class="hero-buttons animate-fade-up delay-3">
                                        <a href="#quickActionSection" class="btn btn-create-ticket-custom btn-ripple">
                                            <i class="bi bi-hdd-network me-2"></i>Yêu Cầu Server
                                        </a>
                                        <a href="#footerSection" class="btn btn-outline-light-custom btn-ripple">
                                            <i class="bi bi-telephone me-2"></i>Liên Hệ
                                            Ngay
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Controls -->
            <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Trước</span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
                <span class="visually-hidden">Sau</span>
            </button>
        </div>
    </section>

    <!-- 4. QUICK ACTION SECTION -->
    <section class="section-bg-light" id="quickActionSection">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8 col-md-10">
                    <h2 class="section-title center">Thực Hiện Nhanh</h2>
                    <p class="subtitle">
                        Thực hiện báo cáo sự cố hoặc tra cứu trạng thái giải quyết yêu cầu kỹ thuật tức
                        thì.
                    </p>
                </div>
            </div>

            <div class="row g-4 reveal">
                <!-- Action 1: Tạo phiếu hỗ trợ -->
                <div class="col-lg-3 col-md-6 col-12">
                    <div class="service-card">
                        <div class="service-icon-box">
                            <i class="bi bi-file-earmark-plus"></i>
                        </div>
                        <h4>Tạo Phiếu Hỗ Trợ</h4>
                        <p>Khai báo chi tiết sự cố mạng, phần mềm hay phần cứng để nhận trợ giúp nhanh nhất.</p>
                        <a asp-controller="Ticket" asp-action="TaoPhieu" class="service-link">
                            Tạo ticket mới <i class="bi bg-transparent bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Action 2: Tra cứu ticket -->
                <div class="col-lg-3 col-md-6 col-12">
                    <div class="service-card">
                        <div class="service-icon-box">
                            <i class="fa-solid fa-search"></i>
                        </div>
                        <h4>Tra Cứu Ticket</h4>
                        <p>
                            Nhập mã phiếu hỗ trợ hoặc số điện thoại đăng ký để kiểm tra tiến trình và kỹ thuật viên xử
                            lý.
                        </p>
                        <a asp-controller="Ticket" asp-action="TraCuuPhieu" class="service-link">
                            Tra cứu ngay <i class="bi bg-transparent bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Action 3: Chat kỹ thuật -->
                <div class="col-lg-3 col-md-6 col-12">
                    <div class="service-card">
                        <div class="service-icon-box">
                            <i class="fa-solid fa-comments"></i>
                        </div>
                        <h4>Live Support</h4>
                        <p>Kết nối trực tiếp với tổng đài viên kỹ thuật để xử lý khẩn cấp và nhận tư vấn nhanh.</p>
                        <a asp-controller="Customers" asp-action="ChatTrucTuyen" class="service-link">
                            Bắt đầu chat <i class="bi bg-transparent bi-arrow-right"></i>
                        </a>
                    </div>
                </div>

                <!-- Action 4: Đánh giá dịch vụ -->
                <div class="col-lg-3 col-md-6 col-12">
                    <div class="service-card">
                        <div class="service-icon-box">
                            <i class="fa-regular fa-star"></i>
                        </div>
                        <h4>Đánh Giá Dịch Vụ</h4>
                        <p>Đóng góp ý kiến về thái độ phục vụ và chất lượng khắc phục sự cố sau khi đóng phiếu.</p>
                        <a href="#feedbackSection" class="service-link">
                            Gửi đánh giá <i class="bi bg-transparent bi-arrow-right"></i>
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 5. GIỚI THIỆU HỆ THỐNG -->
    <section id="aboutSection">
        <div class="container">
            <div class="row align-items-center g-5">
                <!-- Left Column (Dashboard Image Preview) -->
                <div class="col-lg-6 col-12 reveal">
                    <div class="about-image-wrapper">
                        <img src="~/assets/images/about_dashboard.png" alt="TechSupport Web Dashboard" class="about-img"
                             loading="lazy">
                        <!-- Floating Widgets -->
                        <div class="about-floating-badge badge-1 animate-float">
                            <div class="badge-icon"><i class="bi bi-shield-fill-check"></i></div>
                            <div class="badge-text">
                                <span class="d-block fw-bold text-dark" style="font-size: 0.9rem;">99.9% SLA</span>
                                <span class="text-muted d-block" style="font-size: 0.72rem; line-height: 1.2;">
                                    Cam kết
                                    chất lượng
                                </span>
                            </div>
                        </div>
                        <div class="about-floating-badge badge-2 animate-float-delayed">
                            <div class="badge-icon bg-info-subtle text-info"><i class="bi bi-clock-history"></i></div>
                            <div class="badge-text">
                                <span class="d-block fw-bold text-dark" style="font-size: 0.9rem;">&lt; 30 Phút</span>
                                <span class="text-muted d-block" style="font-size: 0.72rem; line-height: 1.2;">
                                    Phản hồi
                                    sự cố
                                </span>
                            </div>
                        </div>
                        <div class="about-tag-overlay">
                            <h5>Trung Tâm Vận Hành SLA</h5>
                            <p>Tự động hóa luồng phân công ticket thông minh dựa trên kỹ năng của kỹ thuật viên.</p>
                        </div>
                    </div>
                </div>

                <!-- Right Column (Contents) -->
                <div class="col-lg-6 col-12 reveal">
                    <span class="text-danger fw-bold text-uppercase tracking-wider d-block mb-2">
                        Về hệ thống
                        TechSupport
                    </span>
                    <h2 class="section-title">Nền Tảng Quản Lý Phiếu<br>Hỗ Trợ Chuẩn Hóa 2026</h2>
                    <p class="text-muted mb-4">
                        TechSupport tích hợp các quy trình nghiệp vụ hiện đại nhằm loại bỏ hoàn
                        toàn các rào cản giao tiếp giữa khách hàng và bộ phận vận hành kỹ thuật Viettel. Đảm bảo thời
                        gian chết hệ thống ở mức tối thiểu.
                    </p>

                    <ul class="about-list">
                        <li>
                            <i class="bi bi-patch-check-fill text-danger"></i> Tự động phân cấp lỗi và chuyển hướng
                            thông minh
                        </li>
                        <li>
                            <i class="bi bi-patch-check-fill text-danger"></i> Giám sát thời gian xử lý (SLA) chặt chẽ
                            theo từng phút
                        </li>
                        <li>
                            <i class="bi bi-patch-check-fill text-danger"></i> Đồng bộ dữ liệu lịch sử sửa chữa giúp
                            chẩn đoán lỗi nhanh
                        </li>
                        <li>
                            <i class="bi bi-patch-check-fill text-danger"></i> Giao diện thân thiện tối ưu hiển thị đa
                            thiết bị
                        </li>
                    </ul>

                    <div class="d-flex align-items-center mb-4">
                        <a href="#serviceGridSection" class="btn btn-viettel btn-ripple me-4">Khám phá ngay</a>
                        <div class="d-flex align-items-center">
                            <div class="flex-shrink-0">
                                <div class="bg-danger-subtle p-3 rounded-circle text-danger d-flex align-items-center justify-content-center"
                                     style="width: 50px; height: 50px;">
                                    <i class="bi bi-shield-fill-check" style="font-size: 1.25rem;"></i>
                                </div>
                            </div>
                            <div class="ms-3">
                                <span class="d-block text-muted small fw-medium">Tiêu chuẩn kiểm duyệt</span>
                                <span class="text-dark fw-bold" style="font-size: 1.1rem;">ISO/IEC 20000 ITIL</span>
                            </div>
                        </div>
                    </div>

                    <!-- Counters inside About Section -->
                    <div class="row about-stats text-start g-3">
                        <div class="col-4">
                            <div class="about-stat-item">
                                <h3><span class="counter-value" data-target="10000">0</span>+</h3>
                                <p>Tickets xử lý</p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="about-stat-item">
                                <h3><span class="counter-value" data-target="500">0</span>+</h3>
                                <p>Kỹ thuật viên</p>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="about-stat-item">
                                <h3>99%</h3>
                                <p>Khách hàng hài lòng</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 6. QUY TRÌNH HỖ TRỢ (TIMELINE PROCESS) -->
    <section class="section-bg-light" id="processSection">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8 col-md-10">
                    <span class="text-danger fw-bold text-uppercase d-block mb-2">Vận Hành Chuyên Nghiệp</span>
                    <h2 class="section-title center">Quy Trình Xử Lý Phiếu Hỗ Trợ</h2>
                    <p class="subtitle">
                        4 bước tối giản giúp sự cố kỹ thuật của bạn được khắc phục một cách nhanh chóng
                        nhất.
                    </p>
                </div>
            </div>

            <!-- Timeline Layout -->
            <div class="support-timeline reveal mt-5">
                <div class="row g-4 relative-row">
                    <!-- Progress line background -->
                    <div class="timeline-progress-bar d-none d-lg-block">
                        <div class="process-line-fill"></div>
                    </div>

                    <!-- Step 1 -->
                    <div class="col-lg-3 col-md-6 col-12 text-center timeline-step">
                        <div class="timeline-icon-wrapper">
                            <div class="timeline-icon">
                                <i class="fa-solid fa-file-pen"></i>
                            </div>
                            <span class="step-number">01</span>
                        </div>
                        <div class="timeline-card">
                            <h4 class="fw-bold">Bước 1: Tạo Phiếu</h4>
                            <p class="text-muted mb-0">
                                Khách hàng khai báo thông tin sự cố qua Website, Hotline hoặc ứng
                                dụng di động.
                            </p>
                        </div>
                    </div>

                    <!-- Step 2 -->
                    <div class="col-lg-3 col-md-6 col-12 text-center timeline-step">
                        <div class="timeline-icon-wrapper">
                            <div class="timeline-icon">
                                <i class="fa-solid fa-clipboard-check"></i>
                            </div>
                            <span class="step-number">02</span>
                        </div>
                        <div class="timeline-card">
                            <h4 class="fw-bold">Bước 2: Tiếp Nhận</h4>
                            <p class="text-muted mb-0">
                                Hệ thống phân cấp tự động và chuyển phiếu đến tổ kỹ thuật chuyên
                                trách phù hợp.
                            </p>
                        </div>
                    </div>

                    <!-- Step 3 -->
                    <div class="col-lg-3 col-md-6 col-12 text-center timeline-step">
                        <div class="timeline-icon-wrapper">
                            <div class="timeline-icon">
                                <i class="fa-solid fa-screwdriver-wrench"></i>
                            </div>
                            <span class="step-number">03</span>
                        </div>
                        <div class="timeline-card">
                            <h4 class="fw-bold">Bước 3: Xử Lý</h4>
                            <p class="text-muted mb-0">
                                Kỹ thuật viên liên hệ trực tiếp, kiểm tra lỗi và tiến hành sửa
                                chữa đúng SLA cam kết.
                            </p>
                        </div>
                    </div>

                    <!-- Step 4 -->
                    <div class="col-lg-3 col-md-6 col-12 text-center timeline-step">
                        <div class="timeline-icon-wrapper">
                            <div class="timeline-icon">
                                <i class="fa-solid fa-circle-check"></i>
                            </div>
                            <span class="step-number">04</span>
                        </div>
                        <div class="timeline-card">
                            <h4 class="fw-bold">Bước 4: Hoàn Tất</h4>
                            <p class="text-muted mb-0">
                                Nghiệm thu kết quả hoạt động, đóng phiếu và ghi nhận ý kiến đánh
                                giá từ khách hàng.
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 7. DANH MỤC DỊCH VỤ -->
    <section id="serviceGridSection">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8 col-md-10">
                    <span class="text-danger fw-bold text-uppercase d-block mb-2">Hỗ Trợ Đa Nền Tảng</span>
                    <h2 class="section-title center">Danh Mục Hỗ Trợ Kỹ Thuật</h2>
                    <p class="subtitle">
                        Đội ngũ kỹ sư sẵn sàng hỗ trợ giải quyết sự cố trên tất cả các dịch vụ số
                        Viettel.
                    </p>
                </div>
            </div>

            <div class="category-grid text-start reveal">
                @if (categories != null && categories.Any())
                {
                    @foreach (var category in categories)
                    {
                        <article class="grid-card-item" style="display: flex;">
                            <div class="card-icon-box">
                                <i class="bi bi-grid-fill" aria-hidden="true"></i>
                            </div>
                            <h3>@category.TenDanhMuc</h3>
                            <p>@(category.MoTa ?? "Chưa có mô tả chi tiết cho danh mục hỗ trợ này.")</p>
                            <div class="card-stats">
                                <i class="bi bi-ticket-detailed-fill" aria-hidden="true"></i>
                                <span>Trạng thái: @category.TrangThai</span>
                            </div>
                            <a asp-controller="Ticket" asp-action="TaoPhieu" asp-route-categoryId="@category.IdDanhMuc" class="btn-card-action">
                                Tạo phiếu hỗ trợ <i class="bi bi-arrow-right" aria-hidden="true"></i>
                            </a>
                        </article>
                    }
                }
                else
                {
                    <div class="col-12 text-center py-5">
                        <p class="text-muted">Không có danh mục hỗ trợ nào được cấu hình trong hệ thống.</p>
                    </div>
                }
            </div>
        </div>
    </section>

    <!-- 8. STATISTICS SECTION -->
    <section class="stats-section">
        <div class="stats-bg-pattern"></div>
        <div class="container">
            <div class="row g-4 justify-content-center">
                <!-- Stat 1 -->
                <div class="col-lg-3 col-6 text-center">
                    <div class="stat-box">
                        <div class="stat-icon"><i class="bi bi-ticket-detailed-fill"></i></div>
                        <div class="stat-number"><span class="counter-value" data-target="10000">0</span>+</div>
                        <div class="stat-title">Phiếu hỗ trợ đã đóng</div>
                    </div>
                </div>
                <!-- Stat 2 -->
                <div class="col-lg-3 col-6 text-center">
                    <div class="stat-box">
                        <div class="stat-icon"><i class="bi bi-person-fill-check"></i></div>
                        <div class="stat-number"><span class="counter-value" data-target="5000">0</span>+</div>
                        <div class="stat-title">Khách hàng tin cậy</div>
                    </div>
                </div>
                <!-- Stat 3 -->
                <div class="col-lg-3 col-6 text-center">
                    <div class="stat-box">
                        <div class="stat-icon"><i class="bi bi-microsoft-teams"></i></div>
                        <div class="stat-number"><span class="counter-value" data-target="500">0</span>+</div>
                        <div class="stat-title">Nhân viên kỹ thuật</div>
                    </div>
                </div>
                <!-- Stat 4 -->
                <div class="col-lg-3 col-6 text-center">
                    <div class="stat-box">
                        <div class="stat-icon"><i class="bi bi-patch-check-fill"></i></div>
                        <div class="stat-number">24/7</div>
                        <div class="stat-title">Hỗ trợ thường trực</div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 9. CUSTOMER FEEDBACK -->
    <section class="testimonial-section" id="feedbackSection">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8 col-md-10">
                    <span class="text-danger fw-bold text-uppercase d-block mb-2">Phản Hồi Thực Tế</span>
                    <h2 class="section-title center">Đánh Giá Từ Khách Hàng</h2>
                    <p class="subtitle">Động lực to lớn để chúng tôi cải thiện chất lượng dịch vụ vận hành mỗi ngày.</p>
                </div>
            </div>

            <div class="testimonial-wrapper reveal">
                <div id="testimonialCarousel" class="carousel slide testimonial-carousel" data-bs-ride="carousel"
                     data-bs-interval="5000">

                    <!-- Indicators -->
                    <div class="carousel-indicators">
                        <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="0" class="active"
                                aria-current="true" aria-label="Slide 1"></button>
                        <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="1"
                                aria-label="Slide 2"></button>
                        <button type="button" data-bs-target="#testimonialCarousel" data-bs-slide-to="2"
                                aria-label="Slide 3"></button>
                    </div>

                    <!-- Slides -->
                    <div class="carousel-inner">
                        <!-- Slide 1 -->
                        <div class="carousel-item active">
                            <div class="testimonial-card">
                                <div class="avatar-wrapper">
                                    <svg width="90" height="90" viewBox="0 0 100 100" class="testimonial-avatar"
                                         aria-hidden="true">
                                        <circle cx="50" cy="50" r="46" fill="#f3f4f6" stroke="#ee0033"
                                                stroke-width="3" />
                                        <path d="M50 30 A18 18 0 0 1 50 66 A18 18 0 0 1 50 30" fill="#6b7280" />
                                        <path d="M22 84 C22 70, 34 68, 50 68 C66 68, 78 70, 78 84" fill="#6b7280" />
                                    </svg>
                                </div>
                                <p class="testimonial-quote">
                                    "Tôi rất ấn tượng với tốc độ phản hồi của hệ thống

                                    thoại dễ dùng. Tôi có thể theo dõi vị trí kỹ thuật viên đang di chuyển tới nhà mình
                                    trên bản đồ và cập nhật thời gian xử lý sự cố camera thực tế."
                                </p>
                                <div class="testimonial-info">
                                    <h5>Võ Thị Mai Phương</h5>
                                    <p>Quản lý Chuỗi Cửa Hàng - TP. Đà Nẵng</p>
                                </div>
                                <div class="testimonial-rating">
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Slide 3 -->
                        <div class="carousel-item">
                            <div class="testimonial-card">
                                <div class="avatar-wrapper">
                                    <svg width="90" height="90" viewBox="0 0 100 100" class="testimonial-avatar"
                                         aria-hidden="true">
                                        <circle cx="50" cy="50" r="46" fill="#f3f4f6" stroke="#ee0033"
                                                stroke-width="3" />
                                        <path d="M50 30 A18 18 0 0 1 50 66 A18 18 0 0 1 50 30" fill="#4b5563" />
                                        <path d="M22 84 C22 70, 34 68, 50 68 C66 68, 78 70, 78 84" fill="#4b5563" />
                                    </svg>
                                </div>
                                <p class="testimonial-quote">
                                    "Chất lượng hỗ trợ server cực kỳ chuyên nghiệp. Đội ngũ kỹ
                                    sư hệ thống làm việc có trách nhiệm, giải thích sự cố rõ ràng và tư vấn cho công ty
                                    chúng tôi phương án dự phòng tốt hơn. Rất cám ơn Viettel!"
                                </p>
                                <div class="testimonial-info">
                                    <h5>Lâm Minh Hoàng</h5>
                                    <p>Trưởng bộ phận IT - Tổng công ty Bán lẻ</p>
                                </div>
                                <div class="testimonial-rating">
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                    <i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

    <!-- 10. NEWS SECTION -->
    <section id="newsSection">
        <div class="container">
            <div class="row justify-content-center text-center">
                <div class="col-lg-8 col-md-10">
                    <span class="text-danger fw-bold text-uppercase d-block mb-2">Cẩm Nang Kỹ Thuật</span>
                    <h2 class="section-title center">Hướng Dẫn & Mẹo Tự Xử Lý</h2>
                    <p class="subtitle">
                        Tham khảo các cẩm nang hữu ích để giải quyết nhanh sự cố mạng hoặc thiết bị tại
                        chỗ.
                    </p>
                </div>
            </div>

            <div class="row g-4 reveal">
                <!-- News 1 -->
                <div class="col-lg-4 col-md-6 col-12">
                    <div class="news-card">
                        <div class="news-thumb-wrapper">
                            <img src="~/assets/images/news_1_6g.png" alt="Hướng dẫn sử dụng TechSupport"
                                 class="news-thumb" loading="lazy">
                            <span class="news-date">29 Tháng 5, 2026</span>
                        </div>
                        <div class="news-card-body">
                            <div class="news-category">Hướng dẫn</div>
                            <h3 class="news-title">
                                <a href="#">
                                    Hướng dẫn chi tiết quy trình tạo và theo dõi phiếu hỗ trợ trên hệ thống
                                    TechSupport
                                </a>
                            </h3>
                            <p class="news-desc">
                                Tìm hiểu cách đính kèm ảnh lỗi, viết mô tả và tương tác trực tiếp với
                                đội ngũ kỹ sư xử lý để rút ngắn thời gian.
                            </p>
                            <a href="#"
                               class="text-danger fw-bold text-decoration-none d-inline-flex align-items-center">
                                Xem
                                thêm <i class="fa-solid fa-chevron-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- News 2 -->
                <div class="col-lg-4 col-md-6 col-12">
                    <div class="news-card">
                        <div class="news-thumb-wrapper">
                            <img src="~/assets/images/news_2_smarthome.png" alt="Thông báo bảo trì hệ thống"
                                 class="news-thumb" loading="lazy">
                            <span class="news-date">25 Tháng 5, 2026</span>
                        </div>
                        <div class="news-card-body">
                            <div class="news-category">Thông báo</div>
                            <h3 class="news-title">
                                <a href="#">
                                    Thông báo lịch bảo trì định kỳ hệ thống máy chủ tổng đài kỹ thuật tháng
                                    06/2026
                                </a>
                            </h3>
                            <p class="news-desc">
                                Lịch bảo trì nâng cấp hạ tầng Cloud Server nhằm tăng gấp đôi tốc độ tải
                                trang và chịu tải dữ liệu của hệ thống ticket.
                            </p>
                            <a href="#"
                               class="text-danger fw-bold text-decoration-none d-inline-flex align-items-center">
                                Xem
                                thêm <i class="fa-solid fa-chevron-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>

                <!-- News 3 -->
                <div class="col-lg-4 col-md-6 col-12 d-md-none d-lg-block">
                    <div class="news-card">
                        <div class="news-thumb-wrapper">
                            <img src="~/assets/images/news_3_upgrade.png" alt="Mẹo xử lý sự cố mạng" class="news-thumb"
                                 loading="lazy">
                            <span class="news-date">18 Tháng 5, 2026</span>
                        </div>
                        <div class="news-card-body">
                            <div class="news-category">Kinh nghiệm</div>
                            <h3 class="news-title">
                                <a href="#">5 mẹo xử lý nhanh sự cố mạng chập chờn hoặc rớt kết nối Wifi tại nhà</a>
                            </h3>
                            <p class="news-desc">
                                Hướng dẫn khởi động lại modem, đặt lại kênh truyền sóng nhiễu và thiết
                                lập vị trí thiết bị phát chuẩn kỹ thuật số.
                            </p>
                            <a href="#"
                               class="text-danger fw-bold text-decoration-none d-inline-flex align-items-center">
                                Xem
                                thêm <i class="fa-solid fa-chevron-right ms-2"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- 11. CTA SECTION -->
    <section class="cta-section py-8 text-center text-white reveal">
        <div class="cta-bg-glow"></div>
        <div class="container relative-z">
            <h2 class="fw-bold mb-3">Cần Hỗ Trợ Kỹ Thuật Ngay Hôm Nay?</h2>
            <p class="mb-4 text-white-50 max-w-600 mx-auto">
                Đội ngũ kỹ thuật viên thường trực 24/7 của chúng tôi đã sẵn
                sàng hỗ trợ bạn khắc phục mọi sự cố phần cứng, phần mềm và mạng di động.
            </p>
            <div class="d-flex flex-wrap justify-content-center gap-3">
                <a asp-controller="Ticket" asp-action="TaoPhieu"
                   class="btn btn-light rounded-pill px-4 py-3 fw-bold text-danger btn-ripple">Tạo Phiếu Hỗ Trợ</a>
                <a asp-controller="Customers" asp-action="LienHe" class="btn btn-outline-light rounded-pill px-4 py-3 fw-bold btn-ripple">
                    <i class="bi bi-telephone-outbound me-2"></i> Liên Hệ Kỹ Thuật Viên
                </a>
            </div>
        </div>
    </section>

    <!-- 12. FOOTER -->
    <partial name="~/Views/Shared/_Footer.cshtml" />
    }
    else
    {
        <main class="main-content" style="min-height: calc(100vh - 200px); padding-top: 80px;">
            @RenderBody()
        </main>
    }

    <!-- Scroll Top Button -->
    <button class="scroll-top-btn" aria-label="Cuộn về đầu trang">
        <i class="bi bi-arrow-up-short"></i>
    </button>

    <!-- AI Chatbox Widget -->
    @await Html.PartialAsync("_ChatBox")

    <!-- Bootstrap 5.3 JS Bundle (includes Popper) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

    <!-- Component-Based JS -->
    <script src="~/assets/js/header.js?v=2.6.0"></script>
    <script src="~/assets/js/sidebar.js?v=2.6.0"></script>
    <script src="~/assets/js/footer.js?v=2.6.0"></script>
    <script src="~/assets/js/chatbox.js" asp-append-version="true"></script>
    <script src="~/assets/js/chat-message.js" asp-append-version="true"></script>
    <script src="~/assets/js/main.js?v=2.6.0"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>