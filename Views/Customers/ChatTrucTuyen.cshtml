@model SupportTicketSysterm.ViewModels.LiveSupportViewModel
@{
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
    ViewData["Title"] = "Trò Chuyện Trực Tuyến - TechSupport Viettel";
}

@section Styles {
    <link rel="stylesheet" href="~/css/live-support.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/assets/css/live-support.css" asp-append-version="true" />
}

<!-- ==================== HERO SECTION ==================== -->
<section class="live-support-hero">
    <div class="container">
        <div class="row align-items-center g-4">
            <div class="col-lg-7 col-12 hero-text-pane animate-fade-up">
                <nav aria-label="breadcrumb" class="hero-breadcrumb-nav mb-2">
                    <ol class="breadcrumb mb-1">
                        <li class="breadcrumb-item"><a href="/"><i class="fa-solid fa-house-door-fill me-1"></i> Trang chủ</a></li>
                        <li class="breadcrumb-item"><a asp-controller="Customers" asp-action="PhieuCuaToi">Hỗ trợ kỹ thuật</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Live Support</li>
                    </ol>
                </nav>

                <div class="hero-status-pill mb-2">
                    <span class="status-indicator-dot"></span>
                    <span>Online 24/7/365</span>
                </div>

                <h1 class="hero-title">TRÒ CHUYỆN TRỰC TUYẾN<br>VỚI NHÂN VIÊN HỖ TRỢ</h1>
                
                <p class="hero-desc mt-2">
                    Kết nối trực tiếp với kỹ thuật viên Viettel để xử lý sự cố kỹ thuật theo thời gian thực và theo dõi tiến độ phiếu.
                </p>

                <div class="hero-tags mt-3 d-flex flex-wrap gap-2">
                    <span class="hero-tag"><i class="bi bi-clock-fill"></i> 24/7</span>
                    <span class="hero-tag"><i class="bi bi-patch-check-fill text-success"></i> Online</span>
                    <span class="hero-tag"><i class="bi bi-people-fill"></i> Kỹ thuật viên</span>
                    <span class="hero-tag"><i class="bi bi-lightning-charge-fill"></i> Phản hồi nhanh</span>
                </div>
            </div>

            <div class="col-lg-5 col-12 hero-visual-pane text-center animate-fade-up delay-1 d-none d-lg-block">
                <div class="visual-container">
                    <div class="glass-illustration-card">
                        <div class="card-inner">
                            <div class="floating-bubble bubble-left">
                                <span class="bubble-icon"><i class="fa-solid fa-headset text-danger"></i></span>
                                <span>Hỗ trợ 24/7</span>
                            </div>
                            <div class="floating-bubble bubble-right">
                                <span class="bubble-icon"><i class="fa-solid fa-shield-halved text-success"></i></span>
                                <span>Bảo mật SLA</span>
                            </div>
                            <div class="main-device-mockup shadow-lg border border-secondary border-opacity-25" style="background:#1E293B; border-radius:20px; padding:12px;">
                                <div class="screen-header d-flex gap-1.5 mb-2">
                                    <span class="window-dot red" style="width:8px; height:8px; background:#EF4444; border-radius:50%;"></span>
                                    <span class="window-dot yellow" style="width:8px; height:8px; background:#F59E0B; border-radius:50%;"></span>
                                    <span class="window-dot green" style="width:8px; height:8px; background:#10B981; border-radius:50%;"></span>
                                </div>
                                <div class="screen-body bg-white rounded-3 p-3 d-flex flex-column justify-content-between" style="height:175px;">
                                    <div class="d-flex align-items-center gap-2 pb-2 border-bottom">
                                        <div class="rounded-circle bg-danger text-white d-grid place-items-center fw-bold small" style="width:28px; height:28px; font-size:0.7rem;">VT</div>
                                        <div class="text-start">
                                            <div class="fw-bold text-dark" style="font-size:0.72rem;">Kỹ thuật viên Viettel</div>
                                            <div class="text-success fw-semibold" style="font-size:0.62rem;">🟢 Đang trực tuyến</div>
                                        </div>
                                    </div>
                                    <div class="mini-chat-stream d-flex flex-column gap-1.5 my-1">
                                        <div class="p-1.5 bg-light rounded-3 text-start small text-dark" style="font-size:0.68rem; max-width:85%;">
                                            Xin chào, Kỹ thuật Viettel sẵn sàng hỗ trợ!
                                        </div>
                                        <div class="p-1.5 bg-danger text-white rounded-3 text-end small align-self-end" style="font-size:0.68rem; max-width:85%;">
                                            Cần hỗ trợ kiểm tra đường truyền
                                        </div>
                                    </div>
                                    <div class="p-1 bg-light rounded-pill d-flex align-items-center justify-content-between px-2" style="font-size:0.65rem; color:#94A3B8;">
                                        <span>Nhập nội dung...</span>
                                        <i class="bi bi-send-fill text-danger"></i>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==================== MAIN WORKSPACE AREA ==================== -->
<section class="live-chat-workspace">
    <div class="container">
        <div class="live-chat-container shadow-lg">
            <div class="row g-0 w-100 h-100 position-relative">
                <!-- LEFT COLUMN: SIDEBAR / INFO (30%) -->
                <div class="col-lg-4 col-12 chat-sidebar-pane order-lg-1 order-2" id="staffSidebar">
                    @await Html.PartialAsync("~/Views/LiveSupport/_InfoPanel.cshtml", Model)
                </div>

                <!-- RIGHT COLUMN: CHAT WINDOW (70%) -->
                <div class="col-lg-8 col-12 chat-main-pane d-flex flex-column order-lg-2 order-1">
                    @await Html.PartialAsync("~/Views/LiveSupport/_Header.cshtml", Model)
                    @await Html.PartialAsync("~/Views/LiveSupport/_MessageList.cshtml", Model)
                    @await Html.PartialAsync("~/Views/LiveSupport/_Footer.cshtml", Model)
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ==================== MODALS ==================== -->
@await Html.PartialAsync("~/Views/LiveSupport/_ModalTicket.cshtml", Model)
@await Html.PartialAsync("~/Views/LiveSupport/_ModalAppointment.cshtml", Model)

<!-- Lightbox Zoom Image Modal -->
<div class="chat-lightbox" id="chatLightboxModal">
    <button class="lightbox-close" id="lightboxClose" aria-label="Đóng">&times;</button>
    <img src="" alt="Zoomed view" class="lightbox-content" id="lightboxImg" />
</div>

<script>
    window.chatConfig = {
        maPhieu: '@Model.Ticket.MaPhieu',
        role: '@Model.CurrentUserRole',
        canChat: @(Model.CanChat ? "true" : "false"),
        ticketStatus: '@Model.Ticket.TrangThai',
        staffId: '@(Model.Staff?.IdNhanVien)',
        staffName: '@(Model.Staff?.HoTen ?? "Kỹ thuật viên Viettel")',
        staffRole: '@(Model.Staff?.VaiTro ?? "Kỹ sư Băng rộng")',
        staffPhone: '@(Model.Staff?.SoDienThoai ?? "1800 8119")',
        staffEmail: '@(Model.Staff?.Email ?? "support@viettel.com.vn")',
        staffAddress: '@(Model.Staff?.DiaChi ?? "Hà Nội")',
        staffStatus: '@(Model.Staff?.TrangThai ?? "Hoạt động")'
    };
</script>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.7/signalr.min.js"></script>
    <script src="~/js/live-support.js" asp-append-version="true"></script>
}
