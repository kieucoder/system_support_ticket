@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@{
    Layout = "~/Views/Shared/_LayoutMain.cshtml";
    ViewData["Title"] = "Trang Chủ Khách Hàng";
    var hoTen = Context.Session?.GetString("HoTen") ?? User.FindFirstValue("HoTen") ?? User.Identity?.Name ?? "Quý khách";
}

@section Styles {
    <!-- Custom Styles for Customer Dashboard -->
    <link rel="stylesheet" href="~/assets/css/customer-home.css" />
}

<div class="container pb-5">
  

    <!-- Quick Actions -->
    <h3 class="fw-bold text-dark mb-4">Lối tắt nhanh</h3>
    <div class="row g-4 mb-5">
        <!-- Card 1: Gửi Phiếu -->
        <div class="col-md-4">
            <a href="#guiYeuCauSection" class="quick-card">
                <div class="icon-wrapper">
                    <i class="bi bi-file-earmark-plus"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Gửi Yêu Cầu Hỗ Trợ</h5>
                <p class="text-muted mb-0 small">Gửi mô tả lỗi kỹ thuật internet, camera, cloud để kỹ thuật viên tiếp nhận nhanh chóng.</p>
            </a>
        </div>
        <!-- Card 2: Tra Cứu Phiếu -->
        <div class="col-md-4">
            <a href="#quickActionSection" class="quick-card">
                <div class="icon-wrapper">
                    <i class="bi bi-search"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Tra Cứu Lịch Sử Phiếu</h5>
                <p class="text-muted mb-0 small">Theo dõi tiến độ xử lý sự cố realtime từ đội ngũ kỹ thuật Viettel Telecom.</p>
            </a>
        </div>
        <!-- Card 3: Thông Tin -->
        <div class="col-md-4">
            <a asp-controller="Customers" asp-action="ThongTinCaNhan" class="quick-card">
                <div class="icon-wrapper">
                    <i class="bi bi-person-gear"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">Thông Tin Tài Khoản</h5>
                <p class="text-muted mb-0 small">Quản lý hồ sơ cá nhân, đổi mật khẩu, và cập nhật thông tin liên hệ khẩn cấp.</p>
            </a>
        </div>
    </div>

    <!-- Simulated Active Service Health Check -->
    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 20px;">
        <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
            <div>
                <h4 class="fw-bold text-dark mb-1">Trạng thái dịch vụ của bạn</h4>
                <p class="text-muted small mb-0">Hệ thống đo lường tự động từ hạ tầng kỹ thuật</p>
            </div>
            <span class="service-badge bg-success-subtle text-success">Đang hoạt động ổn định</span>
        </div>
        <hr class="text-muted opacity-25">
        <div class="row g-3 text-center">
            <div class="col-6 col-md-3">
                <p class="text-muted small mb-1">Gói dịch vụ</p>
                <p class="fw-bold text-dark mb-0">Viettel Fast 150</p>
            </div>
            <div class="col-6 col-md-3">
                <p class="text-muted small mb-1">Tốc độ đo được</p>
                <p class="fw-bold text-success mb-0"><i class="bi bi-arrow-down-short"></i> 148.6 Mbps</p>
            </div>
            <div class="col-6 col-md-3">
                <p class="text-muted small mb-1">IP tĩnh</p>
                <p class="fw-bold text-dark mb-0">115.79.132.84</p>
            </div>
            <div class="col-6 col-md-3">
                <p class="text-muted small mb-1">Ping</p>
                <p class="fw-bold text-dark mb-0">4 ms</p>
            </div>
        </div>
    </div>
</div>