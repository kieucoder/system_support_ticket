@using Microsoft.AspNetCore.Http
@using System.Security.Claims
@model SupportTicketSysterm.Models.KhachHangViewModel
@{
    Layout = null;
}
@functions {
    public string GetStatusClass(string? status) {
        if (string.IsNullOrEmpty(status)) return "badge-status-pending";
        var s = status.ToLower();
        if (s.Contains("hoàn thành")) return "badge-status-completed";
        if (s.Contains("đang xử lý") || s.Contains("xử lý")) return "badge-status-processing";
        if (s.Contains("hủy")) return "badge-status-cancelled";
        return "badge-status-pending";
    }

    public string GetPriorityText(int? priority) {
        if (priority == 1) return "Cao";
        if (priority == 2) return "Trung bình";
        return "Thấp";
    }

    public string GetPriorityClass(int? priority) {
        if (priority == 1) return "priority-high";
        if (priority == 2) return "priority-medium";
        return "priority-low";
    }

    public bool IsAppointmentActive(string? status) {
        if (string.IsNullOrEmpty(status)) return false;
        var s = status.ToLower();
        return s.Contains("chờ") || s.Contains("đang") || s.Contains("active");
    }
}
