                                bạn
                            </span>
                        </div>
                        <div class="form-group-item">
                            <label for="editPhone" class="custom-form-label">
                                Số điện thoại liên hệ <span class="text-required">*</span>
                            </label>
                            <input type="tel" class="custom-form-input" id="editPhone"
                                   placeholder="Nhập số điện thoại..." required>
                            <span class="form-validation-error-msg" id="editPhoneError">
                                Vui lòng nhập số
                                điện thoại hợp
                                lệ (10 số, bắt đầu bằng số 0)
                            </span>
                        </div>
                    </div>
                    <div class="form-row-grid">
                        <div class="form-group-item">
                            <label for="editEmail" class="custom-form-label">Email tài khoản</label>
                            <input type="email" class="custom-form-input" id="editEmail"
                                   placeholder="Nhập địa chỉ email...">
                            <span class="form-validation-error-msg" id="editEmailError">
                                Địa chỉ email không
                                đúng định
                                dạng
                            </span>
                        </div>
                        @* <div class="form-group-item">
                            <label for="editIdentity" class="custom-form-label">
                                Số CMND/CCCD <span class="text-required">*</span>
                            </label>
                            <input type="text" class="custom-form-input" id="editIdentity"
                                   placeholder="Nhập số CMND hoặc CCCD..." required>
                            <span class="form-validation-error-msg" id="editIdentityError">
                                Vui lòng nhập
                                CMND/CCCD hợp
                                lệ (9 hoặc 12 số)
                            </span>
                        </div> *@
                    </div>
                    <div class="form-group-item">
                        <label for="editAddress" class="custom-form-label">
                            Địa chỉ lắp đặt / Liên hệ <span class="text-required">*</span>
                        </label>
                        <textarea class="custom-form-textarea" id="editAddress" rows="3"
                                  placeholder="Nhập địa chỉ đầy đủ (số nhà, tên đường, phường/xã, quận/huyện)..."
                                  required></textarea>
                        <span class="form-validation-error-msg" id="editAddressError">
                            Vui lòng nhập địa chỉ
                            lắp đặt hoặc
                            liên hệ
                        </span>
                    </div>
                    <div class="modal-footer-actions">
                        <button type="button" class="btn-modal-action btn-cancel" data-close-modal>
                            Hủy
                            bỏ
                        </button>
                        <button type="submit" class="btn-modal-action btn-submit btn-viettel-red">
                            <i class="bi bi-save"></i> Lưu thay đổi
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Modal Đổi Mật Khẩu -->
    <div class="profile-custom-modal" id="changePasswordModal" role="dialog" aria-modal="true"
         aria-labelledby="changePasswordModalTitle">
        <div class="modal-dialog-card">
            <div class="modal-header">
                <h3 class="modal-title-text" id="changePasswordModalTitle">
                    <i class="fa-solid fa-shield text-danger"></i> Thay Đổi Mật Khẩu
                </h3>
                <button type="button" class="btn-modal-close" aria-label="Close" data-close-modal>
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="changePasswordForm" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group-item">
                        <label for="currentPassword" class="custom-form-label">
                            Mật khẩu hiện tại <span class="text-required">*</span>
                        </label>

                        <div class="password-input-wrapper">
                            <input type="password"
                                   class="custom-form-input"
                                   id="currentPassword"
                                   name="MatKhauCu"
                                   required />

                            <button type="button"
                                    class="btn-password-visibility-toggle"
                                    data-toggle-password="currentPassword">
                                <i class="bi bi-eye-slash"></i>
                            </button>
                        </div>

                        <span class="form-validation-error-msg"
                              id="currentPasswordError"></span>
                    </div>

                    <div class="form-group-item">
                        <label class="custom-form-label">
                            Mật khẩu mới
                        </label>

                        <div class="password-input-wrapper">

                            <input type="password"
                                   class="custom-form-input"
                                   id="newPassword"
                                   name="MatKhauMoi"
                                   required />

                            <button type="button"
                                    class="btn-password-visibility-toggle"
                                    data-toggle-password="newPassword">
                                <i class="bi bi-eye-slash"></i>
                            </button>

                        </div>

                        <span class="form-validation-error-msg"
                              id="newPasswordError"></span>

                    </div>

                    <div class="form-group-item">

                        <label class="custom-form-label">
                            Xác nhận mật khẩu
                        </label>

                        <div class="password-input-wrapper">

                            <input type="password"
                                   class="custom-form-input"
                                   id="confirmPassword"
                                   name="XacNhanMatKhau"
                                   required />

                            <button type="button"
                                    class="btn-password-visibility-toggle"
                                    data-toggle-password="confirmPassword">
                                <i class="bi bi-eye-slash"></i>
                            </button>

                        </div>

                        <span class="form-validation-error-msg"
                              id="confirmPasswordError"></span>

                    </div>

                    <div class="modal-footer-actions">

                        <button type="button"
                                class="btn-modal-action btn-cancel"
                                data-close-modal>
                            Hủy bỏ
                        </button>

                        <button type="submit"
                                class="btn-modal-action btn-submit btn-viettel-red">

                            <i class="bi bi-key"></i>
                            Xác nhận đổi mật khẩu

                        </button>

                    </div>

                </form>
            </div>
        </div>
    </div>

    <!-- Modal Chi Tiết Phiếu Hỗ Trợ -->
    <div class="profile-custom-modal" id="ticketDetailModal" role="dialog" aria-modal="true"
         aria-labelledby="ticketDetailModalTitle">
        <div class="modal-dialog-card">
            <div class="modal-header">
                <h3 class="modal-title-text" id="ticketDetailModalTitle">
                    <i class="bi bi-ticket-detailed-fill text-danger"></i> Chi Tiết Phiếu Hỗ Trợ
                </h3>
                <button type="button" class="btn-modal-close" aria-label="Close" data-close-modal>
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <div class="row g-4">
                    <!-- Ticket Details Column -->
                    <div class="col-md-7">
                        <h4 class="modal-inner-title mb-3">Thông tin chi tiết</h4>
                        <div class="ticket-detail-fields">
                            <div class="detail-row">
                                <span class="detail-label">Mã phiếu:</span>
                                <span class="detail-value highlight" id="modalTicketCode">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Dịch vụ:</span>
                                <span class="detail-value" id="modalTicketService">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Loại sự cố:</span>
                                <span class="detail-value" id="modalTicketCategory">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Mức độ ưu tiên:</span>
                                <span class="detail-value" id="modalTicketPriority">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Ngày tạo:</span>
                                <span class="detail-value" id="modalTicketDate">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Trạng thái:</span>
                                <span class="detail-value" id="modalTicketStatus">-</span>
                            </div>
                            <div class="detail-row">
                                <span class="detail-label">Nhân viên phụ trách:</span>
                                <span class="detail-value" id="modalTicketStaff">-</span>
                            </div>
                            <div class="detail-row full-width">
                                <span class="detail-label">Mô tả sự cố:</span>
                                <p class="detail-desc-text" id="modalTicketDesc">-</p>
                            </div>
                            <div class="detail-row full-width">
                                <span class="detail-label">Ghi chú xử lý của kỹ thuật viên:</span>
                                <p class="detail-notes-text" id="modalTicketNotes">-</p>
                            </div>
                        </div>
                    </div>
                    <!-- Ticket Timeline Column -->
                    <div class="col-md-5">
                        <h4 class="modal-inner-title mb-3">Tiến độ xử lý</h4>
                        <div class="modal-timeline" id="modalTicketTimeline">
                            <!-- Timeline steps dynamically loaded based on ticket status -->
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer-actions">
                <button type="button" class="btn-modal-action btn-cancel" data-close-modal>Đóng</button>
            </div>
        </div>
    </div>

    <!-- Modal Đổi Lịch Hẹn -->
    <div class="profile-custom-modal" id="rescheduleModal" role="dialog" aria-modal="true"
         aria-labelledby="rescheduleModalTitle">
        <div class="modal-dialog-card">
            <div class="modal-header">
                <h3 class="modal-title-text" id="rescheduleModalTitle">
                    <i class="bi bi-calendar2-week-fill text-danger"></i> Yêu Cầu Thay Đổi Lịch Hẹn
                </h3>
                <button type="button" class="btn-modal-close" aria-label="Close" data-close-modal>
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="rescheduleForm">
                    <input type="hidden" id="rescheduleAppointmentId">
                    <div class="form-group-item mb-3">
                        <label class="custom-form-label">Lịch hẹn hiện tại</label>
                        <input type="text" class="custom-form-input" id="rescheduleCurrentDetails" readonly>
                    </div>
                    <div class="form-row-grid">
                        <div class="form-group-item">
                            <label for="rescheduleNewDate" class="custom-form-label">
                                Chọn ngày mới <span class="text-required">*</span>
                            </label>
                            <input type="date" class="custom-form-input" id="rescheduleNewDate" required>
                        </div>
                        <div class="form-group-item">
                            <label for="rescheduleNewTime" class="custom-form-label">
                                Chọn khung giờ mới
                                <span class="text-required">*</span>
                            </label>
                            <select class="custom-form-input" id="rescheduleNewTime" required>
                                <option value="08:00 - 10:30">Sáng: 08:00 - 10:30</option>
                                <option value="09:00 - 11:30">Sáng: 09:00 - 11:30</option>
                                <option value="14:00 - 16:30">Chiều: 14:00 - 16:30</option>
                                <option value="15:30 - 18:00">Chiều: 15:30 - 18:00</option>
                            </select>
                        </div>
                    </div>
                    <div class="form-group-item mt-3">
                        <label for="rescheduleReason" class="custom-form-label">Lý do thay đổi</label>
                        <textarea class="custom-form-textarea" id="rescheduleReason" rows="3"
                                  placeholder="Vui lòng nhập lý do bạn muốn đổi lịch hẹn..."></textarea>
                    </div>
                    <div class="modal-footer-actions">
                        <button type="button" class="btn-modal-action btn-cancel" data-close-modal>
                            Hủy
                            bỏ
                        </button>
