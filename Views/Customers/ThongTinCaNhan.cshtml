                        <h3 class="stat-value counter-value" id="statTotalTickets" data-target="@Model.TongSoPhieu">@Model.TongSoPhieu</h3>
                    </div>
                </div>
                <div class="stat-card reveal animate-fade-up">
                    <div class="stat-icon-wrapper yellow">
                        <i class="bi bi-clock-history"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Chờ tiếp nhận</span>
                        <h3 class="stat-value counter-value" id="statPendingTickets" data-target="@Model.SoPhieuChoTiepNhan">@Model.SoPhieuChoTiepNhan</h3>
                    </div>
                </div>
                <div class="stat-card reveal animate-fade-up">
                    <div class="stat-icon-wrapper orange">
                        <i class="bi bi-tools"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Đang xử lý</span>
                        <h3 class="stat-value counter-value" id="statProcessingTickets" data-target="@Model.SoPhieuDangXuLy">@Model.SoPhieuDangXuLy</h3>
                    </div>
                </div>
                <div class="stat-card reveal animate-fade-up">
                    <div class="stat-icon-wrapper green">
                        <i class="fa-solid fa-circle-check"></i>
                    </div>
                    <div class="stat-info">
                        <span class="stat-label">Hoàn thành</span>
                        <h3 class="stat-value counter-value" id="statCompletedTickets" data-target="@Model.SoPhieuHoanThanh">@Model.SoPhieuHoanThanh</h3>
                    </div>
                </div>
            </section>

            <!-- Profile Content Grid (Left Card & Right Details) -->
            <div class="profile-layout-grid">

                <!-- Left Column: Avatar & Sidebar Navigation -->
                <aside class="profile-sidebar-col">
