                                   id="menuLinkProfile">
                                    <i class="bi bi-person-fill"></i> Thông tin cá nhân
                                </a>
                            </li>
                            <li class="sidebar-nav-item">
                                <a href="#my-appointments" class="sidebar-nav-link"
                                   id="btnEditProfileInline">
                                    <i class=" bi bi-calendar2-week-fill"></i> Chỉnh sửa
                                </a>
                            </li>
                            <li class="sidebar-nav-item">
                                <a href="#my-tickets" class="sidebar-nav-link" id="menuLinkTickets">
                                    <i class="bi bi-ticket-detailed-fill"></i> Phiếu hỗ trợ
                                </a>
                            </li>
                            <li class="sidebar-nav-item">
                                <a href="#my-appointments" class="sidebar-nav-link"
                                   id="menuLinkAppointments">
                                    <i class="bi bi-calendar2-week-fill"></i> Lịch hẹn
                                </a>
                            </li>
                            <li class="sidebar-nav-item">
                                <a href="#service-review-section" class="sidebar-nav-link"
                                   id="menuLinkReview">
                                    <i class="fa-solid fa-star"></i> Đánh giá
                                </a>
                            </li>
                            <li class="sidebar-nav-item">
                                <a asp-controller="Customers" class="sidebar-nav-link" id="menuLinkChangePassword">
                                    <i class="fa-solid fa-shield"></i> Đổi mật khẩu
                                </a>
                            </li>
                            <li class="sidebar-nav-item border-top mt-2 pt-2">
                                <a asp-controller="Auth" asp-action="DangXuat" class="sidebar-nav-link text-danger" id="menuLinkLogout">
                                    <i class="fa-solid fa-right-from-bracket"></i> Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </div>
                </aside>
                <!-- Right Column: Profile Detailed Form -->
                <article class="profile-content-col" id="personalInfoSection"
                         style="scroll-margin-top: 140px;">
                    <div class="profile-details-card">

                        <form id="inlineProfileForm" class="mt-3" novalidate>
                            @Html.AntiForgeryToken()
                            <div class="profile-fields-grid">
                                <div class="profile-field-item">
                                    <label for="profileUserCode" class="field-label">Mã khách hàng</label>
                                    <input type="text" class="profile-form-input highlight"
                                           id="profileUserCode" value="@Model.MaKh" readonly>
                                </div>
                                <div class="profile-field-item">
                                    <label for="profileFullname" class="field-label">
                                        Họ và tên <span class="text-required">*</span>
                                    </label>
                                    <input type="text" class="profile-form-input" id="profileFullname"
                                           value="@Model.HoTen" readonly required>
                                    <span class="form-validation-error-msg" id="profileFullnameError">
                                        Vui
                                        lòng nhập họ
                                        và tên
                                    </span>
                                </div>
                                <div class="profile-field-item">
                                    <label for="profilePhone" class="field-label">
                                        Số điện thoại đăng ký
                                        <span class="text-required">*</span>
                                    </label>
                                    <input type="tel" class="profile-form-input" id="profilePhone"
                                           value="@Model.SoDienThoai" readonly required>
                                    <span class="form-validation-error-msg" id="profilePhoneError">
                                        Số điện
                                        thoại không
                                        hợp lệ (10 số)
                                    </span>
                                </div>
                                <div class="profile-field-item">
                                    <label for="profileEmail" class="field-label">
                                        Địa chỉ Email <span class="text-required">*</span>
                                    </label>
                                    <input type="email" class="profile-form-input" id="profileEmail"
                                           value="@Model.Email" readonly required>
                                    <span class="form-validation-error-msg" id="profileEmailError">
                                        Email
                                        không đúng định
                                        dạng
                                    </span>
                                </div>
                                <div class="profile-field-item">
                                    <label for="profileIdentity" class="field-label">
                                        Số CMND/CCCD
                                    </label>
                                    <input type="text" class="profile-form-input" id="profileIdentity"
                                           value="Chưa cập nhật" readonly>
                                </div>
                                <div class="profile-field-item full-width">
                                    <label for="profileAddress" class="field-label">
                                        Địa chỉ lắp đặt / Liên hệ
                                    </label>
                                    <input type="text" class="profile-form-input" id="profileAddress"
                                           value="@(Model.DiaChi ?? "Chưa cập nhật")" readonly>
                                </div>
                                <div class="profile-field-item full-width">
                                    <label for="profileJoinDate" class="field-label">
                                        Ngày đăng ký thành viên
                                    </label>
                                    <input type="text" class="profile-form-input" id="profileJoinDate"
                                           value="@(Model.NgayTao?.ToString("dd/MM/yyyy") ?? "--")" readonly>
                                </div>

                            </div>
                            <!-- Inline edit action buttons (hidden by default) -->
                            <div class="inline-edit-actions mt-3 d-none">
                                <button type="button" class="btn btn-secondary px-4 py-2 me-2"
                                        id="btnCancelEditInline">
                                    Hủy bỏ
                                </button>
                                <button type="submit" class="btn btn-hero-create px-4 py-2"
                                        id="btnSaveProfileInline">
                                    <i class="bi bi-save"></i> Lưu thay
                                    đổi
                                </button>
                            </div>
                        </form>
                    </div>
                </article>
            </div>

            <!-- Bottom Sections: Recent Tickets & Appointments Timeline -->
            <div class="profile-sections-grid mt-4">

                <!-- Recent Support Tickets Section -->
                <section class="recent-tickets-card" id="my-tickets" style="scroll-margin-top: 140px;">
                    <div class="section-card-header flex-wrap gap-3">
                        <div class="header-left">
                            <h2 class="card-section-title">
                                <i class="bi bi-ticket-detailed-fill text-danger"></i> Phiếu
                                hỗ trợ của tôi
                            </h2>
                            <p class="section-card-subtitle">
                                Theo dõi các phiếu yêu cầu sửa chữa, lắp đặt và
                                hỗ trợ kỹ
                                thuật.
                            </p>
                        </div>
                        <div class="header-actions-toolbelt d-flex align-items-center gap-2 flex-wrap w-100 mt-2">
                            <div class="search-box-wrapper flex-grow-1">
                                <i class="fa-solid fa-search search-icon"></i>
                                <input type="text" class="custom-form-input ps-5" id="ticketSearchInput"
                                       placeholder="Tìm kiếm mã phiếu hoặc nội dung sự cố...">
                            </div>
                            <div class="filter-dropdown-wrapper">
                                <select class="custom-form-input" id="ticketStatusFilter">
                                    <option value="all">Tất cả trạng thái</option>
                                    <option value="pending">Chờ tiếp nhận</option>
                                    <option value="processing">Đang xử lý</option>
                                    <option value="completed">Đã hoàn thành</option>
                                    <option value="cancelled">Đã hủy</option>
                                </select>
                            </div>
                            <button class="btn btn-hero-create px-4 py-2" id="btnSearchTickets">
                                <i class="bi bi-funnel-fill"></i> Lọc
                            </button>
                            <a href="create-ticket.html"
                               class="btn btn-create-ticket-custom btn-ripple px-4 py-2"
                               style="white-space: nowrap;">
                                <i class="bi bi-plus-circle-fill"></i> Tạo phiếu mới
                            </a>
                        </div>
                    </div>

                    <div class="table-responsive-wrapper mt-3">
                        <table class="tickets-data-table">
                            <thead>
                                <tr>
                                    <th>STT</th>
                                    <th>Mã phiếu</th>
                                    <th>Dịch vụ</th>
                                    <th>Loại sự cố</th>
                                    <th>Ngày tạo</th>
                                    <th>Trạng thái</th>
                                    <th>Mức ưu tiên</th>
                                    <th>Thao tác</th>
                                </tr>
                            </thead>
                            <tbody id="ticketsTableBody">
                                @if (Model.DanhSachPhieu == null || !Model.DanhSachPhieu.Any())
                                {
                                    <tr>
                                        <td colspan="8" class="table-empty-state">
                                            <i class="fa-solid fa-ticket"></i>
                                            <p>Không có phiếu hỗ trợ nào.</p>
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    int stt = 1;
                                    foreach (var phieu in Model.DanhSachPhieu)
                                    {
                                        <tr data-ticket-code="@phieu.MaPhieu" data-ticket-status="@GetStatusClass(phieu.TrangThai)">
                                            <td>@(stt++)</td>
                                            <td><span class="ticket-code-badge">@phieu.MaPhieu</span></td>
                                            <td>@(phieu.IdDichVuNavigation?.TenDichVu ?? "--")</td>
                                            <td>@phieu.LoaiYeuCau</td>
                                            <td>@(phieu.NgayTao?.ToString("dd/MM/yyyy") ?? "--")</td>
                                            <td>
                                                <span class="status-badge @GetStatusClass(phieu.TrangThai)">
                                                    @(phieu.TrangThai ?? "Chờ tiếp nhận")
                                                </span>
                                            </td>
                                            <td>
                                                <span class="priority-badge @GetPriorityClass(phieu.MucDoUuTien)">
                                                    @GetPriorityText(phieu.MucDoUuTien)
                                                </span>
                                            </td>
                                            <td>
                                                <button type="button" class="btn-table-action btn-view-ticket"
                                                        data-ticket-id="@phieu.IdPhieu"
                                                        title="Xem chi tiết">
                                                    <i class="bi bi-eye-fill"></i>
                                                </button>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    @if (Model.TongSoPhieu > 0)
                    {
                        <div class="table-pagination" id="ticketsPagination">
                            <span class="pagination-info">Tổng: @Model.TongSoPhieu phiếu hỗ trợ</span>
                        </div>
                    }

                </section>

                <!-- Upcoming Appointments Section -->
                <section class="appointments-card" id="my-appointments" style="scroll-margin-top: 140px;">
                    <div class="section-card-header">
                        <h2 class="card-section-title">
                            <i class="bi bi-calendar2-week-fill text-danger"></i>
                            Lịch hẹn hỗ
                            trợ
                        </h2>
                        <p class="section-card-subtitle">
                            Kế hoạch khảo sát và sửa chữa của kỹ thuật viên tại
                            nhà.
                        </p>
                    </div>

                    <div class="appointments-timeline" id="appointmentsTimeline">
                        @if (Model.DanhSachLichHen == null || !Model.DanhSachLichHen.Any())
                        {
                            <div class="timeline-empty-state">
                                <i class="bi bi-calendar-check"></i>
                                <p>Không có lịch hẹn hỗ trợ nào.</p>
                            </div>
                        }
                        else
                        {
                            foreach (var lichHen in Model.DanhSachLichHen)
                            {
                                bool isActive = IsAppointmentActive(lichHen.TrangThai);
                                <div class="timeline-item @(isActive ? "active" : "")">
                                    <div class="timeline-marker"></div>
                                    <div class="timeline-content">
                                        <div class="timeline-header d-flex flex-wrap gap-2 align-items-center mb-1">
                                            <span class="timeline-date">
                                                <i class="bi bi-calendar2-event-fill me-1"></i>
                                                @(lichHen.NgayHen?.ToString("dd/MM/yyyy") ?? "--")
                                            </span>
                                            <span class="timeline-time">
                                                <i class="bi bi-clock me-1"></i>
                                                @if (lichHen.GioBatDau.HasValue)
                                                {
                                                    @lichHen.GioBatDau.Value.ToString("HH:mm")
                                                }
                                                @if (lichHen.GioKetThuc.HasValue)
                                                {
                                                    <text> - @lichHen.GioKetThuc.Value.ToString("HH:mm")</text>
                                                }
                                            </span>
                                            <span class="status-badge @GetStatusClass(lichHen.TrangThai)">
                                                @(lichHen.TrangThai ?? "Chờ xử lý")
                                            </span>
                                        </div>
                                        <h4 class="timeline-title mb-1">
                                            @(lichHen.IdPhieuNavigation?.TieuDe ?? lichHen.GhiChu ?? "Hẹn hỗ trợ kỹ thuật")
                                        </h4>
                                        @if (!string.IsNullOrWhiteSpace(lichHen.GhiChu))
                                        {
                                            <p class="timeline-desc text-muted small mb-1">@lichHen.GhiChu</p>
                                        }
                                        <div class="timeline-staff-info">
                                            <i class="bi bi-person-badge-fill text-danger me-1"></i>
                                            <strong>KTV:</strong>
                                            @if (lichHen.IdNhanVienNavigation != null)
                                            {
                                                <span class="ms-1">@lichHen.IdNhanVienNavigation.HoTen</span>
                                                @if (!string.IsNullOrEmpty(lichHen.IdNhanVienNavigation.SoDienThoai))
                                                {
                                                    <span class="ms-2 text-muted small">
                                                        <i class="bi bi-telephone-fill me-1"></i>@lichHen.IdNhanVienNavigation.SoDienThoai
                                                    </span>
                                                }
                                            }
                                            else
                                            {
                                                <span class="ms-1 text-muted">Chưa phân công</span>
                                            }
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(lichHen.DiaChiHoTro))
                                        {
                                            <div class="mt-1 small">
                                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>@lichHen.DiaChiHoTro
                                            </div>
                                        }
                                    </div>
                                </div>
                            }
                        }
                    </div>

                </section>

                <!-- Service Review Section -->
                <section class="service-review-card mt-4" id="service-review-section"
                         style="scroll-margin-top: 140px;">
                    <div class="section-card-header">
                        <h2 class="card-section-title">
                            <i class="fa-solid fa-star text-danger"></i> Đánh giá
                            dịch vụ
                        </h2>
                        <p class="section-card-subtitle">
                            Ý kiến của bạn giúp chúng tôi cải thiện chất lượng
                            phục vụ ngày
                            càng tốt hơn.
                        </p>
                    </div>
                    <div class="review-body mt-3">
                        <form id="serviceReviewForm">
                            <div class="rating-stars-wrapper mb-3 d-flex align-items-center gap-3">
                                <span class="rating-stars-label fw-bold">Chất lượng hỗ trợ:</span>
                                <div class="star-rating" id="starRating">
                                    <span class="star-item" data-rating="1">
                                        <i class="fa-regular fa-star"></i>
                                    </span>
                                    <span class="star-item" data-rating="2">
                                        <i class="fa-regular fa-star"></i>
                                    </span>
                                    <span class="star-item" data-rating="3">
                                        <i class="fa-regular fa-star"></i>
                                    </span>
                                    <span class="star-item" data-rating="4">
                                        <i class="fa-regular fa-star"></i>
                                    </span>
                                    <span class="star-item" data-rating="5">
                                        <i class="fa-regular fa-star"></i>
                                    </span>
                                </div>
                                <input type="hidden" name="ratingValue" id="ratingValue" value="0">
                            </div>
                            <div class="form-group-item mb-3">
                                <label for="reviewFeedback" class="custom-form-label fw-bold">
                                    Ý kiến đóng
                                    góp
                                </label>
                                <textarea class="custom-form-textarea" id="reviewFeedback" rows="4"
                                          placeholder="Nhập cảm nhận của bạn về chất lượng phục vụ kỹ thuật của TechSupport..."></textarea>
                            </div>
                            <button type="submit" class="btn btn-hero-create px-4 py-2"
                                    id="btnSubmitReview">
                                <i class="fa-solid fa-paper-plane me-1"></i> Gửi đánh giá
                            </button>
                        </form>
                    </div>
                </section>

            </div>

        </div>
    </main>

    <!-- FOOTER COMPONENT CONTAINER -->
    <div id="footer-container"></div>

    <!-- CHATBOX WIDGET CONTAINER -->
    <div id="chatbox-container"></div>


    <!-- ==================== MODALS ==================== -->
    <!-- Backdrop Overlay -->
    <div class="modal-backdrop-overlay" id="modalBackdropOverlay"></div>

    <!-- Modal Cập Nhật Thông Tin -->
    <div class="profile-custom-modal" id="editProfileModal" role="dialog" aria-modal="true"
         aria-labelledby="editProfileModalTitle">
        <div class="modal-dialog-card">
            <div class="modal-header">
                <h3 class="modal-title-text" id="editProfileModalTitle">
                    <i class="bi bi-person-fill-gear text-danger"></i> Cập Nhật Thông Tin Cá Nhân
                </h3>
                <button type="button" class="btn-modal-close" aria-label="Close" data-close-modal>
                    <i class="fa-solid fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="editProfileForm" novalidate>
                    @Html.AntiForgeryToken()
                    <div class="form-row-grid">
                        <div class="form-group-item">
                            <label for="editFullname" class="custom-form-label">
                                Họ và tên <span class="text-required">*</span>
                            </label>
                            <input type="text" class="custom-form-input" id="editFullname"
                                   placeholder="Nhập họ và tên..." required>
                            <span class="form-validation-error-msg" id="editFullnameError">
                                Vui lòng nhập họ
