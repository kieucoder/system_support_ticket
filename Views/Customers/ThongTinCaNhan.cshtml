                            <i class="bi bi-gem text-danger"></i> Khách hàng VIP
                        </p> *@
                        <p class="profile-joined-date">
                            <i class="bi bi-clock"></i> Thành viên từ: <span id="sidebarUserJoinDate">@(Model.NgayTao?.ToString("dd/MM/yyyy"))</span>
                        </p>

                        <ul class="sidebar-nav-menu">
                            <li class="sidebar-nav-item">
