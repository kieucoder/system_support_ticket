          content="Trang cá nhân khách hàng TechSupport Viettel Telecom. Quản lý thông tin tài khoản, theo dõi phiếu hỗ trợ kỹ thuật và lịch hẹn hỗ trợ kỹ thuật trực tuyến.">
    <meta name="keywords"
          content="trang cá nhân viettel, quản lý phiếu hỗ trợ, lịch hẹn viettel, sửa mạng viettel, techsupport">
    <meta name="author" content="Viettel Telecom TechSupport">
    <meta name="robots" content="noindex, nofollow">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font Awesome 6.6.0 CDN (Enterprise) -->
    <link rel="stylesheet" id="fa-cdn-link"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <!-- FontAwesome Fallback Script -->
    <script>
        document.getElementById('fa-cdn-link').addEventListener('error', function () {
            document.documentElement.classList.add('fa-fallback-active');
            console.warn("FontAwesome failed to load. Falling back to Bootstrap Icons.");
        });
        window.addEventListener('load', function () {
            setTimeout(function () {
                if (!document.fonts.check('12px "Font Awesome 6 Free"')) {
                    document.documentElement.classList.add('fa-fallback-active');
                }
            }, 1200);
        });
    </script>

    <!-- Google Fonts Inter & Poppins -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Poppins:wght@300;400;500;600;700;800&display=swap"
          rel="stylesheet">

    <!-- Core Stylesheets -->
    <link rel="stylesheet" href="~/assets/css/style.css">
    <link rel="stylesheet" href="~/assets/css/responsive.css">
    <link rel="stylesheet" href="~/assets/css/header.css">
    <link rel="stylesheet" href="~/assets/css/sidebar.css">
    <link rel="stylesheet" href="~/assets/css/footer.css">
    <link rel="stylesheet" href="~/assets/css/chatbox.css">

    <!-- Custom Page CSS (Pure Vanilla CSS Layout) -->
    <link rel="stylesheet" href="~/assets/css/customer-profile.css">

    <!-- ASP.NET Core Validation Helper Styles -->
    <style>
        .field-validation-error {
            display: block !important;
            color: #dc3545;
            font-size: 0.75rem;
            margin-top: 0.35rem;
            font-weight: 600;
        }
        .custom-form-input.input-validation-error {
            border-color: #dc3545 !important;
            background-color: #fffafb !important;
        }
    </style>
</head>

