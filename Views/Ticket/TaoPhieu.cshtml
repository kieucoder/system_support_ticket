@{
    ViewData["Title"] = "Tạo phiếu hỗ trợ";
    Layout = null;
}

@model SupportTicketSysterm.Models.PhieuViewModel

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Tạo Phiếu Hỗ Trợ Kỹ Thuật - TechSupport Viettel</title>

    <!-- SEO Optimization -->
    <meta name="description"
        content="Gửi yêu cầu hỗ trợ kỹ thuật nhanh chóng cho đội ngũ hỗ trợ TechSupport Viettel. Chúng tôi tiếp nhận và xử lý sự cố mạng, Internet, Camera 24/7.">
    <meta name="keywords"
        content="tạo phiếu hỗ trợ, báo lỗi viettel, hỗ trợ kỹ thuật viettel, sự cố wifi, lắp đặt mạng viettel">
    <meta name="author" content="Viettel Telecom TechSupport">
    <meta name="robots" content="index, follow">

    <!-- Open Graph Data -->
    <meta property="og:title" content="Tạo Phiếu Hỗ Trợ Kỹ Thuật - TechSupport Viettel">
    <meta property="og:description"
        content="Gửi yêu cầu trực tiếp cho kỹ thuật viên Viettel. Nhận phản hồi tức thì và tiến độ xử lý sự cố trực tuyến.">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://techsupport.viettel.vn/pages/create-category.html">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font Awesome 6.6.0 CDN (Enterprise) -->
    <link rel="stylesheet" id="fa-cdn-link" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <!-- FontAwesome Fallback Script -->
    <script>
        document.getElementById('fa-cdn-link').addEventListener('error', function() {
            document.documentElement.classList.add('fa-fallback-active');
            console.warn("FontAwesome failed to load. Falling back to Bootstrap Icons.");
        });
        window.addEventListener('load', function() {
            setTimeout(function() {
                if (!document.fonts.check('12px "Font Awesome 6 Free"')) {
                    document.documentElement.classList.add('fa-fallback-active');
                }
            }, 1200);
        });
    </script>

    <!-- Google Fonts Inter & Roboto -->
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Roboto:wght@300;400;500;700;900&display=swap"
        rel="stylesheet">

    <!-- SweetAlert2 CSS CDN -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2/theme-bootstrap-4/bootstrap-4.min.css" rel="stylesheet">

    <!-- Flatpickr CSS CDN -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <!-- Component-Based CSS -->
    <link rel="stylesheet" href="~/assets/css/style.css">
    <link rel="stylesheet" href="~/assets/css/responsive.css">
    <link rel="stylesheet" href="~/assets/css/header.css">
    <link rel="stylesheet" href="~/assets/css/sidebar.css">
    <link rel="stylesheet" href="~/assets/css/footer.css">
    <link rel="stylesheet" href="~/assets/css/chatbox.css">
    <link rel="stylesheet" href="~/assets/css/create-category.css">
</head>

<body>

    <!-- Header Component Container -->
    @await Html.PartialAsync("~/Views/Shared/_Header.cshtml", Context.Session)

    <!-- Sidebar Component Container -->
    @await Html.PartialAsync("~/Views/Shared/_Sidebar.cshtml", Context.Session)


    <!-- HERO SECTION -->
    <section class="hero-section">
        <div class="container hero-content">
            <div class="row align-items-center g-5">
                <div class="col-lg-7 col-12 text-start hero-text-col animate-fade-up">
                    <!-- Breadcrumb Navigation -->
                    <nav aria-label="breadcrumb" class="hero-breadcrumb">
                        <ol class="breadcrumb m-0" itemscope itemtype="https://schema.org/BreadcrumbList">
                            <li class="breadcrumb-item" itemprop="itemListElement" itemscope
                                itemtype="https://schema.org/ListItem">
                                <a href="../index.html" itemprop="item"
                                    class="text-decoration-none d-inline-flex align-items-center">
                                    <i class="fa-solid fa-house-door-fill me-1"></i>
                                    <span itemprop="name">Trang chủ</span>
                                </a>
                                <meta itemprop="position" content="1" />
                            </li>
                            <li class="breadcrumb-item" itemprop="itemListElement" itemscope
                                itemtype="https://schema.org/ListItem">
                                <a href="../index.html#serviceGridSection" itemprop="item"
                                    class="text-decoration-none d-inline-flex align-items-center">
                                    <span itemprop="name">Hỗ trợ kỹ thuật</span>
                                </a>
                                <meta itemprop="position" content="2" />
                            </li>
                            <li class="breadcrumb-item active" itemprop="itemListElement" itemscope
                                itemtype="https://schema.org/ListItem" aria-current="page">
                                <span itemprop="name">Tạo phiếu hỗ trợ</span>
                                <meta itemprop="position" content="3" />
                            </li>
                        </ol>
                    </nav>

                    <!-- Badge -->
                    <span class="hero-badge">
                        <i class="bi bi-shield-check me-1"></i> Hệ thống hỗ trợ kỹ thuật 24/7
                    </span>

                    <!-- Title -->
                    <h1 class="hero-title text-uppercase">Tạo Phiếu Hỗ Trợ Kỹ Thuật</h1>

                    <!-- Description -->
                    <p class="hero-desc">
                        Gửi yêu cầu hỗ trợ nhanh chóng cho đội ngũ kỹ thuật Viettel. Chúng tôi sẽ tiếp nhận và xử lý
                        trong thời gian sớm nhất.
                    </p>

                    <!-- CTA Buttons -->
                    <div class="hero-cta-buttons d-flex flex-wrap gap-3 mt-4">
                        <a href="#ticketFormSection" class="btn btn-hero-create px-4 py-2">
                            <i class="bi bi-plus-circle me-1"></i> Tạo Phiếu
                        </a>
                        <a href="contact.html" class="btn btn-hero-contact px-4 py-2">
                            <i class="bi bi-telephone me-1"></i> Liên Hệ Kỹ Thuật
                        </a>
                    </div>
                </div>

                <div class="col-lg-5 col-12 hero-banner-wrapper animate-fade-up delay-1">
                    <!-- Tech illustration representing helpdesk ticket creation -->
                    <svg class="hero-banner-svg" viewBox="0 0 500 400" xmlns="http://www.w3.org/2000/svg"
                        aria-label="Tech Support Ticket Creation Illustration">
                        <defs>
                            <linearGradient id="svgGradRed" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#ee0033" />
                                <stop offset="100%" stop-color="#ff4d6d" />
                            </linearGradient>
                            <linearGradient id="svgGradDarkGray" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#1f2937" />
                                <stop offset="100%" stop-color="#111827" />
                            </linearGradient>
                        </defs>
                        <!-- Shapes & Decorative Glow -->
                        <circle cx="250" cy="200" r="160" fill="url(#svgGradRed)" opacity="0.05" />
                        <rect x="360" y="50" width="80" height="80" rx="16" fill="url(#svgGradRed)" opacity="0.08"
                            transform="rotate(15 400 90)" />

                        <!-- Main Dashboard Ticket Form Representation -->
                        <rect x="80" y="60" width="340" height="280" rx="24" fill="#ffffff"
                            stroke="rgba(15, 17, 21, 0.05)" stroke-width="2"
                            filter="drop-shadow(0 20px 40px rgba(0,0,0,0.06))" />
                        <!-- Header bar -->
                        <path
                            d="M80 84 C80 70.74, 90.74 60, 104 60 L396 60 C409.26 60, 420 70.74, 420 84 L420 100 L80 100 Z"
                            fill="url(#svgGradDarkGray)" />
                        <!-- Window buttons -->
                        <circle cx="105" cy="80" r="5" fill="#ee0033" />
                        <circle cx="120" cy="80" r="5" fill="#eab308" />
                        <circle cx="135" cy="80" r="5" fill="#10b981" />
                        <rect x="160" y="74" width="180" height="12" rx="6" fill="rgba(255,255,255,0.15)" />

                        <!-- Inside form items simulation -->
                        <!-- Input 1 Title -->
                        <rect x="110" y="130" width="100" height="10" rx="3" fill="#ee0033" opacity="0.8" />
                        <rect x="110" y="148" width="280" height="32" rx="8" fill="#f8fafc" stroke="#e2e8f0"
                            stroke-width="1.5" />
                        <circle cx="130" cy="164" r="6" fill="#cbd5e1" />
                        <rect x="146" y="160" width="120" height="8" rx="4" fill="#94a3b8" />

                        <!-- Input 2 Checkbox -->
                        <rect x="110" y="200" width="20" height="20" rx="6" fill="url(#svgGradRed)" />
                        <path d="M115 210 L119 214 L125 206" stroke="#ffffff" stroke-width="2" fill="none"
                            stroke-linecap="round" />
                        <rect x="140" y="206" width="180" height="8" rx="4" fill="#475569" />

                        <!-- Input 3 Textarea -->
                        <rect x="110" y="240" width="280" height="50" rx="8" fill="#f8fafc" stroke="#e2e8f0"
                            stroke-width="1.5" />
                        <rect x="126" y="252" width="248" height="6" rx="3" fill="#cbd5e1" />
                        <rect x="126" y="264" width="200" height="6" rx="3" fill="#cbd5e1" opacity="0.7" />

                        <!-- Floating Support Ticket Badge -->
                        <g class="floating-avatar-card" transform="translate(320, 240)">
                            <rect x="0" y="0" width="130" height="80" rx="16" fill="url(#svgGradRed)"
                                filter="drop-shadow(0 8px 16px rgba(238, 0, 51, 0.2))" />
                            <circle cx="35" cy="40" r="18" fill="rgba(255,255,255,0.2)" />
                            <!-- Plus icon inside circle -->
                            <path d="M35 33 L35 47 M28 40 L42 40" stroke="#ffffff" stroke-width="3"
                                stroke-linecap="round" />
                            <rect x="65" y="30" width="45" height="6" rx="3" fill="#ffffff" />
                            <rect x="65" y="42" width="30" height="5" rx="2.5" fill="#ffffff" opacity="0.7" />
                        </g>
                    </svg>
                </div>
            </div>
        </div>
    </section>

    <!-- Main Content Section -->
    <main id="ticketFormSection" class="py-5" style="background-color: var(--viettel-gray-light);">
        <div class="container">
            <div class="row g-4 align-items-stretch">

                <!-- 1. LEFT COLUMN: TICKET FORM (8 Cols) -->
                <div class="col-lg-8 col-12">
                    <div id="createTicketFormCard" class="ticket-main-card">

                        <div class="card-header-custom">
                            <i class="fa-solid fa-file-signature text-danger fs-3 me-2"></i>
                            <h2 class="contact-card-title m-0 d-inline-block">Thông Tin Phiếu Hỗ Trợ</h2>
                        </div>

                        <!-- ASP.NET Core Form -->
                        <form id="supportTicketForm" asp-action="TaoPhieu" asp-controller="Ticket" method="post" enctype="multipart/form-data" class="needs-validation mt-4" novalidate>
                            <input type="hidden" asp-for="HoTen" />
                            <input type="hidden" asp-for="SoDienThoai" />
                            <input type="hidden" asp-for="Email" />

                            @if (!ViewData.ModelState.IsValid)
                            {
                                <div class="alert alert-danger alert-dismissible fade show mb-4 border-0 shadow-sm" role="alert" style="background-color: #fff1f2; border-left: 4px solid #ee0033 !important;">
                                    <div class="d-flex align-items-center mb-2">
                                        <i class="fa-solid fa-triangle-exclamation text-danger fs-5 me-2"></i>
                                        <h5 class="m-0 fw-bold text-danger fs-6">Đã xảy ra lỗi vui lòng kiểm tra lại:</h5>
                                    </div>
                                    <ul class="mb-0 text-dark fs-7 ps-3">
                                        @foreach (var modelState in ViewData.ModelState.Values)
                                        {
                                            foreach (var error in modelState.Errors)
                                            {
                                                <li>@error.ErrorMessage</li>
                                            }
                                        }
                                    </ul>
                                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                </div>
                            }

                            <!-- [Thông tin khách hàng] -->
                            <div class="customer-info-section mb-4 p-4 border rounded bg-light">
                                <h4 class="fs-6 fw-bold text-dark mb-3">
                                    <i class="fa-solid fa-user text-danger me-2"></i>Thông tin khách hàng
                                </h4>
                                <div class="row g-3">
                                    <div class="col-md-4 col-12">
                                        <div class="d-flex flex-column">
                                            <span class="text-muted fs-7 small uppercase fw-bold mb-1">Họ tên</span>
                                            <input type="text" class="form-control-plaintext text-dark fw-bold" readonly value="@Model.HoTen">
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-12">
                                        <div class="d-flex flex-column">
                                            <span class="text-muted fs-7 small uppercase fw-bold mb-1">Số điện
                                                thoại</span>
                                            <input type="text" class="form-control-plaintext text-dark fw-bold" readonly value="@Model.SoDienThoai">
                                        </div>
                                    </div>
                                    <div class="col-md-4 col-12">
                                        <div class="d-flex flex-column">
                                            <span class="text-muted fs-7 small uppercase fw-bold mb-1">Email</span>
                                            <input type="text" class="form-control-plaintext text-dark fw-bold" readonly value="@Model.Email">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- [Thông tin yêu cầu hỗ trợ] -->
                            <h4 class="fs-6 fw-bold text-dark mb-3 mt-4 border-top pt-4">
                                <i class="fa-solid fa-file-invoice text-danger me-2"></i>Thông tin yêu cầu hỗ trợ
                            </h4>

                            <div class="row g-3">

                                <!-- Mã Phiếu (Auto-generated Readonly) -->
                                <div class="col-md-6 col-12">
                                    <label for="ticketCode" class="form-label-custom">Mã Phiếu Hỗ Trợ</label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i
                                                class="bi bi-hashtag text-muted"></i></span>
                                        <input type="text"
                                            class="form-control form-control-custom border-start-0 ps-0 text-dark font-monospace fw-bold"
                                            asp-for="MaPhieu" id="ticketCode" readonly>
                                    </div>
                                    <div class="form-text text-muted">Mã số định danh duy nhất của phiếu hỗ trợ.</div>
                                </div>

                                <!-- Tiêu Đề Sự Cố (Required Text Input) -->
                                <div class="col-md-6 col-12">
                                    <label for="ticketTitle" class="form-label-custom">Tiêu đề sự cố
                                        <span>*</span></label>
                                    <div class="input-group">
                                        <span class="input-group-text bg-light border-end-0"><i
                                                class="bi bi-pen text-muted"></i></span>
                                        <input type="text"
                                            class="form-control form-control-custom border-start-0 ps-0 text-dark"
                                            asp-for="TieuDe" id="ticketTitle" placeholder="Nhập tiêu đề sự cố hoặc yêu cầu hỗ trợ"
                                            required>
                                    </div>
                                    <span asp-validation-for="TieuDe" class="invalid-feedback">Vui lòng cung cấp tiêu đề mô tả ngắn gọn sự cố.</span>
                                </div>

                                <!-- Danh mục dịch vụ (Dropdown from SQL Server) -->
                                <div class="col-md-6 col-12">
                                    <label asp-for="IdDanhMuc" class="form-label-custom">Danh mục dịch vụ <span>*</span></label>
                                    <select asp-for="IdDanhMuc" class="form-select form-control-custom" id="IdDanhMuc" required>
                                        <option value="">Chọn danh mục dịch vụ...</option>
                                        @if (ViewBag.DanhMucs != null)
                                        {
                                            @foreach (var dm in ViewBag.DanhMucs)
                                            {
                                                <option value="@dm.IdDanhMuc">@dm.TenDanhMuc</option>
                                            }
                                        }
                                    </select>
                                    <span asp-validation-for="IdDichVuNavigation.IdDanhMuc" class="invalid-feedback">Vui lòng chọn danh mục dịch vụ.</span>
                                </div>




                                <!-- Dịch vụ (Dropdown loaded via AJAX) -->
                                <div class="col-md-6 col-12">
                                    <label asp-for="IdDichVu" class="form-label-custom">Dịch vụ <span>*</span></label>
                                    <select asp-for="IdDichVu" class="form-select form-control-custom" id="IdDichVu" required disabled>
                                        <option value="">Chọn danh mục trước...</option>
                                    </select>
                                    <span asp-validation-for="IdDichVu" class="invalid-feedback">Vui lòng chọn dịch vụ.</span>
                                </div>

                                <!-- Loại yêu cầu -->
                                <div class="col-12 mt-4">
                                    <label asp-for="LoaiYeuCau" class="form-label-custom">Loại yêu cầu <span>*</span></label>
                                    <select asp-for="LoaiYeuCau" class="form-select form-control-custom" required>
                                        <option value="">-- Chọn loại yêu cầu --</option>
                                        <option value="Báo lỗi">Báo lỗi</option>
                                        <option value="Sửa chữa">Sửa chữa</option>
                                        <option value="Lắp đặt mới">Lắp đặt mới</option>
                                        <option value="Bảo trì">Bảo trì</option>
                                        <option value="Nâng cấp dịch vụ">Nâng cấp dịch vụ</option>
                                        <option value="Hỗ trợ kỹ thuật">Hỗ trợ kỹ thuật</option>
                                        <option value="Tư vấn dịch vụ">Tư vấn dịch vụ</option>
                                        <option value="Khiếu nại">Khiếu nại</option>
                                    </select>
                                    <span asp-validation-for="LoaiYeuCau" class="invalid-feedback">Vui lòng chọn loại yêu cầu hỗ trợ.</span>
                                </div>
                                <div class="col-12 mt-4">
                                    <!-- Selected option description area -->
                                    <div class="selected-desc-wrapper d-none mt-3 animate-slide-down"
                                        id="loaiYeuCauSelectedDesc">
                                        <div class="selected-desc-content p-3 rounded">
                                            <i class="fa-solid fa-circle-info text-danger me-2"></i>
                                            <span class="desc-text"></span>
                                        </div>
                                    </div>
                                </div>


                                <!-- Mức Độ Ưu Tiên -->
                                <div class="col-12 mt-4">
                                    <label asp-for="MucDoUuTien" class="form-label-custom mb-3">Mức độ ưu tiên <span>*</span></label>
                                    <div class="row g-2">
                                        <!-- Thấp -->
                                        <div class="col-6 col-md-3">
                                            <input type="radio" asp-for="MucDoUuTien" value="1" id="priorityLow" class="d-none">
                                            <label class="priority-card-label low" for="priorityLow">
                                                <div class="priority-icon text-success">
                                                    <i class="bi bi-arrow-down-circle-fill"></i>
                                                </div>
                                                <div class="priority-title">Thấp</div>
                                            </label>
                                        </div>
                                        <!-- Trung Bình -->
                                        <div class="col-6 col-md-3">
                                            <input type="radio" asp-for="MucDoUuTien" value="2" id="priorityMedium" class="d-none" checked>
                                            <label class="priority-card-label medium" for="priorityMedium">
                                                <div class="priority-icon text-warning">
                                                    <i class="bi bi-dash-circle-fill"></i>
                                                </div>
                                                <div class="priority-title">Trung Bình</div>
                                            </label>
                                        </div>
                                        <!-- Cao -->
                                        <div class="col-6 col-md-3">
                                            <input type="radio" asp-for="MucDoUuTien" value="3" id="priorityHigh" class="d-none">
                                            <label class="priority-card-label high" for="priorityHigh">
                                                <div class="priority-icon text-danger">
                                                    <i class="bi bi-lightning-charge-fill"></i>
                                                </div>
                                                <div class="priority-title">Cao</div>
                                            </label>
                                        </div>
                                        <!-- Khẩn Cấp -->
                                        <div class="col-6 col-md-3">
                                            <input type="radio" asp-for="MucDoUuTien" value="4" id="priorityUrgent" class="d-none">
                                            <label class="priority-card-label urgent" for="priorityUrgent">
                                                <div class="priority-icon text-danger">
                                                    <i class="bi bi-exclamation-triangle-fill pulse-danger"></i>
                                                </div>
                                                <div class="priority-title">Khẩn Cấp</div>
                                            </label>
                                        </div>
                                    </div>
                                    <span asp-validation-for="MucDoUuTien" class="invalid-feedback">Vui lòng chọn mức độ ưu tiên.</span>
                                </div>

                                <!-- Mô tả chi tiết sự cố -->
                                <div class="col-12 mt-4">
                                    <label asp-for="NoiDung" class="form-label-custom">Mô tả chi tiết sự cố
                                        <span>*</span></label>
                                    <textarea asp-for="NoiDung" class="form-control form-control-custom"
                                        placeholder="Mô tả chi tiết sự cố hoặc yêu cầu hỗ trợ của bạn (ví dụ: mất kết nối từ lúc mấy giờ, tín hiệu đèn nháy màu gì...)"
                                        required rows="5"></textarea>
                                    <span asp-validation-for="NoiDung" class="invalid-feedback">Vui lòng nhập nội dung mô tả chi tiết yêu cầu hỗ trợ.</span>
                                </div>

                                <!-- Drag & Drop File Upload Area -->
                                <div class="col-12 mt-4">
                                    <label class="form-label-custom mb-2">Tệp Đính Kèm (Ảnh chụp sự cố, tài liệu PDF,
                                        DOCX)</label>
                                    <div class="upload-area" id="dragDropArea">
                                        <div class="upload-area-icon">
                                            <i class="bi bi-cloud-arrow-up"></i>
                                        </div>
                                        <p class="upload-area-text">Kéo thả tệp tin sự cố tại đây hoặc <span>chọn
                                                tệp</span></p>
                                        <p class="upload-area-hint">Định dạng hỗ trợ: JPG, PNG, PDF, DOCX. Kích thước
                                            tối đa: 5MB/file.</p>
                                        <input type="file" name="Files" id="ticketFileInput" class="d-none" multiple
                                            accept="image/png, image/jpeg, application/pdf, application/vnd.openxmlformats-officedocument.wordprocessingml.document">
                                    </div>

                                    <!-- File Preview Grid Container -->
                                    <div class="upload-preview-grid d-none" id="filePreviewGrid"></div>
                                </div>

                                <!-- Có cần lịch hẹn? -->
                                <div class="col-12 mt-4">
