    <!-- AJAX for loading services by category -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const idDanhMucSelect = document.getElementById('IdDanhMuc');
            const idDichVuSelect = document.getElementById('IdDichVu');

            if (idDanhMucSelect && idDichVuSelect) {
                const initialCatId = idDanhMucSelect.value || '@(Model?.IdDanhMuc ?? 0)';
                const initialServiceId = '@(Model?.IdDichVu ?? 0)';

                function loadServicesForCategory(idDanhMuc, selectedServiceId) {
                    if (idDanhMuc && idDanhMuc !== '0') {
                        idDichVuSelect.disabled = false;
                        idDichVuSelect.innerHTML = '<option value="">Đang tải dịch vụ...</option>';

                        fetch(`/Ticket/GetDichVu?idDanhMuc=${idDanhMuc}`)
                            .then(response => response.json())
                            .then(data => {
                                idDichVuSelect.innerHTML = '<option value="">Chọn dịch vụ...</option>';
                                
                                if (data && data.length > 0) {
                                    data.forEach(service => {
                                        const option = document.createElement('option');
                                        option.value = service.idDichVu;
                                        option.textContent = service.tenDichVu;
                                        if (selectedServiceId && service.idDichVu == selectedServiceId) {
                                            option.selected = true;
                                        }
                                        idDichVuSelect.appendChild(option);
                                    });
                                } else {
                                    const option = document.createElement('option');
                                    option.value = '';
                                    option.textContent = 'Không có dịch vụ nào';
                                    idDichVuSelect.appendChild(option);
                                }
                            })
                            .catch(error => {
                                console.error('Error loading services:', error);
                                idDichVuSelect.innerHTML = '<option value="">Lỗi tải dịch vụ</option>';
                            });
                    } else {
                        idDichVuSelect.disabled = true;
                        idDichVuSelect.innerHTML = '<option value="">Chọn danh mục trước...</option>';
                    }
                }

                // If category is pre-selected on page load
                if (initialCatId && initialCatId !== '0') {
                    idDanhMucSelect.value = initialCatId;
                    loadServicesForCategory(initialCatId, initialServiceId);
                }

                idDanhMucSelect.addEventListener('change', function () {
                    loadServicesForCategory(this.value, null);
                });
            }
        });
    </script>
