@model SupportTicketSysterm.ViewModels.ChiTietPhieuViewModel
@{
    Layout = null;
    ViewData["Title"] = "Chi tiết phiếu hỗ trợ";

    // Helpers for badges mapping
    string GetStatusClass(string status)
    {
        return (status?.ToLower()) switch
        {
            "chờ tiếp nhận" or "pending" or "chotiepnhan" => "status-pending",
            "đang xử lý" or "processing" or "dangxuly" => "status-processing",
            "chờ phản hồi" or "chokhachhangphanhoi" or "feedback" or "chophanhoidung" => "status-feedback",
            "hoàn thành" or "completed" or "dahoanthanh" => "status-completed",
            "đã hủy" or "cancelled" or "dahuy" => "status-cancelled",
            _ => "status-pending"
        };
    }

    string GetStatusText(string status)
    {
        return (status?.ToLower()) switch
        {
            "chờ tiếp nhận" or "pending" or "chotiepnhan" => "Chờ tiếp nhận",
            "đang xử lý" or "processing" or "dangxuly" => "Đang xử lý",
            "chờ phản hồi" or "chokhachhangphanhoi" or "feedback" or "chophanhoidung" => "Chờ phản hồi",
            "hoàn thành" or "completed" or "dahoanthanh" => "Đã hoàn thành",
            "đã hủy" or "cancelled" or "dahuy" => "Đã hủy",
            _ => status ?? "Chờ tiếp nhận"
        };
    }

    string GetPriorityClass(int priority)
    {
        return $"priority-{priority}";
    }

    string GetPriorityText(int priority)
    {
        return priority switch
        {
            1 => "Thấp",
            2 => "Trung bình",
            3 => "Cao",
            4 => "Khẩn cấp",
            _ => "Thấp"
        };
    }
}

<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>Chi Tiết Phiếu Hỗ Trợ - TechSupport Viettel</title>

    <!-- SEO Optimization -->
    <meta name="description" content="Chi tiết phiếu hỗ trợ kỹ thuật và tiến độ xử lý trực tuyến. TechSupport Viettel Telecom.">
    <meta name="robots" content="noindex, nofollow">

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="https://viettel.com.vn/favicon.ico">

    <!-- Bootstrap 5.3 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Font Awesome 6.6.0 CDN -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">

    <!-- Google Fonts Inter & Be Vietnam Pro -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- Core Stylesheets -->
    <link rel="stylesheet" href="~/assets/css/style.css">
    <link rel="stylesheet" href="~/assets/css/responsive.css">
    <link rel="stylesheet" href="~/assets/css/header.css">
    <link rel="stylesheet" href="~/assets/css/sidebar.css">
    <link rel="stylesheet" href="~/assets/css/footer.css">

    <!-- Custom Page CSS -->
    <link rel="stylesheet" href="~/assets/css/ticket-detail.css">
    <link rel="stylesheet" href="~/assets/css/phieu-cuatoi.css" asp-append-version="true">
    <link rel="stylesheet" href="~/assets/css/page-hero.css" asp-append-version="true">
</head>

<body>

    <!-- ==================== HEADER ==================== -->
    @await Html.PartialAsync("~/Views/Shared/_Header.cshtml", Context.Session)

    <!-- ==================== SIDEBAR ==================== -->
    <div id="sidebar-container"></div>

    <!-- ==================== HERO SECTION ==================== -->
    <section class="hero-section" aria-label="Chi tiết phiếu hỗ trợ">
        <div class="container hero-content">
            <div class="row align-items-center g-4">

                <!-- LEFT: text content -->
                <div class="col-lg-7 col-12 text-start hero-text-col animate-fade-up">

                    <!-- Breadcrumb Navigation -->
                    <nav aria-label="breadcrumb" class="hero-breadcrumb d-print-none">
                        <ol class="breadcrumb m-0" itemscope itemtype="https://schema.org/BreadcrumbList">
                            <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                                <a href="@Url.Action("TrangChu", "Customers")" itemprop="item" class="text-decoration-none d-inline-flex align-items-center">
                                    <i class="fa-solid fa-house-door-fill me-1"></i>
                                    <span itemprop="name">Trang chủ</span>
                                </a>
                                <meta itemprop="position" content="1" />
                            </li>
                            <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                                <a href="@Url.Action("PhieuCuaToi", "Customers")" itemprop="item" class="text-decoration-none">
                                    <span itemprop="name">Phiếu của tôi</span>
                                </a>
                                <meta itemprop="position" content="2" />
                            </li>
                            <li class="breadcrumb-item active" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" aria-current="page">
                                <span itemprop="name">Chi tiết phiếu</span>
                                <meta itemprop="position" content="3" />
                            </li>
                        </ol>
                    </nav>

                    <!-- Hero Badge -->
                    <span class="hero-badge">
                        <i class="fa-solid fa-ticket-fill me-1"></i> Phiếu hỗ trợ: @Model.MaPhieu
                    </span>

                    <!-- Title -->
                    <h1 class="hero-title text-uppercase mb-2">@Model.TieuDe</h1>

                    <!-- Description -->
                    <p class="hero-desc mb-3">
                        Theo dõi chi tiết tiến trình xử lý sự cố, xem lịch sử trao đổi, lịch hẹn và tương tác trực tiếp với kỹ thuật viên phụ trách.
                    </p>

                    <!-- Header Tags -->
                    <div class="d-flex flex-wrap align-items-center gap-2 mb-4">
                        <!-- Status Badge -->
                        <span class="tag-badge @GetStatusClass(Model.TrangThai)">
                            <i class="bi bi-clock-history"></i> @GetStatusText(Model.TrangThai)
                        </span>

                        <!-- Priority Badge -->
                        <span class="tag-badge @GetPriorityClass(Model.MucDoUuTien)">
                            <i class="bi bi-exclamation-triangle-fill"></i> Ưu tiên: @GetPriorityText(Model.MucDoUuTien)
                        </span>

                        <!-- Category Badge -->
                        <span class="tag-badge tag-info">
                            <i class="bi bi-folder"></i> @(Model.TenDanhMuc ?? "Dịch vụ mạng")
                        </span>

                        <!-- Request Type Badge -->
                        <span class="tag-badge tag-info">
                            <i class="bi bi-question-circle"></i> @Model.LoaiYeuCau
                        </span>

                        <!-- Created Date -->
                        <span class="tag-badge tag-info">
                            <i class="bi bi-calendar-event"></i> Ngày tạo: @Model.NgayTao.ToString("dd/MM/yyyy")
                        </span>
                    </div>

                    <!-- CTA Buttons -->
                    <div class="hero-cta-buttons d-flex flex-wrap gap-3 mt-3 d-print-none">
                        <a asp-controller="Customers" asp-action="PhieuCuaToi" class="btn btn-hero-contact px-4 py-2">
                            <i class="bi bi-arrow-left me-1"></i> Danh sách phiếu
                        </a>
                        <a asp-controller="Ticket" asp-action="InPhieuPDF" asp-route-id="@Model.IdPhieu" class="btn btn-hero-create px-4 py-2">
                            <i class="fa-solid fa-file-pdf me-1"></i> In Phiếu PDF
                        </a>
                    </div>

                    <!-- Quick Stats -->
                    <div class="lk-hero-stats d-flex flex-wrap gap-3 mt-4 d-print-none">
                        <div class="lk-hero-stat-item">
                            <span class="lk-hero-stat-num" style="color:#D71920">24/7</span>
                            <span class="lk-hero-stat-label">Hỗ trợ kỹ thuật</span>
                        </div>
                        <div class="lk-hero-stat-sep"></div>
                        <div class="lk-hero-stat-item">
                            <span class="lk-hero-stat-num" style="color:#3B82F6">&lt; 30p</span>
                            <span class="lk-hero-stat-label">Thời gian phản hồi</span>
                        </div>
                        <div class="lk-hero-stat-sep"></div>
                        <div class="lk-hero-stat-item">
                            <span class="lk-hero-stat-num" style="color:#10B981">100%</span>
                            <span class="lk-hero-stat-label">Bảo mật thông tin</span>
                        </div>
                    </div>
                </div>

                <!-- RIGHT: SVG Illustration Banner -->
                <div class="col-lg-5 col-12 hero-banner-wrapper animate-fade-up delay-1 d-print-none">
                    <svg class="hero-banner-svg" viewBox="0 0 500 420" xmlns="http://www.w3.org/2000/svg" aria-label="Chi tiết phiếu hỗ trợ">
                        <defs>
                            <linearGradient id="tdGradRed" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#D71920" />
                                <stop offset="100%" stop-color="#ff4d6d" />
                            </linearGradient>
                            <linearGradient id="tdGradDark" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#1f2937" />
                                <stop offset="100%" stop-color="#111827" />
                            </linearGradient>
                            <linearGradient id="tdGradBlue" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#3B82F6" />
                                <stop offset="100%" stop-color="#2563EB" />
                            </linearGradient>
                            <linearGradient id="tdGradGreen" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#10B981" />
                                <stop offset="100%" stop-color="#059669" />
                            </linearGradient>
                        </defs>

                        <!-- Background decorative circles -->
                        <circle cx="250" cy="210" r="175" fill="url(#tdGradRed)" opacity="0.04" />
                        <circle cx="400" cy="80" r="65" fill="url(#tdGradRed)" opacity="0.06" />

                        <!-- Main Ticket Detail Dashboard Card -->
                        <rect x="40" y="50" width="380" height="310" rx="24" fill="#ffffff" stroke="rgba(15,17,21,0.05)" stroke-width="2" filter="drop-shadow(0 20px 40px rgba(0,0,0,0.07))" />

                        <!-- Header bar -->
                        <path d="M40 74 C40 60.85 50.85 50 64 50 L396 50 C409.15 50 420 60.85 420 74 L420 95 L40 95 Z" fill="url(#tdGradDark)" />
                        <!-- Traffic lights -->
                        <circle cx="65" cy="72" r="5" fill="#D71920" />
                        <circle cx="81" cy="72" r="5" fill="#eab308" />
                        <circle cx="97" cy="72" r="5" fill="#10b981" />

                        <!-- Ticket Details graphic on screen -->
                        <rect x="60" y="115" width="320" height="40" rx="8" fill="#F8FAFC" stroke="#E2E8F0" stroke-width="1" />
                        <rect x="75" y="127" width="90" height="8" rx="3" fill="url(#tdGradRed)" opacity="0.85" />
                        <rect x="75" y="139" width="160" height="6" rx="2" fill="#94A3B8" />

                        <!-- Status badge on illustration -->
                        <rect x="290" y="125" width="75" height="20" rx="10" fill="url(#tdGradBlue)" />
                        <circle cx="302" cy="135" r="4" fill="#ffffff" />
                        <rect x="312" y="132" width="42" height="6" rx="3" fill="#ffffff" />

                        <!-- Timeline step graphic 1 -->
                        <circle cx="75" cy="185" r="10" fill="url(#tdGradGreen)" />
                        <path d="M71 185 L74 188 L80 182" stroke="#fff" stroke-width="2" fill="none" stroke-linecap="round" />
                        <rect x="95" y="180" width="120" height="8" rx="3" fill="#334155" />
                        <rect x="95" y="192" width="180" height="6" rx="2" fill="#94A3B8" />

                        <!-- Timeline step graphic 2 -->
                        <line x1="75" y1="195" x2="75" y2="225" stroke="#CBD5E1" stroke-width="2" stroke-dasharray="3 3" />
                        <circle cx="75" cy="235" r="10" fill="url(#tdGradBlue)" />
                        <circle cx="75" cy="235" r="4" fill="#ffffff" />
                        <rect x="95" y="230" width="140" height="8" rx="3" fill="#334155" />
                        <rect x="95" y="242" width="160" height="6" rx="2" fill="#94A3B8" />

                        <!-- Timeline step graphic 3 -->
                        <line x1="75" y1="245" x2="75" y2="275" stroke="#CBD5E1" stroke-width="2" stroke-dasharray="3 3" />
                        <circle cx="75" cy="285" r="10" fill="#E2E8F0" />
                        <rect x="95" y="280" width="110" height="8" rx="3" fill="#94A3B8" />
                        <rect x="95" y="292" width="130" height="6" rx="2" fill="#CBD5E1" />

                        <!-- Floating Badge -->
                        <g transform="translate(320, 290)">
                            <rect x="0" y="0" width="115" height="55" rx="14" fill="url(#tdGradRed)" filter="drop-shadow(0 8px 16px rgba(215,25,32,0.25))" />
                            <circle cx="28" cy="28" r="14" fill="rgba(255,255,255,0.2)" />
                            <path d="M22 28 L26 32 L34 24" stroke="#ffffff" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round" />
                            <rect x="50" y="20" width="52" height="6" rx="3" fill="#ffffff" />
                            <rect x="50" y="31" width="38" height="5" rx="2.5" fill="rgba(255,255,255,0.7)" />
                        </g>
                    </svg>
                </div>

            </div>
        </div>
    </section>

    <!-- MAIN WORKSPACE -->
    <main class="workspace-area">
        <div class="container">

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success border-0 rounded-3 mb-3 animate-fade-up">
                    <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger border-0 rounded-3 mb-3 animate-fade-up">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["ErrorMessage"]
                </div>
            }

            <!-- COLUMN LAYOUT -->
            <div class="row g-4">
                
                <!-- LEFT COLUMN (Main Details) -->
                <div class="col-lg-8 col-md-12">
                    
                    <!-- CARD 1: THÔNG TIN TỔNG QUAN -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon red">
                                <i class="fa-solid fa-file-lines"></i>
                            </div>
                            <h2 class="detail-card-title">Mô tả sự cố & yêu cầu</h2>
                        </div>
                        <div class="detail-card-body">
                            <div class="data-grid mb-3">
                                <div class="data-cell full-width">
                                    <span class="cell-lbl"><i class="fa-solid fa-pen-fancy"></i> Tiêu đề</span>
                                    <span class="cell-val text-danger">@Model.TieuDe</span>
                                </div>
                            </div>
                            <div class="data-cell full-width">
                                <span class="cell-lbl mb-2"><i class="fa-solid fa-align-left"></i> Nội dung chi tiết</span>
                                <p class="desc-box">@Model.NoiDung</p>
                            </div>
                        </div>
                    </div>

                    <!-- CARD 2: LỊCH HẸN KHẢO SÁT/XỬ LÝ -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon blue">
                                <i class="fa-solid fa-calendar-days"></i>
                            </div>
                            <h2 class="detail-card-title">Lịch hẹn hỗ trợ tại nhà</h2>
                        </div>
                        <div class="detail-card-body">
                            <div class="lh-container">
                                @if (Model.LichHens.Any())
                                {
                                    <div class="lh-timeline">
                                        @foreach (var item in Model.LichHens)
                                        {
                                            var statusClass = item.TrangThai switch
                                            {
                                                "Đã xác nhận" => "lh-status-confirmed",
                                                "Chờ xác nhận" => "lh-status-waiting",
                                                "Đã hoàn thành" => "lh-status-completed",
                                                "Đã hủy" => "lh-status-cancelled",
                                                _ => "lh-status-waiting"
                                            };

                                            <div class="lh-item animate-fade-up">
                                                <div class="lh-header">
                                                    <span class="lh-id">Mã lịch hẹn: LH-@item.IdLichHen.ToString("D5")</span>
                                                    <span class="lh-badge @statusClass">
                                                        <span class="status-dot"></span> @item.TrangThai
                                                    </span>
                                                </div>
                                                <div class="lh-body">
                                                    <div class="lh-info-row">
                                                        <div class="lh-info-col">
                                                            <div class="lh-info-label">📅 Ngày hẹn</div>
                                                            <div class="lh-info-value">@(item.NgayHen?.ToString("dd/MM/yyyy") ?? "—")</div>
                                                        </div>
                                                        <div class="lh-info-col">
                                                            <div class="lh-info-label">🕐 Giờ hẹn</div>
                                                            <div class="lh-info-value">@(item.GioHen?.ToString(@"hh\:mm") ?? "—")</div>
                                                        </div>
                                                    </div>

                                                    <div class="lh-info-field">
                                                        <div class="lh-info-label">📍 Địa chỉ</div>
                                                        <div class="lh-info-value">@(item.DiaChi ?? "—")</div>
                                                    </div>

                                                    <div class="lh-info-row">
                                                        <div class="lh-info-col">
                                                            <div class="lh-info-label">👨‍🔧 Kỹ thuật viên</div>
                                                            <div class="lh-info-value">@(item.HoTenNhanVien ?? "Chưa phân công")</div>
                                                        </div>
                                                        <div class="lh-info-col">
                                                            <div class="lh-info-label">📞 Điện thoại</div>
                                                            <div class="lh-info-value">
                                                                @if (!string.IsNullOrEmpty(item.SoDienThoai))
                                                                {
                                                                    <a href="tel:@item.SoDienThoai" class="lh-phone-link">@item.SoDienThoai</a>
                                                                }
                                                                else
                                                                {
                                                                    <span>—</span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </div>

                                                    @if (!string.IsNullOrEmpty(item.GhiChu))
                                                    {
                                                        <div class="lh-notes-box">
                                                            <div class="lh-info-label">📝 Ghi chú</div>
                                                            <div class="lh-notes-content">@item.GhiChu</div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="lh-empty-state">
                                        <span class="lh-empty-icon">📅</span>
                                        <h3 class="lh-empty-title">Chưa có lịch hẹn</h3>
                                        <p class="lh-empty-desc">Hiện tại chưa có lịch hẹn kỹ thuật viên khảo sát tại nhà.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- CARD 3: TIMELINE LỊCH SỬ XỬ LÝ -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon red">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                            </div>
                            <h2 class="detail-card-title">Nhật ký & Tiến trình xử lý</h2>
                        </div>
                        <div class="detail-card-body">
                            <div class="timeline-flow">
                                @if (Model.LichSuXuLys != null && Model.LichSuXuLys.Any())
                                {
                                    @foreach (var step in Model.LichSuXuLys)
                                    {
                                        <div class="timeline-step">
                                            <div class="timeline-dot" style="display: flex; align-items: center; justify-content: center; background-color: var(--vt-red-glow);">
                                                <i class="fa-solid @(step.TrangThaiMoi switch {
                                                    "Chờ tiếp nhận" => "fa-circle-question text-warning",
                                                    "Đang xử lý" => "fa-spinner text-primary",
                                                    "Hoàn thành" => "fa-circle-check text-success",
                                                    "Đã hủy" => "fa-circle-xmark text-danger",
                                                    _ => "fa-info-circle text-info"
                                                })" style="font-size: 0.75rem;"></i>
                                            </div>
                                            <div class="timeline-card">
                                                <div class="timeline-header">
                                                    <span class="timeline-op-name"><i class="bi bi-person-badge text-danger me-1"></i> @step.TenNhanVien</span>
                                                    <span class="timeline-date">@step.ThoiGian</span>
                                                </div>
                                                <p class="timeline-desc">@step.NoiDung</p>
                                                @if (!string.IsNullOrEmpty(step.TrangThaiCu) && !string.IsNullOrEmpty(step.TrangThaiMoi) && step.TrangThaiCu != step.TrangThaiMoi)
                                                {
                                                    <div class="timeline-status-change">
                                                        <span>Trạng thái: </span>
                                                        <span class="status-old">@GetStatusText(step.TrangThaiCu)</span>
                                                        <i class="bi bi-arrow-right"></i>
                                                        <span class="status-new">@GetStatusText(step.TrangThaiMoi)</span>
                                                    </div>
                                                }
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="empty-state-box py-4">
                                        <i class="bi bi-clock empty-state-icon"></i>
                                        <h3 class="empty-state-title">Chưa có nhật ký hoạt động</h3>
                                        <p class="empty-state-desc">Phiếu hỗ trợ chưa phát sinh lịch sử xử lý.</p>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- CARD 4: TÀI LIỆU & FILE ĐÍNH KÈM -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon green">
                                <i class="fa-solid fa-paperclip"></i>
                            </div>
                            <h2 class="detail-card-title">Tài liệu & file đính kèm</h2>
                        </div>
                        <div class="detail-card-body">
                            @if (Model.FileDinhKems != null && Model.FileDinhKems.Any())
                            {
                                <div class="attach-grid">
                                    @foreach (var file in Model.FileDinhKems)
                                    {
                                        var isImg = file.LoaiFile != null && (file.LoaiFile.StartsWith("image/", StringComparison.OrdinalIgnoreCase) || 
                                                     file.TenFile.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || 
                                                     file.TenFile.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || 
                                                     file.TenFile.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                                                     file.TenFile.EndsWith(".gif", StringComparison.OrdinalIgnoreCase) ||
                                                     file.TenFile.EndsWith(".webp", StringComparison.OrdinalIgnoreCase));
                                        
                                        var isPdf = file.TenFile.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase);
                                        var isWord = file.TenFile.EndsWith(".doc", StringComparison.OrdinalIgnoreCase) || file.TenFile.EndsWith(".docx", StringComparison.OrdinalIgnoreCase);
                                        var isExcel = file.TenFile.EndsWith(".xls", StringComparison.OrdinalIgnoreCase) || file.TenFile.EndsWith(".xlsx", StringComparison.OrdinalIgnoreCase);
                                        
                                        var fileIcon = "bi-file-earmark-fill text-secondary";
                                        if (isImg) fileIcon = "bi-file-earmark-image-fill text-primary";
                                        else if (isPdf) fileIcon = "bi-file-earmark-pdf-fill text-danger";
                                        else if (isWord) fileIcon = "bi-file-earmark-word-fill text-primary";
                                        else if (isExcel) fileIcon = "bi-file-earmark-excel-fill text-success";
                                        
                                        var fileTypeLabel = "Khác";
                                        if (isImg) fileTypeLabel = "Hình ảnh";
                                        else if (isPdf) fileTypeLabel = "PDF";
                                        else if (isWord) fileTypeLabel = "Word";
                                        else if (isExcel) fileTypeLabel = "Excel";

                                        <div class="attach-card d-flex flex-column" style="min-height: 100%;">
                                            @if (isImg)
                                            {
                                                <div class="attach-image-preview mb-3" style="width: 100%; height: 160px; overflow: hidden; border-radius: 12px; border: 1.5px solid var(--border-color); background-color: #f8fafc; position: relative;">
                                                    <a href="@file.DuongDan" target="_blank" title="Xem ảnh đầy đủ" style="display: block; width: 100%; height: 100%;">
                                                        <img src="@file.DuongDan" alt="@file.TenFile" style="width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s ease;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'" />
                                                    </a>
                                                </div>
                                            }
                                            <div class="attach-info-row d-flex align-items-start gap-2 flex-grow-1">
                                                <div class="attach-file-icon" style="font-size: 1.5rem; flex-shrink: 0; line-height: 1;">
                                                    <i class="bi @fileIcon"></i>
                                                </div>
                                                <div style="min-width: 0; flex: 1;">
                                                    <span class="attach-file-name fw-bold text-dark text-truncate d-block" title="@file.TenFile" style="font-size: 0.88rem;">@file.TenFile</span>
                                                    <span class="attach-file-size text-muted small d-block" style="font-size: 0.75rem; margin-top: 2px;">
                                                        Loại: <strong>@fileTypeLabel</strong> | Dung lượng: <strong>@file.DungLuong</strong>
                                                    </span>
                                                    <span class="attach-file-size text-muted small d-block" style="font-size: 0.72rem; margin-top: 2px;">
                                                        Người tải: <strong>@file.NguoiTai</strong> | @file.NgayUpload
                                                    </span>
                                                </div>
                                            </div>
                                            <div class="d-flex gap-2 mt-3">
                                                <a href="@file.DuongDan" class="btn btn-outline-secondary btn-sm flex-grow-1" target="_blank">
                                                    <i class="bi bi-eye"></i> Xem
                                                </a>
                                                <a href="@file.DuongDan" class="btn btn-danger btn-sm flex-grow-1" style="background-color: #EE0033; border-color: #EE0033;" download="@file.TenFile">
                                                    <i class="bi bi-download"></i> Tải về
                                                </a>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-box">
                                    <i class="bi bi-folder-symlink empty-state-icon"></i>
                                    <h3 class="empty-state-title">Không có tệp đính kèm</h3>
                                    <p class="empty-state-desc">Phiếu hỗ trợ này chưa được đính kèm bất kỳ hình ảnh hoặc tài liệu nào.</p>
                                </div>
                            }
                        </div>
                    </div>

                </div>

                <!-- RIGHT COLUMN (Metadata/Side Cards) -->
                <div class="col-lg-4 col-md-12">
                    
                    <!-- CARD 5: THÔNG TIN KHÁCH HÀNG -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon red">
                                <i class="fa-solid fa-user-tie"></i>
                            </div>
                            <h2 class="detail-card-title">Thông tin khách hàng</h2>
                        </div>
                        <div class="detail-card-body">
                            <div class="d-flex flex-column gap-3">
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-person-fill"></i> Họ và tên</span>
                                    <span class="cell-val">@Model.HoTen</span>
                                </div>
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-telephone-fill"></i> Số điện thoại</span>
                                    <span class="cell-val">@Model.SoDienThoai</span>
                                </div>
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-envelope-fill"></i> Email</span>
                                    <span class="cell-val">@Model.Email</span>
                                </div>
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-geo-alt-fill"></i> Địa chỉ</span>
                                    <span class="cell-val">@(Model.DiaChiKhachHang ?? "Chưa cung cấp")</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CARD 6: THÔNG TIN DỊCH VỤ -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon blue">
                                <i class="fa-solid fa-network-wired"></i>
                            </div>
                            <h2 class="detail-card-title">Dịch vụ yêu cầu</h2>
                        </div>
                        <div class="detail-card-body">
                            <div class="d-flex flex-column gap-3">
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-tag-fill"></i> Danh mục sự cố</span>
                                    <span class="cell-val">@Model.TenDanhMuc</span>
                                </div>
                                <div class="data-cell">
                                    <span class="cell-lbl"><i class="bi bi-hdd-network-fill"></i> Dịch vụ chi tiết</span>
                                    <span class="cell-val text-danger">@Model.TenDichVu</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- CARD 7: NHÂN VIÊN PHỤ TRÁCH -->
                    <div class="detail-card">
                        <div class="detail-card-head">
                            <div class="card-icon red">
                                <i class="bi bi-person-badge-fill"></i>
                            </div>
                            <h2 class="detail-card-title">Kỹ thuật viên phụ trách</h2>
                        </div>
                        <div class="detail-card-body">
                            @if (!string.IsNullOrEmpty(Model.TenNhanVien))
                            {
                                <div class="d-flex flex-column gap-3">
                                    <div class="data-cell">
                                        <span class="cell-lbl"><i class="bi bi-person-check-fill"></i> Họ tên</span>
                                        <span class="cell-val">@Model.TenNhanVien</span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.MaNhanVien))
                                    {
                                        <div class="data-cell">
                                            <span class="cell-lbl"><i class="bi bi-hash"></i> Mã nhân viên</span>
                                            <span class="cell-val">@Model.MaNhanVien</span>
                                        </div>
                                    }
                                    <div class="data-cell">
                                        <span class="cell-lbl"><i class="bi bi-telephone-outbound-fill"></i> Điện thoại liên hệ</span>
                                        <span class="cell-val"><a href="tel:@Model.SoDienThoaiNV" class="text-danger text-decoration-none fw-bold">@Model.SoDienThoaiNV</a></span>
                                    </div>
                                    @if (!string.IsNullOrEmpty(Model.EmailNV))
                                    {
                                        <div class="data-cell">
                                            <span class="cell-lbl"><i class="bi bi-envelope-at-fill"></i> Email</span>
                                            <span class="cell-val">@Model.EmailNV</span>
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.VaiTroNV))
                                    {
                                        <div class="data-cell">
                                            <span class="cell-lbl"><i class="bi bi-briefcase-fill"></i> Vai trò</span>
                                            <span class="cell-val">@Model.VaiTroNV</span>
                                        </div>
                                    }
                                </div>
                                <div class="mt-3 pt-2 border-top">
                                    <a href="/LiveSupport?maPhieu=@Model.MaPhieu" class="btn btn-viettel btn-red w-100 d-inline-flex align-items-center justify-content-center gap-2" style="background-color: #EE0033 !important; color: white !important; font-weight: 700; border: none; padding: 10px; border-radius: 8px;">
                                        <i class="bi bi-chat-dots-fill"></i> Trao đổi nhân viên
                                    </a>
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-box py-3 bg-light border-0">
                                    <i class="bi bi-person-x-fill empty-state-icon text-muted" style="font-size: 2rem;"></i>
                                    <h4 class="empty-state-title fs-6 text-muted">Chưa phân công nhân viên</h4>
                                    <p class="empty-state-desc" style="font-size: 0.75rem;">Yêu cầu hỗ trợ đang được tiếp nhận và điều phối kỹ thuật viên.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- CARD 8: ĐÁNH GIÁ DỊCH VỤ -->
                    <div class="detail-card" id="card-danh-gia">
                        <div class="detail-card-head">
                            <div class="card-icon green">
                                <i class="fa-solid fa-star"></i>
                            </div>
                            <h2 class="detail-card-title">Đánh giá của bạn</h2>
                        </div>
                        <div class="detail-card-body">
                            @if (Model.DanhGia != null)
                            {
                                <div class="d-flex flex-column">
                                    <div class="rating-metric-item">
                                        <span class="rating-metric-lbl">Chất lượng dịch vụ</span>
                                        <div class="rating-stars-row">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= Model.DanhGia.ChatLuongDichVu ? "bi-star-fill" : "bi-star")"></i>
                                            }
                                        </div>
                                    </div>
                                    <div class="rating-metric-item">
                                        <span class="rating-metric-lbl">Thái độ kỹ thuật viên</span>
                                        <div class="rating-stars-row">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= Model.DanhGia.ThaiDoNhanVien ? "bi-star-fill" : "bi-star")"></i>
                                            }
                                        </div>
                                    </div>
                                    <div class="rating-metric-item">
                                        <span class="rating-metric-lbl">Tốc độ xử lý sự cố</span>
                                        <div class="rating-stars-row">
                                            @for (int i = 1; i <= 5; i++)
                                            {
                                                <i class="bi @(i <= Model.DanhGia.TocDoXuLy ? "bi-star-fill" : "bi-star")"></i>
                                            }
                                        </div>
                                    </div>

                                    @if (!string.IsNullOrEmpty(Model.DanhGia.NhanXet))
                                    {
                                        <div class="review-comment-box">
                                            <span class="review-comment-title"><i class="bi bi-chat-quote-fill me-1"></i> Ý kiến đóng góp</span>
                                            <p class="review-comment-desc">"@Model.DanhGia.NhanXet"</p>
                                            <small class="text-muted d-block mt-2 text-end">Ngày gửi: @Model.DanhGia.NgayDanhGia?.ToString("dd/MM/yyyy")</small>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="empty-state-box py-4 bg-light border-0">
                                    <i class="bi bi-star empty-state-icon text-muted" style="font-size: 2rem;"></i>
                                    <h4 class="empty-state-title fs-6 text-muted">Chưa đánh giá</h4>
                                    <p class="empty-state-desc" style="font-size: 0.75rem;">Yêu cầu hỗ trợ chưa được đánh giá chất lượng dịch vụ.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- CARD 9: PHẢN HỒI TỪ NHÂN VIÊN -->
                    @if (Model.DanhGia != null)
                    {
                        if (Model.DaPhanHoi)
                        {
                            <div class="detail-card feedback-card animate-fade-up mt-3">
                                <div class="detail-card-head border-0 pb-0 mb-3 bg-transparent">
                                    <div class="card-icon">
                                        <i class="fa-solid fa-reply"></i>
                                    </div>
                                    <h2 class="detail-card-title text-dark">Phản hồi từ Nhân viên hỗ trợ</h2>
                                </div>
                                <div class="detail-card-body p-0">
                                    <div class="d-flex align-items-center mb-3">
                                        <div class="avatar-wrap me-3">
                                            <img src="@(string.IsNullOrEmpty(Model.AvatarNhanVien) ? "https://ui-avatars.com/api/?name=" + System.Net.WebUtility.UrlEncode(Model.TenNhanVienPhanHoi ?? "Staff") + "&background=EE0033&color=fff" : Model.AvatarNhanVien)" alt="Avatar nhân viên phản hồi" />
                                        </div>
                                        <div>
                                            <h4 class="m-0 fw-bold text-dark fs-6">@Model.TenNhanVienPhanHoi</h4>
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary" style="font-size: 0.7rem; font-weight: 700; padding: 2px 6px;">Nhân viên Hỗ trợ</span>
                                                <span class="text-muted" style="font-size: 0.75rem;"><i class="bi bi-clock me-1"></i>@(Model.NgayPhanHoi?.ToString("dd/MM/yyyy HH:mm"))</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="feedback-content-box p-3 bg-white border rounded-3">
                                        @Model.PhanHoiNhanVien
                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="detail-card feedback-card pending animate-fade-up mt-3">
                                <div class="detail-card-head border-0 pb-0 mb-3 bg-transparent align-items-center">
                                    <div class="card-icon">
                                        <i class="bi bi-clock-history"></i>
                                    </div>
                                    <h2 class="detail-card-title text-dark">Phản hồi từ Nhân viên hỗ trợ</h2>
                                    <span class="badge bg-warning-subtle text-warning border border-warning ms-auto" style="font-size: 0.72rem; font-weight: 700; padding: 4px 8px; background-color: #FFFBEB !important;">Chưa phản hồi</span>
                                </div>
                                <div class="detail-card-body p-0">
                                    <p class="m-0 fw-bold text-warning-emphasis" style="font-size: 0.9rem;"><i class="bi bi-exclamation-circle-fill me-1"></i> Nhân viên chưa phản hồi đánh giá của bạn.</p>
                                </div>
                            </div>
                        }
                    }

                </div>

            </div>

            <!-- ACTION BUTTONS BAR -->
            <div class="action-buttons-layout">
                <div class="action-btn-group">
                    <a asp-controller="Customers" asp-action="PhieuCuaToi" class="btn btn-viettel btn-outline" style="color: white !important;">
                        <i class="bi bi-arrow-left"></i> Danh sách phiếu
                    </a>
                    @if (!string.IsNullOrEmpty(Model.TenNhanVien))
                    {
                        <a href="/LiveSupport?maPhieu=@Model.MaPhieu" class="btn btn-viettel btn-red" style="background-color: #EE0033 !important; color: white !important; border: none !important;">
                            <i class="bi bi-chat-dots-fill"></i> Trao đổi nhân viên
                        </a>
                    }
                    else
                    {
                        <a asp-controller="Customers" asp-action="LienHe" class="btn btn-viettel btn-outline">
                            <i class="bi bi-telephone-inbound"></i> Liên hệ hỗ trợ
                        </a>
                    }
                </div>

                <div class="action-btn-group">
                    <a asp-controller="Ticket" asp-action="InPhieu" asp-route-id="@Model.IdPhieu" class="btn btn-viettel btn-outline">
                        <i class="bi bi-printer"></i> In phiếu hỗ trợ
                    </a>
                    <a asp-controller="Ticket" asp-action="InPhieuPDF" asp-route-id="@Model.IdPhieu" class="btn btn-viettel btn-red" style="background-color: #EE0033 !important; color: white !important; border: none !important;">
                        <i class="fa-solid fa-print"></i> In Phiếu
                    </a>

                    @if ((Model.TrangThai == "Hoàn thành" || Model.TrangThai == "DaHoanThanh" || Model.TrangThai == "Đã hoàn thành") && Model.DanhGia == null)
                    {
                        <a asp-controller="Ticket" asp-action="DanhGiaPhieu" asp-route-id="@Model.IdPhieu" class="btn btn-viettel btn-red">
                            <i class="bi bi-star"></i> Đánh giá dịch vụ
                        </a>
                    }
                </div>
            </div>

        </div>
    </main>

    <!-- ==================== FOOTER ==================== -->
    @await Html.PartialAsync("_Footer")

    <!-- Auto Print Script Triggers -->
    @if (ViewData["IsPrint"] is bool isPrint && isPrint)
    {
        <script>
            window.addEventListener('DOMContentLoaded', () => {
                setTimeout(() => {
                    window.print();
                }, 500);
            });
        </script>
    }

    <!-- Chatbox Staff Communication Script -->
    <script>
        function openChatWithStaff() {
            // Open chatbox launcher
            const launcher = document.getElementById('chatLauncher');
            const windowEl = document.getElementById('chatWindow');
            
            if (launcher && windowEl) {
                // Open chatbox if closed
                if (!windowEl.classList.contains('open')) {
                    launcher.click();
                }
                
                // Navigate to conversations screen after a short delay
                setTimeout(() => {
                    if (window.TechSupportChat && window.TechSupportChat.openConversation) {
                        // Check if there's an existing conversation for this ticket
                        // For now, navigate to conversations list
                        const btnGoConversations = document.getElementById('btnGoConversations');
                        if (btnGoConversations) {
                            btnGoConversations.click();
                        }
                    }
                }, 300);
            }
    <!-- ==================== SCRIPTS ==================== -->
    <!-- Bootstrap 5.3 JS Bundle -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"
            integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz"
            crossorigin="anonymous"></script>

    <!-- Component-Based scripts -->
    <script src="~/assets/js/header.js" asp-append-version="true"></script>
    <script src="~/assets/js/chatbox.js" asp-append-version="true"></script>
    <script src="~/assets/js/main.js" asp-append-version="true"></script>
    <script>
        if (window.initHeader) {
            window.initHeader();
        }
    </script>
</body>

</html>